---
import LayoutJa from '../../layouts/LayoutJa.astro';
import Hero from '../../components/Hero.astro';
import AlphaMissense from '../../components-ja/AlphaMissense.astro';
import Conservation from '../../components-ja/Conservation.astro';
import Structure3D from '../../components-ja/Structure3D.astro';
import Pseudogene from '../../components-ja/Pseudogene.astro';
import ACMG from '../../components-ja/ACMG.astro';
import MiniSTRC from '../../components-ja/MiniSTRC.astro';
import PrimeEditing from '../../components-ja/PrimeEditing.astro';
import MethodReclass from '../../components-ja/MethodReclass.astro';
import MethodResearch from '../../components-ja/MethodResearch.astro';
import ToolsGrid from '../../components-ja/ToolsGrid.astro';

const variants = [
  { aa: 'A', score: 0.9016, misha: true },
  { aa: 'C', score: 0.9984 }, { aa: 'D', score: 0.9483 },
  { aa: 'F', score: 0.9992 }, { aa: 'G', score: 0.9191 },
  { aa: 'H', score: 0.9927 }, { aa: 'I', score: 0.9923 },
  { aa: 'K', score: 0.9272 }, { aa: 'L', score: 0.9929 },
  { aa: 'M', score: 0.9909 }, { aa: 'N', score: 0.9822 },
  { aa: 'P', score: 0.9985 }, { aa: 'Q', score: 0.846 },
  { aa: 'R', score: 0.9634 }, { aa: 'S', score: 0.9433 },
  { aa: 'T', score: 0.9666 }, { aa: 'V', score: 0.9664 },
  { aa: 'W', score: 0.9997 }, { aa: 'Y', score: 0.9981 },
];

const timeline = [
  { year: '2021年12月', event: 'Shubina-Oleinik et al. (Science Advances): マウスにおける初の二重AAV STRC遺伝子治療。概念実証。DOI: 10.1126/sciadv.abi7629' },
  { year: '2022年12月', event: '香港小児病院でWES実施。STRC欠失（父方）+ VUSミスセンス変異（母方）確認。ラボ番号: 23C7500174。' },
  { year: '2023年12月', event: '親検査確認によりWESレポート更新。複合ヘテロ接合STRC確認。' },
  { year: '2025年', event: 'OTOF遺伝子治療試験: 11/12人の子どもが聴力改善 (DB-OTO, NEJM 2025)。3人が正常聴力達成。内耳遺伝子治療の先例。' },
  { year: '2026年1月', event: 'Iranfar et al. (Clinical and Translational Medicine): Dual AAV9-PHP.eBがSTRCマウスの聴力をほぼ正常閾値まで回復。外有毛細胞導入効率60%。周波数識別が100日まで回復。DOI: 10.1002/ctm2.70571', highlight: true },
  { year: '2026年3月', event: 'AlphaMissense解析: E1659Aスコア0.9016（病原性の可能性が高い）。ACMG再分類エビデンス: PM3 + PP3_中等度 + PM2_補助的 = 病原性の可能性が高い。', highlight: true },
  { year: '~2028-29年', event: 'STRC遺伝子治療の初のヒト臨床試験が期待される。患者は7〜8歳になる予定。注: マウスの治療窓 = P0-P5; ヒトではおそらくより広いが、早期介入が重要。', future: true },
];
---

<LayoutJa>
  <Hero lang="ja" />

  <!-- ═══════════════════════════════════════════ -->
  <!-- 第1部：再分類の証拠 -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">第1部</span>
      <h2 class="text-lg font-bold mt-1">再分類のエビデンス</h2>
      <p class="text-xs text-neutral-400 mt-1">NM_153700.2:c.4976A>C p.(Glu1659Ala) の VUS から病原性の可能性が高いへの再分類を支持する計算論的エビデンス</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <AlphaMissense variants={variants} />
  <Conservation />
  <Structure3D />
  <Pseudogene />
  <ACMG />

  <!-- ═══════════════════════════════════════════ -->
  <!-- 第2部：研究仮説 -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">第2部</span>
      <h2 class="text-lg font-bold mt-1">研究仮説</h2>
      <p class="text-xs text-neutral-400 mt-1">STRC遺伝子治療を加速するための計算論的仮説。実験的検証が必要です。</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <MiniSTRC />
  <PrimeEditing />

  <!-- ═══════════════════════════════════════════ -->
  <!-- 第3部：方法論 -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">第3部</span>
      <h2 class="text-lg font-bold mt-1">実施方法</h2>
      <p class="text-xs text-neutral-400 mt-1">誰でも結果を再現できるよう、ステップごとの方法論</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <MethodReclass />
  <MethodResearch />
  <ToolsGrid />
</LayoutJa>
