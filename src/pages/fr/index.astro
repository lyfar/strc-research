---
import LayoutFr from '../../layouts/LayoutFr.astro';
import Hero from '../../components/Hero.astro';
import AlphaMissense from '../../components-fr/AlphaMissense.astro';
import Conservation from '../../components-fr/Conservation.astro';
import Structure3D from '../../components-fr/Structure3D.astro';
import Pseudogene from '../../components-fr/Pseudogene.astro';
import ACMG from '../../components-fr/ACMG.astro';
import MiniSTRC from '../../components-fr/MiniSTRC.astro';
import PrimeEditing from '../../components-fr/PrimeEditing.astro';
import MethodReclass from '../../components-fr/MethodReclass.astro';
import MethodResearch from '../../components-fr/MethodResearch.astro';
import ToolsGrid from '../../components-fr/ToolsGrid.astro';

const variants = [
  { aa: 'A', score: 0.9016, misha: true },
  { aa: 'C', score: 0.9984 }, { aa: 'D', score: 0.9483 },
  { aa: 'F', score: 0.9992 }, { aa: 'G', score: 0.9191 },
  { aa: 'H', score: 0.9927 }, { aa: 'I', score: 0.9923 },
  { aa: 'K', score: 0.9272 }, { aa: 'L', score: 0.9929 },
  { aa: 'M', score: 0.9909 }, { aa: 'N', score: 0.9822 },
  { aa: 'P', score: 0.9985 }, { aa: 'Q', score: 0.846 },
  { aa: 'R', score: 0.9634 }, { aa: 'S', score: 0.9433 },
  { aa: 'T', score: 0.9666 }, { aa: 'V', score: 0.9664 },
  { aa: 'W', score: 0.9997 }, { aa: 'Y', score: 0.9981 },
];

const timeline = [
  { year: 'Déc. 2021', event: 'Shubina-Oleinik et al. (Science Advances) : Première thérapie génique STRC double-AAV chez la souris. Preuve de concept. DOI : 10.1126/sciadv.abi7629' },
  { year: 'Déc. 2022', event: 'WES réalisé à l\'Hôpital pour enfants de Hong Kong. Délétion STRC (paternelle) + variant de signification incertaine faux-sens (maternelle) identifiés. Nº de labo : 23C7500174.' },
  { year: 'Déc. 2023', event: 'Rapport WES mis à jour avec confirmation des tests parentaux. STRC hétérozygote composite confirmé.' },
  { year: '2025', event: 'Essais de thérapie génique OTOF : 11/12 enfants ont amélioré leur audition (DB-OTO, NEJM 2025). 3 ont atteint une audition normale. Précédent pour la thérapie génique de l\'oreille interne.' },
  { year: 'Jan. 2026', event: 'Iranfar et al. (Clinical and Translational Medicine) : Dual AAV9-PHP.eB restaure l\'audition à des seuils quasi normaux chez les souris STRC. 60 % de transduction des cellules ciliées externes. Discrimination fréquentielle récupérée jusqu\'à 100 jours. DOI : 10.1002/ctm2.70571', highlight: true },
  { year: 'Mar. 2026', event: 'Analyse AlphaMissense : E1659A score 0,9016 (Probablement pathogène). Reclassification ACMG : PM3 + PP3_Modérée + PM2_Soutien = Probablement pathogène.', highlight: true },
  { year: '~2028-29', event: 'Premier essai clinique de thérapie génique STRC chez l\'humain attendu. Le patient aura 7-8 ans. Remarque : la fenêtre thérapeutique chez la souris = P0-P5 ; chez l\'humain probablement plus large, mais une intervention précoce reste critique.', future: true },
];
---

<LayoutFr>
  <Hero lang="fr" />

  <!-- ═══════════════════════════════════════════ -->
  <!-- PARTIE 1 : PREUVES DE RECLASSIFICATION -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">Partie 1</span>
      <h2 class="text-lg font-bold mt-1">Preuves de reclassification</h2>
      <p class="text-xs text-neutral-400 mt-1">Preuves computationnelles en faveur de la reclassification de VUS en Probablement pathogène pour NM_153700.2:c.4976A>C p.(Glu1659Ala)</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <AlphaMissense variants={variants} />
  <Conservation />
  <Structure3D />
  <Pseudogene />
  <ACMG />

  <!-- ═══════════════════════════════════════════ -->
  <!-- PARTIE 2 : HYPOTHÈSES DE RECHERCHE -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">Partie 2</span>
      <h2 class="text-lg font-bold mt-1">Hypothèses de recherche</h2>
      <p class="text-xs text-neutral-400 mt-1">Hypothèses computationnelles pour accélérer la thérapie génique STRC. Une validation expérimentale est nécessaire.</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <MiniSTRC />
  <PrimeEditing />

  <!-- ═══════════════════════════════════════════ -->
  <!-- PARTIE 3 : MÉTHODOLOGIE -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">Partie 3</span>
      <h2 class="text-lg font-bold mt-1">Comment j'ai procédé</h2>
      <p class="text-xs text-neutral-400 mt-1">Méthodologie étape par étape pour que chacun puisse reproduire ces résultats</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <MethodReclass />
  <MethodResearch />
  <ToolsGrid />
</LayoutFr>
