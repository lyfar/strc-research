---
import Layout from '../../../layouts/Layout.astro';

const lang = 'fr';

const hypotheses = [
  { href: '/fr/hypotheses/mini-strc', title: 'Mini-STRC Hypothesis', badge: 'AAV packaging', badgeColor: 'purple', desc: 'Truncated STRC construct (3984 bp) for AAV delivery.' },
  { href: '/fr/hypotheses/prime-editing', title: 'Prime Editing', badge: 'In situ correction', badgeColor: 'green', desc: 'Precision correction of c.4976A>C using PE3/PE3b.' },
  { href: '/fr/hypotheses/sonogenetics', title: 'Sonogenetics', badge: 'Non-invasive', badgeColor: 'blue', desc: 'Mechanosensitive channel activation via focused ultrasound.' },
  { href: '/fr/hypotheses/delivery', title: 'Delivery', badge: 'Sonoporation', badgeColor: 'cyan', desc: 'Non-invasive cochlear gene delivery via sonoporation + LNP.' },
  { href: '/fr/hypotheses/dual-vector', title: 'Dual-Vector vs Single-Vector', badge: 'Stochastic model', badgeColor: 'purple', desc: 'Poisson model of co-transduction probability cost.' },
  { href: '/fr/hypotheses/electrostatics', title: 'Electrostatic Analysis', badge: 'Biophysics', badgeColor: 'blue', desc: 'Coulomb energetics of E1659A adhesion interface.' },
  { href: '/fr/hypotheses/immune', title: 'Immune Response', badge: 'Pharmacokinetics', badgeColor: 'amber', desc: 'NAb kinetics and delivery vehicle comparison.' },
];

const badgeClasses: Record<string, string> = {
  purple: 'bg-purple-500/20 text-purple-400',
  green: 'bg-green-500/20 text-green-400',
  blue: 'bg-blue-500/20 text-blue-400',
  cyan: 'bg-cyan-500/20 text-cyan-400',
  amber: 'bg-amber-500/20 text-amber-400',
};
---

<Layout lang={lang}>
  <div class="px-6 pt-6 pb-2 max-w-4xl mx-auto">
    <a href="/fr/" class="text-xs text-neutral-500 hover:text-white transition-colors no-underline">← Home</a>
  </div>
  <section class="px-6 pt-6 pb-12 max-w-4xl mx-auto">
    <h2 class="text-lg font-bold mt-1 mb-8">Research Hypotheses</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {hypotheses.map((h) => (
        <a href={h.href} class="block bg-white/[0.02] border border-white/5 rounded-lg p-5 hover:border-white/10 hover:bg-white/[0.04] transition-all no-underline group">
          <div class="flex items-center gap-2 mb-2">
            <span class={}>{h.badge}</span>
          </div>
          <h3 class="text-sm font-semibold text-white mb-1">{h.title}</h3>
          <p class="text-xs text-neutral-400 leading-relaxed">{h.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
