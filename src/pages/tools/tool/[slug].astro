---
import Layout from '../../../layouts/Layout.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import { tools, STATUS_CONFIG } from '../../../data/tools';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
};

const { tool } = Astro.props;
---

<Layout lang="en">
  <div class="px-6 pt-6 pb-2 max-w-3xl mx-auto">
    <a href="/tools" class="text-xs text-neutral-500 hover:text-white transition-colors no-underline">&larr; All Tools</a>
  </div>

  <section class="px-6 pt-4 pb-16">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="flex items-center gap-3 mb-1">
        <h1 class="text-lg font-bold text-white">{tool.name}</h1>
        <StatusBadge status={tool.status} />
      </div>
      <p class="text-sm text-neutral-300 leading-relaxed mb-4">{tool.description}</p>

      <!-- Tags -->
      <div class="flex flex-wrap gap-1.5 mb-6">
        <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">{tool.category}</span>
        {tool.acmgRelevance && (
          <span class="text-[10px] px-1.5 py-0.5 rounded bg-purple-500/10 text-purple-400">ACMG: {tool.acmgRelevance}</span>
        )}
        {tool.hasApi && <span class="text-[10px] px-1.5 py-0.5 rounded bg-blue-500/10 text-blue-400">API Available</span>}
        {tool.isFree && <span class="text-[10px] px-1.5 py-0.5 rounded bg-green-500/10 text-green-400">Free</span>}
        {tool.tags.map(tag => (
          <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">{tag}</span>
        ))}
      </div>

      <!-- Content card -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 space-y-6">

        <!-- URL -->
        <div>
          <h3 class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-2">Access</h3>
          <a href={tool.url} target="_blank" rel="noopener" class="text-sm text-blue-400 hover:text-blue-300 transition-colors break-all">{tool.url}</a>
        </div>

        <!-- E1659A Results (if tested) -->
        {tool.e1659a && (
          <div>
            <h3 class="text-xs font-semibold text-green-400 uppercase tracking-wider mb-2">STRC E1659A Result</h3>
            <div class="bg-green-500/5 border border-green-500/10 rounded-lg p-3">
              <div class="text-sm text-white font-mono">{tool.e1659a.score}</div>
              <div class="text-xs text-neutral-400 mt-1">{tool.e1659a.interpretation}</div>
            </div>
          </div>
        )}

        <!-- Quick Info Grid -->
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-white/[0.02] rounded p-2.5">
            <div class="text-[10px] text-neutral-500 uppercase tracking-wider mb-0.5">API</div>
            <div class="text-xs text-neutral-300">{tool.hasApi ? 'Yes' : 'No'}</div>
          </div>
          <div class="bg-white/[0.02] rounded p-2.5">
            <div class="text-[10px] text-neutral-500 uppercase tracking-wider mb-0.5">Cost</div>
            <div class="text-xs text-neutral-300">{tool.isFree ? 'Free' : 'Paid / Limited'}</div>
          </div>
        </div>
      </div>

      <!-- Back to tools -->
      <div class="mt-8 text-center">
        <a href="/tools" class="text-xs text-neutral-500 hover:text-white transition-colors no-underline">&larr; Back to all tools</a>
      </div>
    </div>
  </section>
</Layout>
