---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import { useTranslations } from '../../lib/i18n';

const lang = 'es';
const t = useTranslations(lang);
---

<Layout lang={lang}>
  <Hero lang={lang} />

  <!-- Navigation Cards -->
  <section class="px-6 py-12 border-t border-white/5">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-6">Explore the Research</h2>
      <div class="grid sm:grid-cols-3 gap-4">

        <a href="/es/reclassification" class="block bg-white/[0.02] border border-white/5 rounded-lg p-5 hover:border-white/10 hover:bg-white/[0.04] transition-all no-underline group">
          <div class="flex items-center gap-2 mb-3">
            <span class="px-1.5 py-0.5 text-[10px] rounded bg-red-500/20 text-red-400 font-semibold uppercase tracking-wider">Part 1</span>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">{t('page.part1.title')}</h3>
          <p class="text-xs text-neutral-400 leading-relaxed">{t('page.part1.desc')}</p>
          <div class="mt-4 flex flex-wrap gap-1">
            <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">AlphaMissense</span>
            <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">Conservation</span>
            <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">ACMG</span>
          </div>
        </a>

        <a href="/es/hypotheses" class="block bg-white/[0.02] border border-white/5 rounded-lg p-5 hover:border-white/10 hover:bg-white/[0.04] transition-all no-underline group">
          <div class="flex items-center gap-2 mb-3">
            <span class="px-1.5 py-0.5 text-[10px] rounded bg-purple-500/20 text-purple-400 font-semibold uppercase tracking-wider">Part 2</span>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">{t('page.part2.title')}</h3>
          <p class="text-xs text-neutral-400 leading-relaxed">{t('page.part2.desc')}</p>
          <div class="mt-4 flex flex-wrap gap-1">
            <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">Mini-STRC</span>
            <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">Delivery</span>
            <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">+5 more</span>
          </div>
        </a>

        <a href="/es/methodology" class="block bg-white/[0.02] border border-white/5 rounded-lg p-5 hover:border-white/10 hover:bg-white/[0.04] transition-all no-underline group">
          <div class="flex items-center gap-2 mb-3">
            <span class="px-1.5 py-0.5 text-[10px] rounded bg-blue-500/20 text-blue-400 font-semibold uppercase tracking-wider">Part 3</span>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">{t('page.part3.title')}</h3>
          <p class="text-xs text-neutral-400 leading-relaxed">{t('page.part3.desc')}</p>
        </a>

      </div>
    </div>
  </section>
</Layout>
