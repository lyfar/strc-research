---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import AlphaMissense from '../../components/AlphaMissense.astro';
import Conservation from '../../components/Conservation.astro';
import Structure3D from '../../components/Structure3D.astro';
import Pseudogene from '../../components/Pseudogene.astro';
import ACMG from '../../components/ACMG.astro';
import MiniSTRC from '../../components/MiniSTRC.astro';
import AF3Results from '../../components/AF3Results.astro';
import PrimeEditing from '../../components/PrimeEditing.astro';
import MethodReclass from '../../components/MethodReclass.astro';
import MethodResearch from '../../components/MethodResearch.astro';
import ToolsGrid from '../../components/ToolsGrid.astro';

const lang = 'es';

const variants = [
  { aa: 'A', score: 0.9016, misha: true },
  { aa: 'C', score: 0.9984 }, { aa: 'D', score: 0.9483 },
  { aa: 'F', score: 0.9992 }, { aa: 'G', score: 0.9191 },
  { aa: 'H', score: 0.9927 }, { aa: 'I', score: 0.9923 },
  { aa: 'K', score: 0.9272 }, { aa: 'L', score: 0.9929 },
  { aa: 'M', score: 0.9909 }, { aa: 'N', score: 0.9822 },
  { aa: 'P', score: 0.9985 }, { aa: 'Q', score: 0.846 },
  { aa: 'R', score: 0.9634 }, { aa: 'S', score: 0.9433 },
  { aa: 'T', score: 0.9666 }, { aa: 'V', score: 0.9664 },
  { aa: 'W', score: 0.9997 }, { aa: 'Y', score: 0.9981 },
];
---

<Layout lang={lang}>
  <Hero lang={lang} />

  <!-- ═══════════════════════════════════════════ -->
  <!-- PARTE 1: EVIDENCIA DE RECLASIFICACIÓN -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">Parte 1</span>
      <h2 class="text-lg font-bold mt-1">Evidencia de reclasificación</h2>
      <p class="text-xs text-neutral-400 mt-1">Evidencia computacional que respalda la reclasificación de VUS a Probablemente patogénica para NM_153700.2:c.4976A>C p.(Glu1659Ala)</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <AlphaMissense variants={variants} lang={lang} />
  <Conservation lang={lang} />
  <Structure3D lang={lang} />
  <Pseudogene lang={lang} />
  <ACMG lang={lang} />

  <!-- ═══════════════════════════════════════════ -->
  <!-- PARTE 2: HIPÓTESIS DE INVESTIGACIÓN -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">Parte 2</span>
      <h2 class="text-lg font-bold mt-1">Hipótesis de investigación</h2>
      <p class="text-xs text-neutral-400 mt-1">Hipótesis computacionales para acelerar la terapia génica STRC. Requieren validación experimental.</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <MiniSTRC lang={lang} />
  <AF3Results lang={lang} />
  <PrimeEditing lang={lang} />

  <!-- ═══════════════════════════════════════════ -->
  <!-- PARTE 3: METODOLOGÍA -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">Parte 3</span>
      <h2 class="text-lg font-bold mt-1">Cómo lo hice</h2>
      <p class="text-xs text-neutral-400 mt-1">Metodología paso a paso para que cualquiera pueda reproducir estos resultados</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <MethodReclass lang={lang} />
  <MethodResearch lang={lang} />
  <ToolsGrid lang={lang} />
</Layout>
