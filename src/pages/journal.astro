---
import Layout from '../layouts/Layout.astro';
import PaperCard from '../components/PaperCard.astro';
import { getCollection } from 'astro:content';
import { parseRanking, TIER_META } from '../lib/hypothesis-ranking';

const lang = 'en';
const papers = await getCollection('papers');
// Sort by date_added (agent run date) primary, publication date as tiebreak.
// Keeps ahead-of-print papers in the batch they arrived with, not floated to top.
papers.sort((a, b) => {
  const aAdded = a.data.date_added?.getTime() ?? 0;
  const bAdded = b.data.date_added?.getTime() ?? 0;
  if (aAdded !== bAdded) return bAdded - aAdded;
  return b.data.date.getTime() - a.data.date.getTime();
});

const scanDates = papers.map(p => p.data.date_added).filter(Boolean) as Date[];
scanDates.sort((a, b) => b.getTime() - a.getTime());
const lastScan = scanDates[0]?.toISOString().split('T')[0] ?? 'pending';

const { hypotheses: allHypotheses } = parseRanking();
const sTier = allHypotheses.filter(h => h.tier === 'S');
const aTier = allHypotheses.filter(h => h.tier === 'A');
---

<Layout lang={lang} title="Research Monitor — STRC/DFNB16">
  <main class="px-6 py-12">
    <div class="max-w-3xl mx-auto">

      <!-- Header -->
      <div class="mb-10">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-[11px] font-mono text-green-400 uppercase tracking-wider">Monitor active</span>
        </div>
        <h1 class="text-xl font-bold text-white mb-3">Research Monitor</h1>
        <p class="text-sm text-neutral-400 leading-relaxed max-w-xl">
          Every night, a Claude agent queries PubMed for new papers on STRC, DFNB16,
          and inner ear gene therapy. It reads each abstract, scores relevance,
          and writes analysis of what it means for our program. Papers appear here automatically.
        </p>
        <div class="mt-3 flex gap-5 text-xs text-neutral-600 font-mono">
          <span>{papers.length} papers indexed</span>
          <span>Last scan: {lastScan}</span>
          <span>Runs daily 02:00 UTC</span>
        </div>
      </div>

      <!-- What we're working on (S/A-tier priority context) -->
      <div class="mb-10 bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-[10px] font-semibold uppercase tracking-wider text-neutral-500">Current priority — what the agent is looking for</h2>
          <a href="/hypotheses/" class="text-[11px] text-neutral-500 hover:text-white no-underline">Full register →</a>
        </div>
        <div class="space-y-2">
          {sTier.map(h => (
            <div class="flex items-start gap-2 text-xs">
              <span class={`mt-0.5 text-[10px] font-semibold px-1.5 py-0.5 rounded border shrink-0 ${TIER_META.S.color}`}>S</span>
              <div class="flex-1 min-w-0">
                <div class="text-neutral-300 font-medium">{h.title}</div>
                <div class="text-[11px] text-neutral-500 truncate"><span class="text-neutral-600">next:</span> {h.nextStep}</div>
              </div>
            </div>
          ))}
          {aTier.map(h => (
            <div class="flex items-start gap-2 text-xs">
              <span class={`mt-0.5 text-[10px] font-semibold px-1.5 py-0.5 rounded border shrink-0 ${TIER_META.A.color}`}>A</span>
              <div class="flex-1 min-w-0">
                <div class="text-neutral-400">{h.title}</div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-[11px] text-neutral-600 mt-4 leading-relaxed">
          Papers below are scored against this priority. Anything advancing an S-tier hypothesis is high-value. Anything on a killed (D-tier) mechanism gets skipped unless it credibly flips the kill.
        </p>
      </div>

      <!-- How it works -->
      <div class="mb-10 bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <h2 class="text-[10px] font-semibold uppercase tracking-wider text-neutral-500 mb-4">How it works</h2>
        <div class="grid sm:grid-cols-3 gap-5">
          <div>
            <div class="text-xs font-mono text-blue-400 mb-1">01 / Scan</div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              PubMed queried for STRC, stereocilin, DFNB16, cochlear gene therapy, and related terms.
              New PMIDs since yesterday are collected.
            </p>
          </div>
          <div>
            <div class="text-xs font-mono text-blue-400 mb-1">02 / Analyze</div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Claude reads the abstract and full text when available. Scores relevance 1–10.
              Extracts what it means for mini-STRC, delivery, and regulatory path.
            </p>
          </div>
          <div>
            <div class="text-xs font-mono text-blue-400 mb-1">03 / Publish</div>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Summaries committed to GitHub as Markdown. GitHub Actions builds and deploys here.
              Brain vault synced via symlink — appears in Obsidian the same morning.
            </p>
          </div>
        </div>
      </div>

      <!-- Papers -->
      {papers.length === 0 ? (
        <div class="text-center py-16 text-neutral-600 text-sm">
          No papers yet. First scan pending.
        </div>
      ) : (
        <div class="space-y-5">
          {papers.map(paper => (
            <PaperCard paper={paper} />
          ))}
        </div>
      )}

    </div>
  </main>
</Layout>
