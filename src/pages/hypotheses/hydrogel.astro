---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/hydrogel/Hero.astro';
import ExactAsk from '../../components/hydrogel/ExactAsk.astro';
import ClaimsAndNonClaims from '../../components/hydrogel/ClaimsAndNonClaims.astro';
import MechanismStack from '../../components/hydrogel/MechanismStack.astro';
import PhaseEvidence from '../../components/hydrogel/PhaseEvidence.astro';
import Constructs from '../../components/hydrogel/Constructs.astro';
import AvidityGate from '../../components/hydrogel/AvidityGate.astro';
import PrecedentTable from '../../components/hydrogel/PrecedentTable.astro';
import ObjectionTable from '../../components/hydrogel/ObjectionTable.astro';
import BoltzControlPanel from '../../components/hydrogel/BoltzControlPanel.astro';
import FeasibilityPackage from '../../components/hydrogel/FeasibilityPackage.astro';
import ClaimBoundary from '../../components/hydrogel/ClaimBoundary.astro';
---

<Layout lang="en" title="H09 STRC Synthetic Peptide Hydrogel Evidence Package">
  <div class="px-6 pt-6 pb-2 max-w-5xl mx-auto">
    <a href="/hypotheses" class="text-xs text-neutral-500 hover:text-white transition-colors no-underline">← All hypotheses</a>
  </div>

  <Hero />
  <ExactAsk />
  <ClaimsAndNonClaims />
  <MechanismStack />
  <PhaseEvidence />
  <Constructs />
  <AvidityGate />
  <PrecedentTable />
  <ObjectionTable />
  <BoltzControlPanel />
  <FeasibilityPackage />
  <ClaimBoundary />

  <div class="px-6 py-8 max-w-5xl mx-auto">
    <a href="/hypotheses" class="text-xs text-neutral-500 hover:text-white transition-colors no-underline">← All hypotheses</a>
  </div>
</Layout>
