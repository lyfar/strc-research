---
import Layout from '../../layouts/Layout.astro';
import { parseRanking, TIER_ORDER, TIER_META, type Tier, type Hypothesis } from '../../lib/hypothesis-ranking';

const lang = 'en';
const { hypotheses, updatedDate } = parseRanking();

const grouped: Record<Tier, Hypothesis[]> = {
  S: [], A: [], B: [], C: [], 'D/C': [], D: [], reference: [],
};
for (const h of hypotheses) grouped[h.tier].push(h);

const total = hypotheses.length;
const sCount = grouped.S.length;
const killedCount = grouped.D.length + grouped['D/C'].length;
---

<Layout lang={lang}>
  <div class="px-6 pt-6 pb-2 max-w-4xl mx-auto">
    <a href="/" class="text-xs text-neutral-500 hover:text-white transition-colors no-underline">← Back to overview</a>
  </div>

  <section class="px-6 pt-6 pb-4 max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <span class="flex h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
      <span class="text-[11px] font-mono text-green-400 uppercase tracking-wider">Live priority register</span>
    </div>
    <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">Part 2</span>
    <h2 class="text-lg font-bold mt-1 mb-1">Research Hypotheses</h2>
    <p class="text-xs text-neutral-400 mb-3">
      Rolling rubric for all STRC/DFNB16 hypotheses, Misha-centric. Each scored 1–5 on Mechanism (M), Delivery (D), Misha-fit (F).
      Tier ≈ min(M, D, F). This page mirrors <code class="text-[10px] bg-white/5 px-1 py-0.5 rounded">~/Brain/notes/STRC Hypothesis Ranking.md</code> — the canonical register.
    </p>
    <div class="flex flex-wrap gap-4 text-[11px] font-mono text-neutral-500 mb-6">
      <span>{total} hypotheses</span>
      <span class="text-red-400">{sCount} S-tier</span>
      <span class="text-neutral-600">{killedCount} killed</span>
      {updatedDate && <span>updated {updatedDate}</span>}
    </div>
  </section>

  <section class="px-6 pb-12 max-w-4xl mx-auto space-y-10">
    {TIER_ORDER.map((tier) => grouped[tier].length > 0 && (
      <div>
        <div class="flex items-baseline gap-3 mb-3 pb-2 border-b border-white/5">
          <span class={`px-2 py-0.5 text-[11px] rounded font-semibold border ${TIER_META[tier].color}`}>{TIER_META[tier].label}</span>
          <span class="text-[11px] text-neutral-500">{TIER_META[tier].caption}</span>
          <span class="text-[11px] text-neutral-600 ml-auto font-mono">{grouped[tier].length}</span>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {grouped[tier].map((h) => {
            const muted = tier === 'D' || tier === 'D/C';
            const Card = h.slug ? 'a' : 'div';
            const cardProps = h.slug
              ? { href: `/hypotheses/${h.slug}`, class: 'block bg-white/[0.02] border border-white/5 rounded-lg p-4 hover:border-white/15 hover:bg-white/[0.04] transition-all no-underline group' }
              : { class: `block bg-white/[0.015] border border-white/5 rounded-lg p-4 ${muted ? 'opacity-60' : ''}` };
            return (
              <Card {...cardProps}>
                <div class="flex items-center justify-between gap-2 mb-2">
                  <span class="text-[10px] font-mono text-neutral-600">#{h.num}</span>
                  <div class="flex items-center gap-1.5">
                    {tier !== 'reference' && (
                      <span class="text-[10px] font-mono text-neutral-500" title="Mechanism / Delivery / Misha-fit">
                        M{h.mech} · D{h.deliv} · F{h.misha}
                      </span>
                    )}
                  </div>
                </div>
                <h3 class={`text-sm font-semibold mb-1.5 ${muted ? 'line-through text-neutral-500' : 'text-white group-hover:text-white/90'}`}>
                  {h.title}
                </h3>
                {tier !== 'reference' && (
                  <p class="text-[11px] text-neutral-500 mb-1.5">
                    <span class="text-neutral-400">Evidence:</span> {h.evidence}
                  </p>
                )}
                <p class="text-[11px] text-neutral-500 mb-1.5">
                  <span class="text-neutral-400">Status:</span> {h.status}
                </p>
                {h.nextStep && h.nextStep !== '—' && (
                  <p class="text-[11px] text-neutral-500">
                    <span class="text-neutral-400">Next:</span> {h.nextStep}
                  </p>
                )}
                {!h.slug && tier !== 'reference' && (
                  <p class="text-[10px] text-neutral-600 mt-2 italic">No detail page yet</p>
                )}
              </Card>
            );
          })}
        </div>
      </div>
    ))}
  </section>
</Layout>
