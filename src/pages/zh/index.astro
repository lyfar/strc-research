---
import LayoutZh from '../../layouts/LayoutZh.astro';
import Hero from '../../components/Hero.astro';
import AlphaMissense from '../../components-zh/AlphaMissense.astro';
import Conservation from '../../components-zh/Conservation.astro';
import Structure3D from '../../components-zh/Structure3D.astro';
import Pseudogene from '../../components-zh/Pseudogene.astro';
import ACMG from '../../components-zh/ACMG.astro';
import MiniSTRC from '../../components-zh/MiniSTRC.astro';
import PrimeEditing from '../../components-zh/PrimeEditing.astro';
import MethodReclass from '../../components-zh/MethodReclass.astro';
import MethodResearch from '../../components-zh/MethodResearch.astro';
import ToolsGrid from '../../components-zh/ToolsGrid.astro';

const variants = [
  { aa: 'A', score: 0.9016, misha: true },
  { aa: 'C', score: 0.9984 }, { aa: 'D', score: 0.9483 },
  { aa: 'F', score: 0.9992 }, { aa: 'G', score: 0.9191 },
  { aa: 'H', score: 0.9927 }, { aa: 'I', score: 0.9923 },
  { aa: 'K', score: 0.9272 }, { aa: 'L', score: 0.9929 },
  { aa: 'M', score: 0.9909 }, { aa: 'N', score: 0.9822 },
  { aa: 'P', score: 0.9985 }, { aa: 'Q', score: 0.846 },
  { aa: 'R', score: 0.9634 }, { aa: 'S', score: 0.9433 },
  { aa: 'T', score: 0.9666 }, { aa: 'V', score: 0.9664 },
  { aa: 'W', score: 0.9997 }, { aa: 'Y', score: 0.9981 },
];

const timeline = [
  { year: '2021年12月', event: 'Shubina-Oleinik et al.（Science Advances）：首次在小鼠中进行双AAV STRC基因治疗，概念验证。DOI: 10.1126/sciadv.abi7629' },
  { year: '2022年12月', event: '在香港儿童医院进行全外显子组测序（WES）。检测到STRC缺失（父系）及意义不明变异（VUS）错义突变（母系）。实验室编号：23C7500174。' },
  { year: '2023年12月', event: 'WES报告更新，经亲本检测确认为复合杂合STRC。' },
  { year: '2025年', event: 'OTOF基因治疗试验：12名儿童中11名听力改善（DB-OTO，NEJM 2025），3名恢复正常听力。为内耳基因治疗建立先例。' },
  { year: '2026年1月', event: 'Iranfar et al.（Clinical and Translational Medicine）：双AAV9-PHP.eB在STRC小鼠中将听力恢复至接近正常阈值。60%外毛细胞转导。频率辨别能力在100天内恢复。DOI: 10.1002/ctm2.70571', highlight: true },
  { year: '2026年3月', event: 'AlphaMissense分析：E1659A评分0.9016（可能致病）。ACMG重分类证据：PM3 + PP3_Moderate + PM2_Supporting = 可能致病。', highlight: true },
  { year: '约2028-29年', event: '预计首次人体STRC基因治疗试验。患者届时将为7-8岁。注：小鼠治疗窗口期为P0-P5；人类可能更宽，但早期干预至关重要。', future: true },
];
---

<LayoutZh>
  <Hero lang="zh" />

  <!-- ═══════════════════════════════════════════ -->
  <!-- 第一部分：重分类证据 -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">第一部分</span>
      <h2 class="text-lg font-bold mt-1">重分类证据</h2>
      <p class="text-xs text-neutral-400 mt-1">支持将NM_153700.2:c.4976A&gt;C p.(Glu1659Ala) 由意义不明变异（VUS）重分类为可能致病性变异的计算证据</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <AlphaMissense variants={variants} />
  <Conservation />
  <Structure3D />
  <Pseudogene />
  <ACMG />

  <!-- ═══════════════════════════════════════════ -->
  <!-- 第二部分：研究假说 -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">第二部分</span>
      <h2 class="text-lg font-bold mt-1">研究假说</h2>
      <p class="text-xs text-neutral-400 mt-1">加速STRC基因治疗的计算假说，需要实验验证。</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <MiniSTRC />
  <PrimeEditing />

  <!-- ═══════════════════════════════════════════ -->
  <!-- 第三部分：研究方法 -->
  <section class="px-6 pt-12 pb-4 border-t-2 border-white/10">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">第三部分</span>
      <h2 class="text-lg font-bold mt-1">研究方法</h2>
      <p class="text-xs text-neutral-400 mt-1">详细的操作步骤，任何人均可复现这些结果</p>
    </div>
  </section>
  <!-- ═══════════════════════════════════════════ -->

  <MethodReclass />
  <MethodResearch />
  <ToolsGrid />
</LayoutZh>
