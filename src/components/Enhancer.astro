---
// Enhancer-Driven OHC Targeting hypothesis (Zhao 2025 ARBITER)
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="enhancer" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('enh.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-emerald-500/20 text-emerald-400 font-semibold">NEW</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-blue-500/20 text-blue-400 font-semibold">CELL TARGETING</span>
    </div>
    <p class="text-neutral-400 text-sm mb-8 max-w-2xl" set:html={t('enh.desc')} />

    <!-- The Problem: CAG promoter is non-specific -->
    <div class="bg-white/[0.02] border border-red-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-4">{t('enh.problem.title')}</h3>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="border border-red-500/10 bg-red-950/10 rounded-lg p-4">
          <div class="text-[10px] text-red-400 font-semibold uppercase tracking-wider mb-2">{t('enh.problem.cag_label')}</div>
          <div class="space-y-1.5 text-xs text-neutral-400">
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span>{t('enh.problem.cag1')}</span></div>
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span>{t('enh.problem.cag2')}</span></div>
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span>{t('enh.problem.cag3')}</span></div>
          </div>
        </div>
        <div class="border border-green-500/10 bg-green-950/10 rounded-lg p-4">
          <div class="text-[10px] text-green-400 font-semibold uppercase tracking-wider mb-2">{t('enh.problem.b8_label')}</div>
          <div class="space-y-1.5 text-xs text-neutral-400">
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span>{t('enh.problem.b81')}</span></div>
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span>{t('enh.problem.b82')}</span></div>
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span>{t('enh.problem.b83')}</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ARBITER workflow -->
    <div class="bg-white/[0.02] border border-emerald-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('enh.arbiter.title')}</h3>
      <p class="text-xs text-neutral-400 leading-relaxed mb-4" set:html={t('enh.arbiter.desc')} />
      
      <!-- Pipeline visualization -->
      <div class="flex flex-wrap items-center gap-2 text-[10px] mb-4">
        <div class="px-2 py-1.5 bg-blue-500/10 border border-blue-500/20 rounded text-blue-400 font-mono">CNE screen</div>
        <span class="text-neutral-600">→</span>
        <div class="px-2 py-1.5 bg-purple-500/10 border border-purple-500/20 rounded text-purple-400 font-mono">AAV-ie reporter</div>
        <span class="text-neutral-600">→</span>
        <div class="px-2 py-1.5 bg-cyan-500/10 border border-cyan-500/20 rounded text-cyan-400 font-mono">in vivo test</div>
        <span class="text-neutral-600">→</span>
        <div class="px-2 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded text-amber-400 font-mono">dissect elements</div>
        <span class="text-neutral-600">→</span>
        <div class="px-2 py-1.5 bg-green-500/10 border border-green-500/20 rounded text-green-400 font-mono font-bold">B8 synthetic enhancer</div>
      </div>
    </div>

    <!-- Key Results -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-4">{t('enh.results.title')}</h3>
      <div class="grid sm:grid-cols-3 gap-4 mb-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-green-400 mb-1">B8</div>
          <div class="text-[10px] text-neutral-500">{t('enh.results.b8_label')}</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-green-400 mb-1">100%</div>
          <div class="text-[10px] text-neutral-500">{t('enh.results.restore_label')}</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-neutral-400 mb-1">0%</div>
          <div class="text-[10px] text-neutral-500">{t('enh.results.leak_label')}</div>
        </div>
      </div>
      <div class="space-y-2 text-xs text-neutral-400">
        <p set:html={t('enh.results.p1')} />
        <p set:html={t('enh.results.p2')} />
        <p set:html={t('enh.results.p3')} />
      </div>
    </div>

    <!-- STRC Implication -->
    <div class="bg-white/[0.02] border border-purple-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('enh.strc.title')}</h3>
      <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('enh.strc.p1')} />
      <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('enh.strc.p2')} />
      
      <!-- Synergy with mini-STRC -->
      <div class="bg-purple-500/5 border border-purple-500/10 rounded-lg p-3 mt-3">
        <div class="text-[10px] text-purple-400 font-semibold mb-1">{t('enh.strc.synergy_title')}</div>
        <p class="text-[10px] text-neutral-400" set:html={t('enh.strc.synergy')} />
      </div>
    </div>

    <!-- References -->
    <div class="text-[10px] text-neutral-600 space-y-1">
      <p>Zhao et al. (2025) "Deciphering the enhancers of hearing loss genes enables targeted and effective gene therapy." <em>Neuron</em>.</p>
    </div>
  </div>
</section>
