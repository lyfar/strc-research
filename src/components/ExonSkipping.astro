---
// Antisense Oligonucleotide / Exon Skipping hypothesis
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="exon-skipping" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('aso.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-purple-500/20 text-purple-400 font-semibold">NEW</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-amber-500/20 text-amber-400 font-semibold">RNA THERAPEUTICS</span>
    </div>
    <p class="text-neutral-400 text-sm mb-8 max-w-2xl" set:html={t('aso.desc')} />

    <!-- DMD Precedent -->
    <div class="bg-white/[0.02] border border-green-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-4">{t('aso.precedent.title')}</h3>
      <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('aso.precedent.p1')} />
      
      <div class="grid sm:grid-cols-3 gap-3 mb-3">
        <div class="bg-green-500/5 border border-green-500/10 rounded-lg p-3 text-center">
          <div class="text-lg font-bold text-green-400">4</div>
          <div class="text-[10px] text-neutral-500">{t('aso.precedent.approved')}</div>
        </div>
        <div class="bg-green-500/5 border border-green-500/10 rounded-lg p-3 text-center">
          <div class="text-lg font-bold text-green-400">DMD</div>
          <div class="text-[10px] text-neutral-500">{t('aso.precedent.gene')}</div>
        </div>
        <div class="bg-green-500/5 border border-green-500/10 rounded-lg p-3 text-center">
          <div class="text-lg font-bold text-green-400">Weekly</div>
          <div class="text-[10px] text-neutral-500">{t('aso.precedent.dosing')}</div>
        </div>
      </div>
      <p class="text-[10px] text-neutral-500" set:html={t('aso.precedent.note')} />
    </div>

    <!-- How it would work for STRC -->
    <div class="bg-white/[0.02] border border-purple-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('aso.strc.title')}</h3>
      <p class="text-xs text-neutral-400 leading-relaxed mb-4" set:html={t('aso.strc.desc')} />

      <!-- Pipeline -->
      <div class="flex flex-wrap items-center gap-2 text-[10px] mb-4">
        <div class="px-2 py-1.5 bg-purple-500/10 border border-purple-500/20 rounded text-purple-400 font-mono">ASO design</div>
        <span class="text-neutral-600">→</span>
        <div class="px-2 py-1.5 bg-cyan-500/10 border border-cyan-500/20 rounded text-cyan-400 font-mono">Skip mutant exon</div>
        <span class="text-neutral-600">→</span>
        <div class="px-2 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded text-amber-400 font-mono">Shorter mRNA</div>
        <span class="text-neutral-600">→</span>
        <div class="px-2 py-1.5 bg-green-500/10 border border-green-500/20 rounded text-green-400 font-mono">Truncated but functional protein</div>
      </div>

      <div class="space-y-2 text-xs text-neutral-400">
        <p set:html={t('aso.strc.p1')} />
        <p set:html={t('aso.strc.p2')} />
      </div>
    </div>

    <!-- Advantages vs Gene Therapy -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-4">{t('aso.advantages.title')}</h3>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <div class="text-[10px] text-green-400 font-semibold mb-2">{t('aso.advantages.pros_label')}</div>
          <div class="space-y-1.5 text-xs text-neutral-400">
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span>{t('aso.advantages.pro1')}</span></div>
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span>{t('aso.advantages.pro2')}</span></div>
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span>{t('aso.advantages.pro3')}</span></div>
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span>{t('aso.advantages.pro4')}</span></div>
          </div>
        </div>
        <div>
          <div class="text-[10px] text-red-400 font-semibold mb-2">{t('aso.advantages.cons_label')}</div>
          <div class="space-y-1.5 text-xs text-neutral-400">
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span>{t('aso.advantages.con1')}</span></div>
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span>{t('aso.advantages.con2')}</span></div>
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span>{t('aso.advantages.con3')}</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Open Questions -->
    <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4 mb-6">
      <h3 class="text-xs font-semibold text-amber-400 mb-2">{t('aso.questions.title')}</h3>
      <div class="space-y-1 text-xs text-neutral-400">
        <p set:html={t('aso.questions.q1')} />
        <p set:html={t('aso.questions.q2')} />
        <p set:html={t('aso.questions.q3')} />
      </div>
    </div>

    <!-- References -->
    <div class="text-[10px] text-neutral-600 space-y-1">
      <p>Eteplirsen (Exondys 51), Golodirsen (Vyondys 53), Viltolarsen (Viltepso), Casimersen (Amondys 45) - FDA-approved exon-skipping ASOs for DMD.</p>
      <p>Leclere et al. (2024) "Gene therapy for hearing loss: Advances and prospects of non-viral vectors." <em>Hear Res</em>.</p>
    </div>
  </div>
</section>
