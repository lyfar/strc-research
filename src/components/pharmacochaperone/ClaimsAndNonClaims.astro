---
import SectionHeader from './SectionHeader.astro';
import { claims, nonClaims } from './data';
---
<section id="claims" class="px-6 py-12 border-t border-white/5 scroll-mt-6">
  <div class="max-w-5xl mx-auto">
    <SectionHeader
      title="Claims & non-claims"
      lead="Two columns kept symmetric on purpose: every claim has a paired non-claim so the reviewer can see exactly where the dossier stops."
    />
    <div class="grid md:grid-cols-2 gap-4">
      <div class="border border-emerald-500/20 bg-emerald-500/[0.04] rounded-lg p-5">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-emerald-300 mb-3">What we claim</h3>
        <ul class="space-y-3 text-xs text-neutral-300 leading-relaxed">
          {claims.map((c) => (
            <li class="flex gap-2">
              <span class="text-emerald-400 font-mono mt-0.5">+</span>
              <span>{c}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="border border-rose-500/20 bg-rose-500/[0.04] rounded-lg p-5">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-rose-300 mb-3">What we do not claim</h3>
        <ul class="space-y-3 text-xs text-neutral-300 leading-relaxed">
          {nonClaims.map((c) => (
            <li class="flex gap-2">
              <span class="text-rose-400 font-mono mt-0.5">−</span>
              <span>{c}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
