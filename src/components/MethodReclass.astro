---
// How I Did This: Steps 1-8 (Reclassification methodology)
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="reproduce" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="mb-6">
      <h3 class="text-sm font-semibold text-white">Day 1, evening</h3>
      <p class="text-neutral-400 text-xs mt-1" set:html={t('methodreclass.intro')} />
    </div>
    
    <div class="space-y-6">

      <!-- Step 1 -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold shrink-0">1</span>
          <h3 class="text-sm font-semibold">{t('methodreclass.step1.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('methodreclass.step1.body')} />
        <div class="text-xs text-neutral-500 bg-black/30 p-3 rounded" set:html={t('methodreclass.step1.tip')} />
      </div>

      <!-- Step 2 -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold shrink-0">2</span>
          <h3 class="text-sm font-semibold">{t('methodreclass.step2.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('methodreclass.step2.body')} />
        <div class="text-xs text-neutral-500 bg-black/30 p-3 rounded space-y-1">
          <div set:html={t('methodreclass.step2.stepA')} />
          <div set:html={t('methodreclass.step2.stepB')} />
        </div>
        <div class="mt-3 grid grid-cols-2 gap-2">
          <div class="bg-black/40 rounded border border-white/10 p-3">
            <div class="text-[10px] text-blue-400 font-semibold mb-1">{t('methodreclass.step2.card1.label')}</div>
            <div class="text-xs text-white font-mono mb-1">{t('methodreclass.step2.card1.id')}</div>
            <div class="text-[10px] text-neutral-400">{t('methodreclass.step2.card1.desc')}</div>
            <div class="text-[10px] text-neutral-500 mt-1">{t('methodreclass.step2.card1.note')}</div>
          </div>
          <div class="bg-black/40 rounded border border-white/10 p-3">
            <div class="text-[10px] text-blue-400 font-semibold mb-1">{t('methodreclass.step2.card2.label')}</div>
            <div class="text-xs text-white font-mono mb-1">{t('methodreclass.step2.card2.id')}</div>
            <div class="text-[10px] text-neutral-400" set:html={t('methodreclass.step2.card2.desc')} />
            <div class="text-[10px] text-neutral-500 mt-1">{t('methodreclass.step2.card2.note')}</div>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-red-500/20 flex items-center justify-center text-xs font-bold text-red-400 shrink-0">3</span>
          <h3 class="text-sm font-semibold">{t('methodreclass.step3.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3">{t('methodreclass.step3.body1')}</p>
        <p class="text-xs text-neutral-300 leading-relaxed mb-3" set:html={t('methodreclass.step3.body2')} />
        <div class="text-xs text-neutral-500 bg-black/30 p-3 rounded space-y-1">
          <div set:html={t('methodreclass.step3.how')} />
          <div set:html={t('methodreclass.step3.then')} />
          <div set:html={t('methodreclass.step3.other')} />
        </div>
        <div class="mt-3 bg-black/40 rounded border border-white/10 p-3 overflow-x-auto">
          <div class="text-[10px] text-blue-400 font-semibold mb-2">{t('methodreclass.step3.table_label')}</div>
          <table class="text-[11px] font-mono min-w-[320px]">
            <tr class="text-neutral-500"><td class="pr-4 py-0.5">protein_variant</td><td class="pr-4">am_pathogenicity</td><td>am_class</td></tr>
            <tr class="text-red-400 font-bold"><td class="pr-4 py-0.5">E1659A</td><td class="pr-4">0.9016</td><td>LPath</td></tr>
            <tr class="text-neutral-400"><td class="pr-4 py-0.5">E1659D</td><td class="pr-4">0.9483</td><td>LPath</td></tr>
            <tr class="text-neutral-400"><td class="pr-4 py-0.5">E1659G</td><td class="pr-4">0.9191</td><td>LPath</td></tr>
            <tr class="text-neutral-500"><td class="pr-4 py-0.5" colspan="3">{t('methodreclass.step3.table_rest')}</td></tr>
          </table>
        </div>
      </div>

      <!-- Step 4 -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold shrink-0">4</span>
          <h3 class="text-sm font-semibold">{t('methodreclass.step4.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3">{t('methodreclass.step4.body1')}</p>
        <p class="text-xs text-neutral-300 leading-relaxed mb-3" set:html={t('methodreclass.step4.body2')} />
        <div class="text-xs text-neutral-500 bg-black/30 p-3 rounded space-y-1">
          <div set:html={t('methodreclass.step4.how')} />
          <div set:html={t('methodreclass.step4.then')} />
          <div set:html={t('methodreclass.step4.shortcut')} />
        </div>
      </div>

      <!-- Step 5 -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold shrink-0">5</span>
          <h3 class="text-sm font-semibold">{t('methodreclass.step5.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('methodreclass.step5.body1')} />
        <p class="text-xs text-neutral-400 leading-relaxed" set:html={t('methodreclass.step5.body2')} />
        <div class="text-xs text-neutral-500 bg-black/30 p-3 rounded mt-3 space-y-1">
          <div set:html={t('methodreclass.step5.check')} />
          <div set:html={t('methodreclass.step5.note')} />
        </div>
      </div>

      <!-- Step 6 -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold shrink-0">6</span>
          <h3 class="text-sm font-semibold">{t('methodreclass.step6.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-2" set:html={t('methodreclass.step6.body')} />
        <ul class="text-xs text-neutral-400 mt-2 space-y-2">
          <li set:html={t('methodreclass.step6.pm3')} />
          <li set:html={t('methodreclass.step6.pp3')} />
          <li set:html={t('methodreclass.step6.pm2')} />
          <li set:html={t('methodreclass.step6.pp1')} />
        </ul>
        <p class="text-xs text-neutral-300 mt-3" set:html={t('methodreclass.step6.result')} />
      </div>

      <!-- Step 7 -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold shrink-0">7</span>
          <h3 class="text-sm font-semibold">{t('methodreclass.step7.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed">{t('methodreclass.step7.body')}</p>
      </div>

      <!-- Step 8 -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold text-purple-400 shrink-0">8</span>
          <h3 class="text-sm font-semibold">{t('methodreclass.step8.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed" set:html={t('methodreclass.step8.body')} />
      </div>

    </div>
  </div>
</section>
