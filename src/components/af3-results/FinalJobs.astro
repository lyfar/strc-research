---
// AF3 Results — Final construct cards (Jobs B, D2, F, G, H — Day 6)
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<!-- Job B: Full STRC homodimer (Day 6) -->
<div class="bg-white/[0.02] border border-amber-500/20 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-amber-500/20 text-amber-400 font-semibold z-10">DAY 6</span>
  <div id="v-jobb" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-amber-500 mb-1">Critical Control</div>
    <div class="text-xs font-semibold text-amber-400 mb-1">{t('af3results.jobb.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-amber-400">{t('af3results.jobb.score')}</span>
      <span class="text-[10px] text-neutral-500">Validates Job C</span>
    </div>
    <p class="text-[10px] text-neutral-400 leading-relaxed">{t('af3results.jobb.desc')}</p>
  </div>
</div>

<!-- Job D2: mini-STRC + Tectorin ZP (Day 6) -->
<div class="bg-white/[0.02] border border-neutral-500/20 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-neutral-500/20 text-neutral-400 font-semibold z-10">DAY 6</span>
  <div id="v-jobd2" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-neutral-500 mb-1">TM Binding Test</div>
    <div class="text-xs font-semibold text-neutral-300 mb-1">{t('af3results.jobd2.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-neutral-400">{t('af3results.jobd2.score')}</span>
      <span class="text-[10px] text-neutral-500">No binding</span>
    </div>
    <p class="text-[10px] text-neutral-500 leading-relaxed">{t('af3results.jobd2.desc')}</p>
  </div>
</div>

<!-- Job F: Shorter mini-STRC (Day 6) -->
<div class="bg-white/[0.02] border border-green-500/20 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-green-500/20 text-green-400 font-semibold z-10">DAY 6</span>
  <div id="v-jobf" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-green-500 mb-1">Truncation Variant</div>
    <div class="text-xs font-semibold text-green-400 mb-1">{t('af3results.jobf.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-green-400 font-bold">{t('af3results.jobf.score')}</span>
      <span class="text-[10px] text-neutral-400">4% disordered</span>
    </div>
    <p class="text-[10px] text-neutral-400 leading-relaxed">{t('af3results.jobf.desc')}</p>
  </div>
</div>

<!-- Job G: Delta LRR linker (Day 6) -->
<div class="bg-white/[0.02] border border-yellow-500/20 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-yellow-500/20 text-yellow-400 font-semibold z-10">DAY 6</span>
  <div id="v-jobg" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-yellow-500 mb-1">Linker Approach</div>
    <div class="text-xs font-semibold text-yellow-400 mb-1">{t('af3results.jobg.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-yellow-400">{t('af3results.jobg.score')}</span>
      <span class="text-[10px] text-neutral-500">8-12% disordered</span>
    </div>
    <p class="text-[10px] text-neutral-500 leading-relaxed">{t('af3results.jobg.desc')}</p>
  </div>
</div>

<!-- Job H: C-term only (Day 6) -->
<div class="bg-white/[0.02] border border-emerald-500/30 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-emerald-500/20 text-emerald-400 font-semibold z-10">🏆 DAY 6</span>
  <div id="v-jobh" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-emerald-500 mb-1">Best Construct</div>
    <div class="text-xs font-semibold text-emerald-400 mb-1">{t('af3results.jobh.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-emerald-400 font-bold">{t('af3results.jobh.score')}</span>
      <span class="text-[10px] text-neutral-400">6% disordered</span>
    </div>
    <p class="text-[10px] text-neutral-400 leading-relaxed">{t('af3results.jobh.desc')}</p>
  </div>
</div>
