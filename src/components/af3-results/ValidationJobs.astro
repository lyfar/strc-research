---
// AF3 Results — Validation & interaction cards (Jobs 8, A, C, D, E — Day 3-5)
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<!-- Job 8: NFATC1 + CnA + CnB (Day 3) -->
<a href="https://alphafoldserver.com/fold/1f78a8dd5afe06b2" target="_blank" rel="noopener" class="bg-white/[0.02] border border-cyan-500/20 rounded-lg overflow-hidden no-underline group hover:border-cyan-500/30 transition-colors relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-cyan-500/20 text-cyan-400 font-semibold z-10">DAY 3</span>
  <div id="v-job8" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-cyan-500 mb-1">Cascade Validation</div>
    <div class="text-xs font-semibold text-cyan-400 mb-1">{t('af3results.job8.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-cyan-400 font-bold">{t('af3results.job8.score')}</span>
      <span class="text-[10px] text-neutral-400">50% disordered</span>
    </div>
    <p class="text-[10px] text-neutral-400 leading-relaxed">{t('af3results.job8.desc')}</p>
  </div>
</a>

<!-- Job A: mini-STRC + Piezo2 CED (Day 4) -->
<div class="bg-white/[0.02] border border-neutral-500/20 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-neutral-500/20 text-neutral-400 font-semibold z-10">DAY 4</span>
  <div id="v-joba" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-neutral-500 mb-1">Interaction Test</div>
    <div class="text-xs font-semibold text-neutral-300 mb-1">{t('af3results.joba.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-neutral-400">{t('af3results.joba.score')}</span>
      <span class="text-[10px] text-neutral-500">No interaction</span>
    </div>
    <p class="text-[10px] text-neutral-500 leading-relaxed">{t('af3results.joba.desc')}</p>
  </div>
</div>

<!-- Job C: mini-STRC homodimer (Day 5) -->
<div class="bg-white/[0.02] border border-red-500/20 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-red-500/20 text-red-400 font-semibold z-10">DAY 5</span>
  <div id="v-jobc" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-red-500 mb-1">Self-Association Test</div>
    <div class="text-xs font-semibold text-neutral-300 mb-1">{t('af3results.jobc.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-red-400">{t('af3results.jobc.score')}</span>
      <span class="text-[10px] text-neutral-500">No dimerization</span>
    </div>
    <p class="text-[10px] text-neutral-500 leading-relaxed">{t('af3results.jobc.desc')}</p>
  </div>
</div>

<!-- Job D: mini-STRC + Otoancorin (Day 5) -->
<div class="bg-white/[0.02] border border-neutral-500/20 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-neutral-500/20 text-neutral-400 font-semibold z-10">DAY 5</span>
  <div id="v-jobd" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-neutral-500 mb-1">TM Binding Test</div>
    <div class="text-xs font-semibold text-neutral-300 mb-1">{t('af3results.jobd.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-neutral-400">{t('af3results.jobd.score')}</span>
      <span class="text-[10px] text-neutral-500">No direct contact</span>
    </div>
    <p class="text-[10px] text-neutral-500 leading-relaxed">{t('af3results.jobd.desc')}</p>
  </div>
</div>

<!-- Job E: mini-STRC + TMC1 (Day 5) -->
<div class="bg-white/[0.02] border border-neutral-500/20 rounded-lg overflow-hidden group relative">
  <span class="absolute top-2 right-2 px-1.5 py-0.5 text-[9px] rounded bg-neutral-500/20 text-neutral-400 font-semibold z-10">DAY 5</span>
  <div id="v-jobe" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-neutral-500 mb-1">Channel Interaction</div>
    <div class="text-xs font-semibold text-neutral-300 mb-1">{t('af3results.jobe.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-neutral-400">{t('af3results.jobe.score')}</span>
      <span class="text-[10px] text-neutral-500">No interaction</span>
    </div>
    <p class="text-[10px] text-neutral-500 leading-relaxed">{t('af3results.jobe.desc')}</p>
  </div>
</div>
