---
// AF3 Results — Summary box
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<div class="mt-6 bg-white/[0.02] border border-white/5 rounded-lg p-4">
  <h3 class="text-xs font-semibold text-neutral-300 mb-2">{t('af3results.summary.title')}</h3>
  <p class="text-xs text-neutral-400 leading-relaxed" set:html={t('af3results.summary.desc')} />
</div>
