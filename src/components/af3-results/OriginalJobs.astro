---
// AF3 Results — Original experiment cards (Jobs 1-6, Day 1-2)
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<!-- Job 1 -->
<a href="https://alphafoldserver.com/fold/739cbeb76239c7c8" target="_blank" rel="noopener" class="bg-white/[0.02] border border-white/5 rounded-lg overflow-hidden no-underline group hover:border-white/10 transition-colors">
  <div id="v-job1" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
  <div class="p-3">
    <div class="text-[10px] text-neutral-500 mb-1">Question 1</div>
    <div class="text-xs font-semibold text-white mb-1">{t('af3results.job1.title')}</div>
    <div class="flex items-center gap-2 mb-2">
      <span class="text-xs font-mono text-yellow-400">{t('af3results.job1.score')}</span>
      <span class="text-[10px] text-neutral-500">Low confidence</span>
    </div>
    <p class="text-[10px] text-neutral-500 leading-relaxed">{t('af3results.job1.desc')}</p>
  </div>
</a>

<!-- Job 2 -->
<a href="https://alphafoldserver.com/fold/1f78a8dd5afe06b2" target="_blank" rel="noopener" class="bg-white/[0.02] border border-green-500/20 rounded-lg overflow-hidden no-underline group hover:border-green-500/30 transition-colors">
