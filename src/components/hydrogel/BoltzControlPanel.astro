---
import SectionHeader from './SectionHeader.astro';
import { boltzPanel } from './data';
---
<section id="controls" class="px-6 py-12 border-t border-white/5 scroll-mt-6">
  <div class="max-w-5xl mx-auto">
    <SectionHeader
      title="Orthogonal Boltz-2 WH2 control panel"
      lead="Phase 4p — independent model family asked the same WH2 question. h09 stays inside the positive-reference band and above all sequence-destroyed negatives. Boltz does not recover the Chereau ITC rank order cleanly (WIP false-low, Tbeta4 false-high), so this is supportive, not affinity evidence."
    />
    <div class="overflow-x-auto border border-white/5 rounded-lg max-w-3xl">
      <table class="w-full text-left text-xs">
        <thead class="bg-white/[0.03] text-neutral-500 uppercase tracking-wider">
          <tr>
            <th class="px-4 py-3 font-semibold">Construct</th>
            <th class="px-4 py-3 font-semibold">Role</th>
            <th class="px-4 py-3 font-semibold text-right">Boltz ipTM</th>
            <th class="px-4 py-3 font-semibold">Read</th>
          </tr>
        </thead>
        <tbody>
          {boltzPanel.map((row) => {
            const isQuery = row.role === 'query';
            const rowClass = isQuery ? 'bg-cyan-500/5' : '';
            return (
              <tr class={`border-t border-white/5 align-top ${rowClass}`}>
                <td class={`px-4 py-3 font-mono ${isQuery ? 'text-cyan-300 font-semibold' : 'text-neutral-300'}`}>{row.construct}</td>
                <td class="px-4 py-3 text-neutral-500">{row.role}</td>
                <td class="px-4 py-3 text-emerald-400 font-mono text-right">{row.iptm}</td>
                <td class="px-4 py-3 text-neutral-500">{row.read}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</section>
