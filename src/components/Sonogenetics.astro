---
// Day 3: Sonogenetic STRC Hypothesis
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="sonogenetics" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('sono.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">DAY 3</span>
    </div>

    <!-- Story: 3 paragraphs, Egor's voice -->
    <div class="space-y-4 text-sm text-neutral-300 leading-relaxed mb-10">
      <p set:html={t('sono.story.p1')} />
      <p set:html={t('sono.story.p2')} />
      <p set:html={t('sono.story.p3')} />
    </div>

    <!-- CASCADE DIAGRAM: detailed SVG -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-5">{t('sono.cascade.title')}</h3>
      
      <!-- SVG cascade diagram -->
      <div class="overflow-x-auto">
        <svg viewBox="0 0 900 420" xmlns="http://www.w3.org/2000/svg" class="w-full min-w-[700px]" style="font-family: ui-monospace, monospace;">
          <!-- Step 1: Sound / Hearing Aid -->
          <rect x="10" y="20" width="160" height="90" rx="8" fill="#0e2a3a" stroke="#22d3ee" stroke-width="1" opacity="0.8"/>
          <text x="90" y="48" text-anchor="middle" fill="#22d3ee" font-size="11" font-weight="bold">SOUND</text>
          <text x="90" y="65" text-anchor="middle" fill="#8b9caa" font-size="9">Hearing aid amplifies</text>
          <text x="90" y="78" text-anchor="middle" fill="#8b9caa" font-size="9">everyday sounds to 60-80 dB</text>
          <text x="90" y="100" text-anchor="middle" fill="#555" font-size="8">No special frequencies</text>

          <!-- Arrow 1→2 -->
          <line x1="170" y1="65" x2="200" y2="65" stroke="#333" stroke-width="1.5"/>
          <polygon points="197,60 207,65 197,70" fill="#444"/>
          <text x="188" y="55" text-anchor="middle" fill="#555" font-size="7">deflects</text>

          <!-- Step 2: Stereocilia / MET channels -->
          <rect x="210" y="20" width="160" height="90" rx="8" fill="#0e2a3a" stroke="#22d3ee" stroke-width="1" opacity="0.8"/>
          <text x="290" y="48" text-anchor="middle" fill="#22d3ee" font-size="11" font-weight="bold">STEREOCILIA</text>
          <text x="290" y="65" text-anchor="middle" fill="#8b9caa" font-size="9">MET channels open at tips</text>
          <text x="290" y="78" text-anchor="middle" fill="#8b9caa" font-size="9">~134 channels per cell</text>
          <text x="290" y="100" text-anchor="middle" fill="#555" font-size="8">15% Ca²⁺ permeability</text>

          <!-- Arrow 2→3 -->
          <line x1="370" y1="65" x2="400" y2="65" stroke="#333" stroke-width="1.5"/>
          <polygon points="397,60 407,65 397,70" fill="#444"/>
          <text x="388" y="55" text-anchor="middle" fill="#555" font-size="7">Ca²⁺ influx</text>

          <!-- Step 3: Calcium in apical compartment -->
          <rect x="410" y="20" width="160" height="90" rx="8" fill="#1a2a0e" stroke="#4ade80" stroke-width="1" opacity="0.8"/>
          <text x="490" y="48" text-anchor="middle" fill="#4ade80" font-size="11" font-weight="bold">Ca²⁺ SIGNAL</text>
          <text x="490" y="65" text-anchor="middle" fill="#8b9caa" font-size="9">Apical compartment</text>
          <text x="490" y="78" text-anchor="middle" fill="#8b9caa" font-size="9">70 nM → 500-900 nM</text>
          <text x="490" y="100" text-anchor="middle" fill="#555" font-size="8">V = 0.05 pL (tiny space)</text>

          <!-- Arrow 3→4 (down) -->
          <line x1="490" y1="110" x2="490" y2="150" stroke="#333" stroke-width="1.5"/>
          <polygon points="485,147 490,157 495,147" fill="#444"/>
          <text x="520" y="135" text-anchor="start" fill="#555" font-size="7">activates</text>

          <!-- Step 4: Calcineurin -->
          <rect x="410" y="160" width="160" height="80" rx="8" fill="#1a1a2e" stroke="#818cf8" stroke-width="1" opacity="0.8"/>
          <text x="490" y="188" text-anchor="middle" fill="#818cf8" font-size="11" font-weight="bold">CALCINEURIN</text>
          <text x="490" y="205" text-anchor="middle" fill="#8b9caa" font-size="9">Ca²⁺-dependent phosphatase</text>
          <text x="490" y="218" text-anchor="middle" fill="#8b9caa" font-size="9">CnA + CnB heterodimer</text>
          <text x="490" y="232" text-anchor="middle" fill="#555" font-size="8">Kd = 500 nM, Hill n=4</text>

          <!-- Arrow 4→5 (left) -->
          <line x1="410" y1="200" x2="370" y2="200" stroke="#333" stroke-width="1.5"/>
          <polygon points="373,195 363,200 373,205" fill="#444"/>
          <text x="390" y="190" text-anchor="middle" fill="#555" font-size="7">dephosphorylates</text>

          <!-- Step 5: NFAT -->
          <rect x="200" y="160" width="170" height="80" rx="8" fill="#1a1a2e" stroke="#c084fc" stroke-width="1" opacity="0.8"/>
          <text x="285" y="188" text-anchor="middle" fill="#c084fc" font-size="11" font-weight="bold">NFAT</text>
          <text x="285" y="205" text-anchor="middle" fill="#8b9caa" font-size="9">Transcription factor</text>
          <text x="285" y="218" text-anchor="middle" fill="#8b9caa" font-size="9">Dephosphorylated → NLS exposed</text>
          <text x="285" y="232" text-anchor="middle" fill="#555" font-size="8">Translocates to nucleus in minutes</text>

          <!-- Arrow 5→6 (down) -->
          <line x1="285" y1="240" x2="285" y2="280" stroke="#333" stroke-width="1.5"/>
          <polygon points="280,277 285,287 290,277" fill="#444"/>
          <text x="315" y="265" text-anchor="start" fill="#555" font-size="7">enters nucleus</text>

          <!-- Step 6: 6xNFAT Promoter -->
          <rect x="200" y="290" width="170" height="80" rx="8" fill="#2a1a0e" stroke="#f59e0b" stroke-width="1" opacity="0.8"/>
          <text x="285" y="318" text-anchor="middle" fill="#f59e0b" font-size="11" font-weight="bold">6×NFAT PROMOTER</text>
          <text x="285" y="335" text-anchor="middle" fill="#8b9caa" font-size="9">6 binding sites + minimal promoter</text>
          <text x="285" y="348" text-anchor="middle" fill="#8b9caa" font-size="9">Sharp digital switch (Hill ~4)</text>
          <text x="285" y="362" text-anchor="middle" fill="#555" font-size="8">62× induction, zero leakage (Wu 2023)</text>

          <!-- Arrow 6→7 (right) -->
          <line x1="370" y1="330" x2="410" y2="330" stroke="#333" stroke-width="1.5"/>
          <polygon points="407,325 417,330 407,335" fill="#444"/>
          <text x="390" y="320" text-anchor="middle" fill="#555" font-size="7">transcribes</text>

          <!-- Step 7: mini-STRC protein -->
          <rect x="420" y="290" width="170" height="80" rx="8" fill="#0e2a1a" stroke="#22c55e" stroke-width="1" opacity="0.8"/>
          <text x="505" y="318" text-anchor="middle" fill="#22c55e" font-size="11" font-weight="bold">mini-STRC</text>
          <text x="505" y="335" text-anchor="middle" fill="#8b9caa" font-size="9">1182 aa (residues 594-1775)</text>
          <text x="505" y="348" text-anchor="middle" fill="#8b9caa" font-size="9">Traffics to stereocilia tips</text>
          <text x="505" y="362" text-anchor="middle" fill="#555" font-size="8">t½ ~30 days. Accumulates over days.</text>

          <!-- Arrow 7→8 (right) -->
          <line x1="590" y1="330" x2="630" y2="330" stroke="#333" stroke-width="1.5"/>
          <polygon points="627,325 637,330 627,335" fill="#444"/>
          <text x="610" y="320" text-anchor="middle" fill="#555" font-size="7">integrates</text>

          <!-- Step 8: Hearing restored -->
          <rect x="640" y="290" width="170" height="80" rx="8" fill="#0a2a0a" stroke="#22c55e" stroke-width="2" opacity="0.9"/>
          <text x="725" y="318" text-anchor="middle" fill="#22c55e" font-size="11" font-weight="bold">HEARING</text>
          <text x="725" y="335" text-anchor="middle" fill="#8b9caa" font-size="9">Top connectors restored</text>
          <text x="725" y="348" text-anchor="middle" fill="#8b9caa" font-size="9">Bundle moves as unit again</text>
          <text x="725" y="362" text-anchor="middle" fill="#555" font-size="8">50% in 13h, full in 72h</text>

          <!-- Feedback arrow: hearing improves → more signal → more protein (dashed) -->
          <path d="M 810 330 Q 860 330 860 200 Q 860 65 570 65" fill="none" stroke="#22c55e" stroke-width="1" stroke-dasharray="4,3" opacity="0.4"/>
          <polygon points="573,60 563,65 573,70" fill="#22c55e" opacity="0.4"/>
          <text x="870" y="200" text-anchor="start" fill="#22c55e" font-size="7" opacity="0.5">positive</text>
          <text x="870" y="210" text-anchor="start" fill="#22c55e" font-size="7" opacity="0.5">feedback</text>

          <!-- OFF state annotation -->
          <rect x="640" y="30" width="170" height="70" rx="8" fill="#1a0e0e" stroke="#ef4444" stroke-width="1" stroke-dasharray="3,3" opacity="0.5"/>
          <text x="725" y="55" text-anchor="middle" fill="#ef4444" font-size="10" font-weight="bold" opacity="0.7">SLEEP / SILENCE</text>
          <text x="725" y="72" text-anchor="middle" fill="#777" font-size="8">No sound → no Ca²⁺</text>
          <text x="725" y="85" text-anchor="middle" fill="#777" font-size="8">Promoter OFF. Protein stable.</text>
        </svg>
      </div>
    </div>

    <!-- AAV Vector Construct -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-3">{t('sono.construct.title')}</h3>
      <div class="bg-black/40 rounded-lg p-4 font-mono text-xs overflow-x-auto mb-3">
        <div class="flex items-center gap-0 min-w-[500px]">
          <div class="bg-neutral-700 text-neutral-300 px-2 py-1.5 rounded-l text-center" style="min-width:50px">
            <div class="text-[9px] text-neutral-500">ITR</div>
            <div>145bp</div>
          </div>
          <div class="bg-cyan-900/60 text-cyan-300 px-3 py-1.5 text-center" style="min-width:90px">
            <div class="text-[9px] text-cyan-500">Promoter</div>
            <div>6xNFAT</div>
            <div class="text-[9px]">~300bp</div>
          </div>
          <div class="bg-green-900/60 text-green-300 px-4 py-1.5 flex-1 text-center">
            <div class="text-[9px] text-green-500">Transgene</div>
            <div>mini-STRC CDS</div>
            <div class="text-[9px]">3546bp</div>
          </div>
          <div class="bg-purple-900/40 text-purple-300 px-2 py-1.5 text-center" style="min-width:60px">
            <div class="text-[9px] text-purple-500">PolyA</div>
            <div>bGH</div>
            <div class="text-[9px]">250bp</div>
          </div>
          <div class="bg-neutral-700 text-neutral-300 px-2 py-1.5 rounded-r text-center" style="min-width:50px">
            <div class="text-[9px] text-neutral-500">ITR</div>
            <div>145bp</div>
          </div>
        </div>
      </div>
      <div class="flex items-center justify-between text-xs">
        <span class="text-neutral-500">{t('sono.construct.total')}: <span class="text-white font-mono font-bold">4,401 bp</span></span>
        <span class="text-neutral-500">{t('sono.construct.limit')}: <span class="text-green-400 font-mono font-bold">4,700 bp</span></span>
        <span class="text-green-400 font-semibold">{t('sono.construct.margin')}: 299 bp</span>
      </div>
    </div>

    <!-- Literature -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-3">{t('sono.literature.title')}</h3>
      <div class="space-y-2 text-xs text-neutral-400">
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[1]</span>
          <span set:html={t('sono.literature.ref1')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[2]</span>
          <span set:html={t('sono.literature.ref2')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[3]</span>
          <span set:html={t('sono.literature.ref3')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[4]</span>
          <span set:html={t('sono.literature.ref4')} />
        </div>
      </div>
    </div>

    <!-- Caveat -->
    <p class="text-xs text-neutral-500 italic">{t('sono.caveat_short')}</p>
  </div>
</section>
