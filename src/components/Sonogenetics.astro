---
// Day 3: Sonogenetic STRC Hypothesis — mechanosensitive promoter for self-dosing gene therapy
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="sonogenetics" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('sono.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">DAY 3</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-yellow-500/20 text-yellow-400 font-semibold">{t('sono.badge_comp')}</span>
    </div>
    <p class="text-neutral-400 text-sm mb-8 max-w-3xl">{t('sono.desc')}</p>

    <!-- Plain language intro -->
    <div class="bg-white/[0.03] border border-white/10 rounded-lg p-5 mb-8">
      <h3 class="text-sm font-semibold text-white mb-3">{t('sono.plain.title')}</h3>
      <div class="space-y-3 text-xs leading-relaxed">
        <p class="text-neutral-300">{t('sono.plain.p1')}</p>
        <p class="text-neutral-300" set:html={t('sono.plain.p2')} />
        <p class="text-neutral-300" set:html={t('sono.plain.p3')} />
        <p class="text-neutral-400">{t('sono.plain.p4')}</p>
      </div>
    </div>

    <!-- The Insight -->
    <div class="bg-cyan-500/5 border border-cyan-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold text-cyan-400 mb-3">{t('sono.insight.title')}</h3>
      <p class="text-xs text-neutral-300 leading-relaxed mb-3" set:html={t('sono.insight.p1')} />
      <p class="text-xs text-neutral-400 leading-relaxed" set:html={t('sono.insight.p2')} />
    </div>

    <!-- How It Works: 5-step cascade -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-4">{t('sono.cascade.title')}</h3>
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <span class="w-6 h-6 rounded-full bg-cyan-500/20 flex items-center justify-center text-[10px] font-bold text-cyan-400 shrink-0 mt-0.5">1</span>
          <div>
            <div class="text-xs font-semibold text-white">{t('sono.cascade.s1.title')}</div>
            <p class="text-[11px] text-neutral-400 mt-0.5">{t('sono.cascade.s1.desc')}</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-6 h-6 rounded-full bg-cyan-500/20 flex items-center justify-center text-[10px] font-bold text-cyan-400 shrink-0 mt-0.5">2</span>
          <div>
            <div class="text-xs font-semibold text-white">{t('sono.cascade.s2.title')}</div>
            <p class="text-[11px] text-neutral-400 mt-0.5">{t('sono.cascade.s2.desc')}</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-6 h-6 rounded-full bg-cyan-500/20 flex items-center justify-center text-[10px] font-bold text-cyan-400 shrink-0 mt-0.5">3</span>
          <div>
            <div class="text-xs font-semibold text-white">{t('sono.cascade.s3.title')}</div>
            <p class="text-[11px] text-neutral-400 mt-0.5">{t('sono.cascade.s3.desc')}</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-6 h-6 rounded-full bg-cyan-500/20 flex items-center justify-center text-[10px] font-bold text-cyan-400 shrink-0 mt-0.5">4</span>
          <div>
            <div class="text-xs font-semibold text-white">{t('sono.cascade.s4.title')}</div>
            <p class="text-[11px] text-neutral-400 mt-0.5">{t('sono.cascade.s4.desc')}</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="w-6 h-6 rounded-full bg-green-500/20 flex items-center justify-center text-[10px] font-bold text-green-400 shrink-0 mt-0.5">5</span>
          <div>
            <div class="text-xs font-semibold text-green-400">{t('sono.cascade.s5.title')}</div>
            <p class="text-[11px] text-neutral-400 mt-0.5">{t('sono.cascade.s5.desc')}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- AAV Vector Construct -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('sono.construct.title')}</h3>
      <div class="bg-black/40 rounded-lg p-4 font-mono text-xs overflow-x-auto mb-3">
        <div class="flex items-center gap-0 min-w-[500px]">
          <div class="bg-neutral-700 text-neutral-300 px-2 py-1.5 rounded-l text-center" style="min-width:50px">
            <div class="text-[9px] text-neutral-500">ITR</div>
            <div>145bp</div>
          </div>
          <div class="bg-cyan-900/60 text-cyan-300 px-3 py-1.5 text-center" style="min-width:90px">
            <div class="text-[9px] text-cyan-500">Promoter</div>
            <div>6xNFAT</div>
            <div class="text-[9px]">~300bp</div>
          </div>
          <div class="bg-green-900/60 text-green-300 px-4 py-1.5 flex-1 text-center">
            <div class="text-[9px] text-green-500">Transgene</div>
            <div>mini-STRC CDS</div>
            <div class="text-[9px]">3546bp</div>
          </div>
          <div class="bg-purple-900/40 text-purple-300 px-2 py-1.5 text-center" style="min-width:60px">
            <div class="text-[9px] text-purple-500">PolyA</div>
            <div>bGH</div>
            <div class="text-[9px]">250bp</div>
          </div>
          <div class="bg-neutral-700 text-neutral-300 px-2 py-1.5 rounded-r text-center" style="min-width:50px">
            <div class="text-[9px] text-neutral-500">ITR</div>
            <div>145bp</div>
          </div>
        </div>
      </div>
      <div class="flex items-center justify-between text-xs">
        <span class="text-neutral-500">{t('sono.construct.total')}: <span class="text-white font-mono font-bold">4,401 bp</span></span>
        <span class="text-neutral-500">{t('sono.construct.limit')}: <span class="text-green-400 font-mono font-bold">4,700 bp</span></span>
        <span class="text-green-400 font-semibold">{t('sono.construct.margin')}: 299 bp</span>
      </div>
    </div>

    <!-- Key advantage: self-dosing -->
    <div class="bg-green-500/5 border border-green-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold text-green-400 mb-2">{t('sono.selfdose.title')}</h3>
      <p class="text-xs text-neutral-300 leading-relaxed" set:html={t('sono.selfdose.desc')} />
    </div>

    <!-- Literature support -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('sono.literature.title')}</h3>
      <div class="space-y-2 text-xs text-neutral-400">
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[1]</span>
          <span set:html={t('sono.literature.ref1')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[2]</span>
          <span set:html={t('sono.literature.ref2')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[3]</span>
          <span set:html={t('sono.literature.ref3')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[4]</span>
          <span set:html={t('sono.literature.ref4')} />
        </div>
      </div>
    </div>

    <!-- Caveat -->
    <div class="bg-yellow-500/10 border border-yellow-500/20 rounded-lg p-4">
      <p class="text-xs text-neutral-300" set:html={t('sono.caveat')} />
    </div>
  </div>
</section>
