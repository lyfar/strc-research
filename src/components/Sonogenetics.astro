---
// Day 3: Sonogenetic STRC Hypothesis
import { useTranslations } from '../lib/i18n';
import Story from './sonogenetics/Story.astro';
import CascadeDiagram from './sonogenetics/CascadeDiagram.astro';
import VectorConstruct from './sonogenetics/VectorConstruct.astro';
import Literature from './sonogenetics/Literature.astro';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="sonogenetics" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('sono.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">DAY 3</span>
    </div>

    <Story lang={lang} />
    <CascadeDiagram lang={lang} />
    <VectorConstruct lang={lang} />
    <Literature lang={lang} />
  </div>
</section>

<style is:global>
  .cascade-flow {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cascade-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 0;
    align-items: stretch;
  }

  /* 2-column rows */
  .cascade-row-reverse {
    grid-template-columns: 1fr auto 1fr;
    max-width: 70%;
    margin-left: auto;
  }

  .cascade-node {
    border-width: 1px;
    border-style: solid;
    border-radius: 8px;
    padding: 12px;
    min-width: 0;
  }

  .cascade-label {
    font-size: 11px;
    font-weight: 700;
    font-family: ui-monospace, monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }

  .cascade-detail {
    font-size: 11px;
    color: #a1a1aa;
    line-height: 1.5;
  }

  .cascade-meta {
    font-size: 9px;
    color: #555;
    margin-top: 4px;
  }

  .cascade-arrow-h {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #444;
    font-size: 16px;
    padding: 0 6px;
    flex-shrink: 0;
  }

  .cascade-arrow-v {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #444;
    font-size: 16px;
    padding: 8px 0;
    padding-left: 70%;
    justify-content: flex-start;
  }

  .cascade-row-reverse + .cascade-arrow-v {
    padding-left: 50%;
  }

  .cascade-arrow-label {
    font-size: 9px;
    color: #555;
    font-style: italic;
  }

  .cascade-node-small {
    border-width: 1px;
    border-radius: 6px;
    padding: 8px 12px;
    flex: 1;
  }

  /* Mobile: stack vertically */
  @media (max-width: 640px) {
    .cascade-row {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .cascade-row-reverse {
      grid-template-columns: 1fr;
      max-width: 100%;
      margin-left: 0;
    }

    .cascade-arrow-h {
      padding: 4px 0;
      font-size: 14px;
      transform: rotate(90deg);
    }

    .cascade-arrow-v {
      padding-left: 0;
      justify-content: center;
    }

    .cascade-node {
      padding: 10px;
    }

    .cascade-node-small {
      padding: 8px;
    }

    .mt-5.flex {
      flex-direction: column;
    }
  }
</style>
