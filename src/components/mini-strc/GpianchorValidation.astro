---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/GpianchorValidation.en.json';
import zh from './i18n/GpianchorValidation.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-amber-400 mb-4"><Fragment set:html={t('t15')} /></h3>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
        <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t1')} /></p>
        <p class="text-xs text-neutral-400 leading-relaxed mb-5"><Fragment set:html={t('t2')} /></p>
        
        <div class="overflow-x-auto mb-5">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/10 text-neutral-300">
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t11')} /></th>
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t12')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t13')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t14')} /></th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t5')} /></td>
                <td class="p-3"><Fragment set:html={t('t6')} /></td>
                <td class="p-3 text-right font-mono">S1749</td>
                <td class="p-3 text-right font-mono">0.471</td>
              </tr>
              <tr class="border-b border-white/5 bg-amber-500/[0.03]">
                <td class="p-3 text-amber-400 font-medium"><Fragment set:html={t('t7')} /></td>
                <td class="p-3"><Fragment set:html={t('t8')} /></td>
                <td class="p-3 text-right font-mono text-amber-400">S1071*</td>
                <td class="p-3 text-right font-mono text-amber-400">0.471</td>
              </tr>
              <tr class="border-b border-white/5 bg-emerald-500/[0.05]">
                <td class="p-3 text-white font-semibold">IgK-SP + Ultra-Mini 1075-1775 (clinical · identical C-term)</td>
                <td class="p-3"><span class="text-emerald-400 font-semibold">GPI-Anchored</span></td>
                <td class="p-3 text-right font-mono text-emerald-400">S675*</td>
                <td class="p-3 text-right font-mono text-emerald-400 font-bold">0.471</td>
              </tr>
              <tr class="text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t9')} /></td>
                <td class="p-3"><Fragment set:html={t('t10')} /></td>
                <td class="p-3 text-right font-mono">S1050*</td>
                <td class="p-3 text-right font-mono">0.471</td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <p class="text-[10px] text-neutral-500 mb-4"><Fragment set:html={t('t3')} /></p>
        
        <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4">
          <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('t4')} /></p>
        </div>
      </div>
    </div>