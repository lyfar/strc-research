---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/ConstructEngineering.en.json';
import zh from './i18n/ConstructEngineering.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-orange-400 mb-4">{t('t5')}</h3>
      
      <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t1')} /></p>
      
      <!-- Signal peptide finding -->
      <div class="bg-orange-500/10 border border-orange-500/20 rounded-lg p-4 mb-4">
        <h4 class="text-[10px] text-orange-400 font-semibold uppercase tracking-wider mb-2">{t('t6')}</h4>
        <p class="text-xs text-neutral-300 leading-relaxed mb-3"><Fragment set:html={t('t2')} /></p>
        <div class="grid sm:grid-cols-3 gap-2 text-[10px]">
          <div class="bg-black/30 rounded p-2">
            <div class="text-orange-400 font-semibold mb-1">{t('t8')}</div>
            <div class="text-neutral-500">20 aa, 60 bp</div>
            <div class="text-neutral-400 mt-1">{t('t9')}</div>
          </div>
          <div class="bg-black/30 rounded p-2">
            <div class="text-neutral-400 font-semibold mb-1">{t('t10')}</div>
            <div class="text-neutral-500">26 aa, 78 bp</div>
            <div class="text-neutral-400 mt-1">{t('t11')}</div>
          </div>
          <div class="bg-black/30 rounded p-2">
            <div class="text-neutral-400 font-semibold mb-1">CD8α SP</div>
            <div class="text-neutral-500">21 aa, 63 bp</div>
            <div class="text-neutral-400 mt-1">{t('t12')}</div>
          </div>
        </div>
      </div>
      
      <!-- Revised AAV construct map -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4 mb-4">
        <div class="text-[10px] text-neutral-500 uppercase tracking-wider font-semibold mb-3">{t('t13')}</div>
        
        <!-- Shorter mini-STRC construct -->
        <div class="mb-4">
          <div class="text-[10px] text-green-400 font-semibold mb-1">Shorter mini-STRC (recommended)</div>
          <div class="flex h-6 rounded overflow-hidden mb-1 text-[8px] font-mono">
            <div class="bg-neutral-700 flex items-center justify-center px-1" style="width:3.1%" title="ITR 145bp">ITR</div>
            <div class="bg-purple-500/40 flex items-center justify-center px-1" style="width:12.5%" title="B8 enhancer 587bp">B8 enh.</div>
            <div class="bg-orange-500/40 flex items-center justify-center" style="width:1.3%" title="IgK SP 60bp">SP</div>
            <div class="bg-green-500/40 flex items-center justify-center px-1" style="width:68.7%" title="CDS 3,228bp">CDS 3,228 bp</div>
            <div class="bg-blue-500/30 flex items-center justify-center px-1" style="width:4.8%" title="bGH polyA 225bp">pA</div>
            <div class="bg-neutral-700 flex items-center justify-center px-1" style="width:3.1%" title="ITR 145bp">ITR</div>
            <div class="bg-neutral-800/50 flex items-center justify-center px-1 text-neutral-500" style="width:6.5%" title="600bp headroom">600 bp free</div>
          </div>
          <div class="text-[9px] text-neutral-500">Between ITRs: 4,100 bp / 4,700 bp capacity. 600 bp headroom for UTR optimization or short WPRE.</div>
        </div>
        
        <!-- C-term only construct -->
        <div>
          <div class="text-[10px] text-emerald-400 font-semibold mb-1">C-term only (backup)</div>
          <div class="flex h-6 rounded overflow-hidden mb-1 text-[8px] font-mono">
            <div class="bg-neutral-700 flex items-center justify-center px-1" style="width:3.1%" title="ITR 145bp">ITR</div>
            <div class="bg-purple-500/40 flex items-center justify-center px-1" style="width:12.5%" title="B8 enhancer 587bp">B8 enh.</div>
            <div class="bg-orange-500/40 flex items-center justify-center" style="width:1.3%" title="IgK SP 60bp">SP</div>
            <div class="bg-emerald-500/40 flex items-center justify-center px-1" style="width:44.7%" title="CDS 2,103bp">CDS 2,103 bp</div>
            <div class="bg-yellow-500/30 flex items-center justify-center px-1" style="width:12.6%" title="WPRE 592bp">WPRE</div>
            <div class="bg-blue-500/30 flex items-center justify-center px-1" style="width:4.8%" title="bGH polyA 225bp">pA</div>
            <div class="bg-neutral-700 flex items-center justify-center px-1" style="width:3.1%" title="ITR 145bp">ITR</div>
            <div class="bg-neutral-800/50 flex items-center justify-center px-1 text-neutral-500" style="width:17.9%" title="1133bp headroom">1,133 bp free</div>
          </div>
          <div class="text-[9px] text-neutral-500">Between ITRs: 3,567 bp / 4,700 bp capacity. Room for B8 enhancer AND WPRE (2-5x expression boost).</div>
        </div>
      </div>
      
      <!-- Glycosylation impact -->
      <div class="bg-yellow-500/10 border border-yellow-500/20 rounded-lg p-4">
        <h4 class="text-[10px] text-yellow-400 font-semibold uppercase tracking-wider mb-2">{t('t7')}</h4>
        <p class="text-xs text-neutral-300 leading-relaxed mb-2"><Fragment set:html={t('t3')} /></p>
        <div class="grid sm:grid-cols-3 gap-2 text-[10px]">
          <div class="bg-black/30 rounded p-2 text-center">
            <div class="text-neutral-500 mb-1">{t('t14')}</div>
            <div class="text-xl font-bold text-white">14</div>
            <div class="text-neutral-500">glycosylation sites</div>
          </div>
          <div class="bg-black/30 rounded p-2 text-center border border-green-500/20">
            <div class="text-green-400 mb-1">Shorter mini-STRC</div>
            <div class="text-xl font-bold text-green-400">5</div>
            <div class="text-neutral-500">sites retained (9 lost)</div>
          </div>
          <div class="bg-black/30 rounded p-2 text-center">
            <div class="text-emerald-400 mb-1">C-term only</div>
            <div class="text-xl font-bold text-emerald-400">2</div>
            <div class="text-neutral-500">sites retained (12 lost)</div>
          </div>
        </div>
        <p class="text-[10px] text-neutral-500 mt-2"><Fragment set:html={t('t4')} /></p>
      </div>
    </div>