---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/NormalModeAnalysis.en.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en });
---
<div class="mt-16 pt-10 border-t border-white/5">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-violet-400 mb-4"><Fragment set:html={t('title')} /></h3>
  <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('desc')} /></p>

  <!-- Key finding -->
  <div class="bg-violet-500/10 border border-violet-500/20 rounded-lg p-4 mb-4">
    <h4 class="text-[10px] text-violet-400 font-semibold uppercase tracking-wider mb-2">{t('key_finding_title')}</h4>
    <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('key_finding')} /></p>
  </div>

  <!-- Mode overlap table -->
  <div class="mb-4">
    <h4 class="text-[10px] text-neutral-500 uppercase tracking-wider font-semibold mb-2">{t('overlap_title')}</h4>
    <p class="text-[10px] text-neutral-500 mb-2"><Fragment set:html={t('overlap_desc')} /></p>
    <div class="bg-white/[0.02] border border-white/5 rounded-lg overflow-hidden mb-2">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b border-white/5 text-neutral-500">
            <th class="text-left p-2 pl-3 font-medium">Full Mode</th>
            <th class="text-left p-2 font-medium">Mini Mode</th>
            <th class="text-right p-2 pr-3 font-medium">Overlap</th>
          </tr>
        </thead>
        <tbody class="text-neutral-400 font-mono">
          <tr class="border-b border-white/5"><td class="p-2 pl-3">21</td><td class="p-2">1</td><td class="p-2 pr-3 text-right text-green-400 font-bold">0.971</td></tr>
          <tr class="border-b border-white/5"><td class="p-2 pl-3">24</td><td class="p-2">2</td><td class="p-2 pr-3 text-right text-green-400">0.750</td></tr>
          <tr class="border-b border-white/5"><td class="p-2 pl-3">25</td><td class="p-2">2</td><td class="p-2 pr-3 text-right text-green-400 font-bold">0.938</td></tr>
          <tr class="border-b border-white/5"><td class="p-2 pl-3">48</td><td class="p-2">3</td><td class="p-2 pr-3 text-right text-green-400">0.834</td></tr>
          <tr><td class="p-2 pl-3">50</td><td class="p-2">4</td><td class="p-2 pr-3 text-right text-green-400 font-bold">0.991</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-neutral-300"><Fragment set:html={t('overlap_cumulative')} /></p>
  </div>

  <!-- Mode characterization -->
  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4 mb-4">
    <h4 class="text-[10px] text-neutral-500 uppercase tracking-wider font-semibold mb-2">{t('modes_title')}</h4>
    <ul class="text-xs text-neutral-400 space-y-1">
      <li><Fragment set:html={t('mode1')} /></li>
      <li><Fragment set:html={t('mode2')} /></li>
      <li><Fragment set:html={t('mode3')} /></li>
    </ul>
    <p class="text-[10px] text-neutral-500 mt-2"><Fragment set:html={t('bfactor')} /></p>
  </div>

  <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-4">
    <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('conclusion')} /></p>
  </div>
</div>
