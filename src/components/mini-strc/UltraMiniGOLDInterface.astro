---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/UltraMiniGOLDInterface.en.json';
import ru from './i18n/UltraMiniGOLDInterface.ru.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, ru });
---
<div class="mb-12">
  <div class="flex items-center gap-2 mb-3">
    <h3 class="text-xs font-semibold uppercase tracking-wider text-emerald-400">{t('title')}</h3>
    <span class="px-1.5 py-0.5 text-[9px] rounded bg-emerald-500/15 text-emerald-400 font-semibold">GATE 1 · CONTROL</span>
  </div>
  <p class="text-xs text-neutral-400 mb-4 max-w-3xl"><Fragment set:html={t('lede')} /></p>

  <div class="grid sm:grid-cols-3 gap-3 mb-4">
    <div class="bg-emerald-500/5 border border-emerald-500/20 rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-neutral-500 mb-1">ipTM</div>
      <div class="text-2xl font-mono text-emerald-400 font-bold">0.68</div>
      <div class="text-[10px] text-neutral-500 mt-1">{t('iptm_sub')}</div>
    </div>
    <div class="bg-emerald-500/5 border border-emerald-500/20 rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-neutral-500 mb-1">{t('zone_title')}</div>
      <div class="text-2xl font-mono text-emerald-400 font-bold">21 / 21</div>
      <div class="text-[10px] text-neutral-500 mt-1">{t('zone_sub')}</div>
    </div>
    <div class="bg-emerald-500/5 border border-emerald-500/20 rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-neutral-500 mb-1">{t('pae_title')}</div>
      <div class="text-2xl font-mono text-emerald-400 font-bold">&lt; 5 Å</div>
      <div class="text-[10px] text-neutral-500 mt-1">{t('pae_sub')}</div>
    </div>
  </div>

  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4">
    <div class="text-[10px] uppercase tracking-wider text-neutral-500 mb-2">{t('why_title')}</div>
    <p class="text-xs text-neutral-300 leading-relaxed mb-3"><Fragment set:html={t('why1')} /></p>
    <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('why2')} /></p>
  </div>

  <p class="text-[10px] text-neutral-500 mt-3">
    <Fragment set:html={t('files')} />
  </p>
</div>
