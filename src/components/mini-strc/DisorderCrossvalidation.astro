---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/DisorderCrossvalidation.en.json';
import zh from './i18n/DisorderCrossvalidation.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-sky-400 mb-4"><Fragment set:html={t('t30')} /></h3>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
        <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t1')} /></p>
        
        <!-- IUPred3 plot -->
        <div class="bg-white rounded-lg overflow-hidden mb-5">
          <img src="/images/iupred3-strc-full.jpg" alt="IUPred3 disorder prediction for full STRC (Q7RTU9, 1775 residues) showing N-terminal disorder and ordered C-terminal" class="w-full" loading="lazy" />
        </div>
        <p class="text-[10px] text-neutral-500 mb-5 text-center"><Fragment set:html={t('t2')} /></p>
        
        <!-- Region disorder table -->
        <div class="overflow-x-auto mb-5">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/10 text-neutral-300">
                <th class="text-left p-2 font-medium"><Fragment set:html={t('t24')} /></th>
                <th class="text-left p-2 font-medium"><Fragment set:html={t('t25')} /></th>
                <th class="text-right p-2 font-medium"><Fragment set:html={t('t26')} /></th>
                <th class="text-right p-2 font-medium"><Fragment set:html={t('t27')} /></th>
                <th class="text-right p-2 font-medium"><Fragment set:html={t('t28')} /></th>
                <th class="text-left p-2 font-medium"><Fragment set:html={t('t29')} /></th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-2">N-terminal</td>
                <td class="p-2 font-mono">1-114</td>
                <td class="p-2 text-right font-mono">0.220</td>
                <td class="p-2 text-right font-mono">12.3%</td>
                <td class="p-2 text-right font-mono">40.9</td>
                <td class="p-2 text-green-400"><Fragment set:html={t('t15')} /></td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-2"><Fragment set:html={t('t16')} /></td>
                <td class="p-2 font-mono">115-615</td>
                <td class="p-2 text-right font-mono">0.254</td>
                <td class="p-2 text-right font-mono">9.6%</td>
                <td class="p-2 text-right font-mono">50.2</td>
                <td class="p-2 text-green-400"><Fragment set:html={t('t17')} /></td>
              </tr>
              <tr class="border-b border-white/5 bg-red-500/[0.03]">
                <td class="p-2 text-red-400 font-medium"><Fragment set:html={t('t18')} /></td>
                <td class="p-2 font-mono text-red-400">616-699</td>
                <td class="p-2 text-right font-mono text-red-400">0.282</td>
                <td class="p-2 text-right font-mono text-red-400 font-bold">25.0%</td>
                <td class="p-2 text-right font-mono text-red-400">60.2</td>
                <td class="p-2 text-green-400"><Fragment set:html={t('t19')} /></td>
              </tr>
              <tr class="border-b border-white/5 bg-sky-500/[0.03]">
                <td class="p-2 text-sky-400 font-medium"><Fragment set:html={t('t20')} /></td>
                <td class="p-2 font-mono text-sky-400">700-1775</td>
                <td class="p-2 text-right font-mono text-sky-400">0.187</td>
                <td class="p-2 text-right font-mono text-sky-400 font-bold">2.5%</td>
                <td class="p-2 text-right font-mono text-sky-400">71.2</td>
                <td class="p-2 text-green-400"><Fragment set:html={t('t21')} /></td>
              </tr>
              <tr class="bg-emerald-500/[0.05]">
                <td class="p-2 text-white font-semibold"><Fragment set:html={t('t22')} /></td>
                <td class="p-2 font-mono text-emerald-400">1075-1775</td>
                <td class="p-2 text-right font-mono text-emerald-400">0.184</td>
                <td class="p-2 text-right font-mono text-emerald-400 font-bold">3.9%</td>
                <td class="p-2 text-right font-mono text-emerald-400">73.0</td>
                <td class="p-2 text-emerald-400"><Fragment set:html={t('t23')} /></td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <!-- Cross-validation at cut point -->
        <div class="bg-sky-500/10 border border-sky-500/20 rounded-lg p-4 mb-5">
          <h4 class="text-xs font-semibold text-sky-400 mb-2">{t('t31')}</h4>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1"><Fragment set:html={t('t3')} /></p>
              <div class="space-y-1 text-xs">
                <p class="text-neutral-300"><Fragment set:html={t('t4')} /></p>
                <p class="text-neutral-300"><Fragment set:html={t('t5')} /></p>
                <p class="text-neutral-300"><Fragment set:html={t('t6')} /></p>
              </div>
            </div>
            <div>
              <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1"><Fragment set:html={t('t7')} /></p>
              <div class="space-y-1 text-xs">
                <p class="text-neutral-300"><Fragment set:html={t('t8')} /></p>
                <p class="text-neutral-300"><Fragment set:html={t('t9')} /></p>
                <p class="text-neutral-300"><Fragment set:html={t('t10')} /></p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Disordered stretches -->
        <div class="mb-5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-2"><Fragment set:html={t('t11')} /></p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">73-86 (14 aa)</span>
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">151-166 (16 aa)</span>
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">200-208 (9 aa)</span>
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">270-282 (13 aa)</span>
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">332-339 (8 aa)</span>
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/15 border border-red-500/30 text-red-300 font-bold"><Fragment set:html={t('t32')} /></span>
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-sky-500/10 border border-sky-500/20 text-sky-400">1246-1248 (3 aa)</span>
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-sky-500/10 border border-sky-500/20 text-sky-400">1459-1463 (5 aa)</span>
            <span class="px-2 py-1 text-[10px] font-mono rounded bg-sky-500/10 border border-sky-500/20 text-sky-400">1734-1752 (19 aa)</span>
          </div>
          <p class="text-[10px] text-neutral-500 mt-2"><Fragment set:html={t('t12')} /></p>
        </div>
        
        <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-4">
          <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('t13')} /></p>
        </div>
        
        <p class="text-[10px] text-neutral-500 mt-4"><Fragment set:html={t('t14')} /></p>
      </div>
    </div>