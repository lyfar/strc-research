---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/Problem.en.json';
import zh from './i18n/Problem.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-red-400 mb-4">{t('t2')}</h3>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <p class="text-xs text-neutral-400 leading-relaxed mb-5"><Fragment set:html={t('t1')} /></p>
        
        <!-- Progress bars -->
        <div class="space-y-3">
          <div>
            <div class="flex items-center justify-between mb-1 text-xs">
              <span class="text-neutral-400">Full STRC cDNA</span>
              <span class="text-red-400 font-mono">5,325 bp</span>
            </div>
            <div class="h-3 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-red-500/60 rounded-full" style="width:100%"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1 text-xs">
              <span class="text-neutral-400"><Fragment set:html={t('t3')} /></span>
              <span class="text-yellow-400 font-mono">~4,400 bp</span>
            </div>
            <div class="h-3 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-yellow-500/60 rounded-full" style="width:82.6%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>