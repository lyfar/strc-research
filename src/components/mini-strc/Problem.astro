---
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
// No props needed

---
<!-- ═══════════════════════════════════════════ -->
<!-- SECTION 1: THE PROBLEM                      -->
<!-- ═══════════════════════════════════════════ -->
<div class="mb-12">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-red-400 mb-4">{t('ministrc.problem.t1')}</h3>
  
  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
    <p class="text-xs text-neutral-400 leading-relaxed mb-5">
      <Fragment set:html={t('ministrc.problem.t2')} />
      <strong class="text-white">~4,400 bp</strong> of cargo space. The gene is 925 bp too large. Current approaches split it 
      {t('ministrc.problem.t3')}
    </p>
    
    <!-- Progress bars -->
    <div class="space-y-3">
      <div>
        <div class="flex items-center justify-between mb-1 text-xs">
          <span class="text-neutral-400">{t('ministrc.problem.t4')}</span>
          <span class="text-red-400 font-mono">5,325 bp</span>
        </div>
        <div class="h-3 bg-white/5 rounded-full overflow-hidden">
          <div class="h-full bg-red-500/60 rounded-full" style="width:100%"></div>
        </div>
      </div>
      <div>
        <div class="flex items-center justify-between mb-1 text-xs">
          <span class="text-neutral-400">{t('ministrc.problem.t5')}</span>
          <span class="text-yellow-400 font-mono">~4,400 bp</span>
        </div>
        <div class="h-3 bg-white/5 rounded-full overflow-hidden">
          <div class="h-full bg-yellow-500/60 rounded-full" style="width:82.6%"></div>
        </div>
      </div>
    </div>
  </div>
</div>
