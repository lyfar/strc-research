---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/ThreeConstructs.en.json';
import ru from './i18n/ThreeConstructs.ru.json';
import zh from './i18n/ThreeConstructs.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, ru, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-cyan-400 mb-4">{t('t12')}</h3>
      <p class="text-xs text-neutral-400 mb-5 max-w-3xl"><Fragment set:html={t('lede')} /></p>

      <!-- Narrative arc: 3 steps -->
      <div class="grid lg:grid-cols-3 gap-3 mb-5">
        <div class="bg-white/[0.02] border border-white/10 rounded-lg p-4 relative">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-6 h-6 rounded-full bg-blue-500/20 text-blue-400 text-[10px] font-bold flex items-center justify-center">1</span>
            <span class="text-[9px] uppercase tracking-wider text-blue-400 font-semibold">{t('step1_label')}</span>
          </div>
          <div class="text-sm text-white font-semibold mb-1 font-mono">700–1775</div>
          <div class="text-[10px] text-neutral-500 mb-2">1,076 aa · 3,228 bp · 1,472 bp AAV spare</div>
          <p class="text-[11px] text-neutral-400 leading-relaxed"><Fragment set:html={t('step1_body')} /></p>
        </div>
        <div class="bg-white/[0.02] border border-white/10 rounded-lg p-4 relative">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-6 h-6 rounded-full bg-cyan-500/20 text-cyan-400 text-[10px] font-bold flex items-center justify-center">2</span>
            <span class="text-[9px] uppercase tracking-wider text-cyan-400 font-semibold">{t('step2_label')}</span>
          </div>
          <div class="text-sm text-white font-semibold mb-1">{t('step2_title')}</div>
          <div class="text-[10px] text-neutral-500 mb-2">{t('step2_sub')}</div>
          <p class="text-[11px] text-neutral-400 leading-relaxed"><Fragment set:html={t('step2_body')} /></p>
        </div>
        <div class="bg-emerald-500/[0.05] border border-emerald-500/30 rounded-lg p-4 relative">
          <div class="absolute top-2 right-2 text-[9px] px-1.5 py-0.5 rounded bg-emerald-500/20 text-emerald-400 font-bold">CLINICAL</div>
          <div class="flex items-center gap-2 mb-2">
            <span class="w-6 h-6 rounded-full bg-emerald-500/20 text-emerald-400 text-[10px] font-bold flex items-center justify-center">3</span>
            <span class="text-[9px] uppercase tracking-wider text-emerald-400 font-semibold">{t('step3_label')}</span>
          </div>
          <div class="text-sm text-white font-semibold mb-1 font-mono">1075–1775</div>
          <div class="text-[10px] text-neutral-500 mb-2">701 aa · 2,103 bp · 2,597 bp AAV spare</div>
          <p class="text-[11px] text-neutral-300 leading-relaxed"><Fragment set:html={t('step3_body')} /></p>
        </div>
      </div>

      <!-- Full comparison table -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg overflow-hidden mb-4">
        <div class="px-4 pt-3 pb-1 text-[10px] uppercase tracking-wider text-neutral-500">{t('table_title')}</div>
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/5 text-neutral-500">
                <th class="text-left p-3 font-medium">Construct</th>
                <th class="text-left p-3 font-medium">Residues</th>
                <th class="text-right p-3 font-medium">Length</th>
                <th class="text-right p-3 font-medium">CDS</th>
                <th class="text-right p-3 font-medium">AAV headroom</th>
                <th class="text-right p-3 font-medium">pTM</th>
                <th class="text-right p-3 font-medium">Status</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3">{t('row_mini_conservative')}</td>
                <td class="p-3 font-mono text-[10px]">616-1775</td>
                <td class="p-3 text-right font-mono">1,160 aa</td>
                <td class="p-3 text-right font-mono">3,480 bp</td>
                <td class="p-3 text-right font-mono">920 bp</td>
                <td class="p-3 text-right font-mono text-green-400">0.81</td>
                <td class="p-3 text-right text-[10px] text-neutral-500">{t('status_retired')}</td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3">{t('row_shorter')}</td>
                <td class="p-3 font-mono text-[10px]">700-1775</td>
                <td class="p-3 text-right font-mono">1,076 aa</td>
                <td class="p-3 text-right font-mono">3,228 bp</td>
                <td class="p-3 text-right font-mono text-green-400">1,472 bp</td>
                <td class="p-3 text-right font-mono text-green-400 font-bold">0.86</td>
                <td class="p-3 text-right text-[10px] text-blue-400">{t('status_original')}</td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-300 bg-emerald-500/[0.05]">
                <td class="p-3 font-semibold text-white">{t('row_ultra')}</td>
                <td class="p-3 font-mono text-[10px] text-emerald-400">1075-1775</td>
                <td class="p-3 text-right font-mono text-emerald-400">701 aa</td>
                <td class="p-3 text-right font-mono text-emerald-400">2,103 bp</td>
                <td class="p-3 text-right font-mono text-emerald-400 font-bold">2,597 bp</td>
                <td class="p-3 text-right font-mono text-emerald-400 font-bold">0.87</td>
                <td class="p-3 text-right text-[10px] text-emerald-400 font-bold">{t('status_clinical')}</td>
              </tr>
              <tr class="text-neutral-500">
                <td class="p-3">{t('row_delta_lrr')}</td>
                <td class="p-3 font-mono text-[10px]"><Fragment set:html={t('t6')} /></td>
                <td class="p-3 text-right font-mono">989 aa</td>
                <td class="p-3 text-right font-mono">2,967 bp</td>
                <td class="p-3 text-right font-mono">1,733 bp</td>
                <td class="p-3 text-right font-mono">0.80</td>
                <td class="p-3 text-right text-[10px] text-neutral-500">{t('status_rejected')}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- 3D viewers -->
      <div class="grid sm:grid-cols-3 gap-3 mb-4">
        <div class="bg-white/[0.02] border border-blue-500/20 rounded-lg overflow-hidden">
          <div id="v-jobf" style="width:100%;height:140px;position:relative;overflow:hidden;background:#080808;"></div>
          <div class="p-2 text-center">
            <div class="text-[10px] text-blue-400 font-semibold">Original Mini-STRC (700–1775)</div>
            <div class="text-[10px] text-neutral-500">pTM 0.86 · first validated candidate</div>
          </div>
        </div>
        <div class="bg-white/[0.02] border border-emerald-500/30 rounded-lg overflow-hidden ring-1 ring-emerald-500/10">
          <div id="v-jobh" style="width:100%;height:140px;position:relative;overflow:hidden;background:#080808;"></div>
          <div class="p-2 text-center">
            <div class="text-[10px] text-emerald-400 font-semibold">Ultra-Mini (1075–1775)</div>
            <div class="text-[10px] text-emerald-400">pTM 0.87 · <span class="font-bold">clinical candidate</span></div>
          </div>
        </div>
        <div class="bg-white/[0.02] border border-neutral-500/20 rounded-lg overflow-hidden opacity-60">
          <div id="v-jobg" style="width:100%;height:140px;position:relative;overflow:hidden;background:#080808;"></div>
          <div class="p-2 text-center">
            <div class="text-[10px] text-neutral-500 font-semibold">{t('t13')}</div>
            <div class="text-[10px] text-neutral-500">pTM 0.80 · rejected</div>
          </div>
        </div>
      </div>

    </div>
