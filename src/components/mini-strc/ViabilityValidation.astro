---
// Viability Validation — wraps SP, GPI, DeepLoc, Glycosylation by question
import { useTranslations } from '../../lib/i18n';
import SignalPeptide from './SignalPeptide.astro';
import GPIAnchor from './GPIAnchor.astro';
import SubcellularLocalization from './SubcellularLocalization.astro';
import Glycosylation from './Glycosylation.astro';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

---
<!-- ═══════════════════════════════════════════ -->
<!-- VIABILITY VALIDATION (grouped by question)  -->
<!-- ═══════════════════════════════════════════ -->
<div class="mb-12">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-cyan-400 mb-2">{t('ministrc.viability_validation.t1')}</h3>
  <p class="text-xs text-neutral-500 mb-6">
    {t('ministrc.viability_validation.t2')}
  </p>

  <!-- Question grid intro -->
  <div class="grid sm:grid-cols-2 gap-3 mb-8">
    <div class="p-3 bg-cyan-500/5 border border-cyan-500/10 rounded-lg">
      <p class="text-[10px] text-cyan-400 font-semibold uppercase tracking-wider">{t('ministrc.viability_validation.t3')}</p>
      <p class="text-[10px] text-neutral-500 mt-1"><Fragment set:html={t('ministrc.viability_validation.t4')} /></p>
    </div>
    <div class="p-3 bg-amber-500/5 border border-amber-500/10 rounded-lg">
      <p class="text-[10px] text-amber-400 font-semibold uppercase tracking-wider">{t('ministrc.viability_validation.t5')}</p>
      <p class="text-[10px] text-neutral-500 mt-1"><Fragment set:html={t('ministrc.viability_validation.t6')} /></p>
    </div>
    <div class="p-3 bg-teal-500/5 border border-teal-500/10 rounded-lg">
      <p class="text-[10px] text-teal-400 font-semibold uppercase tracking-wider">{t('ministrc.viability_validation.t7')}</p>
      <p class="text-[10px] text-neutral-500 mt-1"><Fragment set:html={t('ministrc.viability_validation.t8')} /></p>
    </div>
    <div class="p-3 bg-amber-500/5 border border-amber-500/10 rounded-lg">
      <p class="text-[10px] text-amber-400 font-semibold uppercase tracking-wider">{t('ministrc.viability_validation.t9')}</p>
      <p class="text-[10px] text-neutral-500 mt-1"><Fragment set:html={t('ministrc.viability_validation.t10')} /></p>
    </div>
  </div>

  <SignalPeptide lang={lang} />
  <GPIAnchor lang={lang} />
  <SubcellularLocalization lang={lang} />
  <Glycosylation lang={lang} />
</div>
