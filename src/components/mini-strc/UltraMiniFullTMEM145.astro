---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/UltraMiniFullTMEM145.en.json';
import ru from './i18n/UltraMiniFullTMEM145.ru.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, ru });
---
<div class="mb-12">
  <div class="flex items-center gap-2 mb-3">
    <h3 class="text-xs font-semibold uppercase tracking-wider text-emerald-400">{t('title')}</h3>
    <span class="px-1.5 py-0.5 text-[9px] rounded bg-emerald-500/15 text-emerald-400 font-semibold">GATE 1/3 · 2026-04-21</span>
  </div>
  <p class="text-xs text-neutral-400 mb-4 max-w-3xl"><Fragment set:html={t('lede')} /></p>

  <div class="grid lg:grid-cols-2 gap-4 mb-4">
    <!-- 5-model consensus -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-neutral-500 mb-2">{t('consensus')}</div>
      <table class="w-full text-[11px] font-mono">
        <thead>
          <tr class="text-neutral-500 border-b border-white/5">
            <th class="text-left pb-1.5 font-medium">Metric</th>
            <th class="text-right pb-1.5 font-medium">M0</th>
            <th class="text-right pb-1.5 font-medium">M1</th>
            <th class="text-right pb-1.5 font-medium">M2</th>
            <th class="text-right pb-1.5 font-medium">M3</th>
            <th class="text-right pb-1.5 font-medium">M4</th>
            <th class="text-right pb-1.5 font-medium text-emerald-400">μ</th>
          </tr>
        </thead>
        <tbody class="text-neutral-300">
          <tr class="border-b border-white/5">
            <td class="py-1">ipTM</td><td class="text-right">0.44</td><td class="text-right">0.43</td><td class="text-right">0.43</td><td class="text-right">0.43</td><td class="text-right">0.42</td><td class="text-right text-emerald-400">0.43</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1">pTM</td><td class="text-right">0.65</td><td class="text-right">0.65</td><td class="text-right">0.65</td><td class="text-right">0.65</td><td class="text-right">0.65</td><td class="text-right text-emerald-400">0.65</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1">PAE min (Å)</td><td class="text-right">6.93</td><td class="text-right">7.12</td><td class="text-right">7.11</td><td class="text-right">7.39</td><td class="text-right">7.37</td><td class="text-right text-neutral-300">7.18</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1">fraction_disord</td><td class="text-right">0.11</td><td class="text-right">0.11</td><td class="text-right">0.10</td><td class="text-right">0.10</td><td class="text-right">0.11</td><td class="text-right">0.11</td>
          </tr>
          <tr>
            <td class="py-1">has_clash</td><td class="text-right text-emerald-400">0</td><td class="text-right text-emerald-400">0</td><td class="text-right text-emerald-400">0</td><td class="text-right text-emerald-400">0</td><td class="text-right text-emerald-400">0</td><td class="text-right text-emerald-400">0</td>
          </tr>
        </tbody>
      </table>
      <p class="text-[10px] text-neutral-500 mt-3 leading-relaxed"><Fragment set:html={t('consensus_note')} /></p>
    </div>

    <!-- Precedent ladder -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4">
      <div class="text-[10px] uppercase tracking-wider text-neutral-500 mb-2">{t('ladder')}</div>
      <table class="w-full text-[11px] font-mono">
        <tbody class="text-neutral-300">
          <tr class="border-b border-white/5">
            <td class="py-1.5 text-neutral-400">Full STRC 1-1775 × TMEM145 full</td>
            <td class="text-right">0.47</td>
            <td class="text-right text-neutral-500 text-[9px]">Job 1 · 2026-03-16</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 text-neutral-400">Mini-STRC 594-1775 × TMEM145 full</td>
            <td class="text-right">0.43</td>
            <td class="text-right text-neutral-500 text-[9px]">Job 2 · 2026-03-16</td>
          </tr>
          <tr class="border-b border-white/5 bg-emerald-500/5">
            <td class="py-1.5 text-white font-semibold">Ultra-Mini 1075-1775 × TMEM145 full</td>
            <td class="text-right text-emerald-400 font-bold">0.43</td>
            <td class="text-right text-emerald-400 text-[9px]">this job · 2026-04-21</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 text-neutral-400">Ultra-Mini × TMEM145 <em>GOLD pruned</em></td>
            <td class="text-right text-emerald-400">0.68</td>
            <td class="text-right text-neutral-500 text-[9px]">2026-04-21</td>
          </tr>
          <tr>
            <td class="py-1.5 text-neutral-500">Derstroff et al. 2026 (pruned)</td>
            <td class="text-right text-neutral-500">0.91</td>
            <td class="text-right text-neutral-500 text-[9px]">published · coIP</td>
          </tr>
        </tbody>
      </table>
      <p class="text-[10px] text-neutral-500 mt-3 leading-relaxed"><Fragment set:html={t('ladder_note')} /></p>
    </div>
  </div>

  <!-- Interface residues -->
  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <div class="text-[10px] uppercase tracking-wider text-neutral-500">{t('interface')}</div>
      <div class="text-[10px] font-mono text-emerald-400">23 / 41 in GOLD zone (aa 1603–1749)</div>
    </div>
    <div class="grid sm:grid-cols-2 gap-3 text-[11px]">
      <div>
        <div class="text-[10px] text-neutral-500 mb-1">{t('gold_clusters')}</div>
        <div class="space-y-1 font-mono text-neutral-300">
          <div class="flex justify-between border-b border-white/5 py-0.5"><span>1630–1638</span><span class="text-emerald-400">2 / 9</span></div>
          <div class="flex justify-between border-b border-white/5 py-0.5"><span>1648–1651</span><span class="text-emerald-400">3 / 4</span></div>
          <div class="flex justify-between border-b border-white/5 py-0.5 bg-emerald-500/5"><span class="text-white font-semibold">1669–1680 (hot-spot)</span><span class="text-emerald-400 font-bold">9 / 12</span></div>
          <div class="flex justify-between border-b border-white/5 py-0.5 bg-emerald-500/5"><span class="text-white font-semibold">1692–1707 (hot-spot)</span><span class="text-emerald-400 font-bold">8 / 16</span></div>
          <div class="flex justify-between py-0.5"><span class="text-neutral-500">1603–1607</span><span class="text-neutral-500">0 / 5</span></div>
        </div>
        <p class="text-[10px] text-neutral-500 mt-2 leading-relaxed"><Fragment set:html={t('clusters_note')} /></p>
      </div>
      <div>
        <div class="text-[10px] text-neutral-500 mb-1">{t('out_of_zone')}</div>
        <div class="space-y-1 font-mono text-neutral-300">
          <div class="py-0.5 text-neutral-400"><span class="text-yellow-400">aa 1178–1212</span> · 12 contacts</div>
          <div class="py-0.5 text-neutral-400"><span class="text-yellow-400">aa 1769–1775</span> · 6 contacts</div>
        </div>
        <p class="text-[10px] text-neutral-500 mt-2 leading-relaxed"><Fragment set:html={t('oo_note')} /></p>
      </div>
    </div>
  </div>

  <!-- Gate pass criteria -->
  <div class="bg-emerald-500/10 border border-emerald-500/20 rounded-lg p-4">
    <div class="text-[10px] uppercase tracking-wider text-emerald-400 mb-2 font-semibold">{t('gate_title')}</div>
    <ul class="text-[11px] text-neutral-300 space-y-1">
      <li><span class="text-emerald-400 font-mono mr-1">✓</span> ipTM 0.43 > 0.4 <span class="text-neutral-500">(pre-registered threshold)</span></li>
      <li><span class="text-emerald-400 font-mono mr-1">✓</span> 23 / 41 contacts land in aa 1603–1749 (GOLD-validated binding zone)</li>
      <li><span class="text-emerald-400 font-mono mr-1">✓</span> Zero clashes, 11 % fraction-disordered across 5 models</li>
      <li><span class="text-emerald-400 font-mono mr-1">✓</span> 5-model consensus within ±0.02 ipTM (no outliers)</li>
    </ul>
  </div>

  <p class="text-[10px] text-neutral-500 mt-3">
    <Fragment set:html={t('files')} />
  </p>
</div>
