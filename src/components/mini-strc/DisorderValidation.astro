---
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
// No props needed

---
<!-- ═══════════════════════════════════════════ -->
<!-- SECTION 14: DISORDER CROSS-VALIDATION       -->
<!-- ═══════════════════════════════════════════ -->
<div class="mb-12">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-sky-400 mb-4">
    {t('ministrc.disorder_validation.t1')}
    <span class="ml-2 px-1.5 py-0.5 text-[10px] rounded bg-sky-500/20 text-sky-400 font-semibold normal-case">IUPred3</span>
  </h3>
  
  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
    <p class="text-xs text-neutral-400 leading-relaxed mb-4">
      <Fragment set:html={t('ministrc.disorder_validation.t2')} />
    </p>
    
    <!-- IUPred3 plot -->
    <div class="bg-white rounded-lg overflow-hidden mb-5">
      <img src="/images/iupred3-strc-full.jpg" alt="IUPred3 disorder prediction for full STRC (Q7RTU9, 1775 residues) showing N-terminal disorder and ordered C-terminal" class="w-full" loading="lazy" />
    </div>
    <p class="text-[10px] text-neutral-500 mb-5 text-center">
      {t('ministrc.disorder_validation.t3')}
    </p>
    
    <!-- Region disorder table -->
    <div class="overflow-x-auto mb-5">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b border-white/10 text-neutral-300">
            <th class="text-left p-2 font-medium">Region</th>
            <th class="text-left p-2 font-medium">Residues</th>
            <th class="text-right p-2 font-medium">{t('ministrc.disorder_validation.t4')}</th>
            <th class="text-right p-2 font-medium">% disordered</th>
            <th class="text-right p-2 font-medium">{t('ministrc.disorder_validation.t5')}</th>
            <th class="text-left p-2 font-medium">Agreement</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-white/5 text-neutral-400">
            <td class="p-2">N-terminal</td>
            <td class="p-2 font-mono">1-114</td>
            <td class="p-2 text-right font-mono">0.220</td>
            <td class="p-2 text-right font-mono">12.3%</td>
            <td class="p-2 text-right font-mono">40.9</td>
            <td class="p-2 text-green-400">{t('ministrc.disorder_validation.t6')}</td>
          </tr>
          <tr class="border-b border-white/5 text-neutral-400">
            <td class="p-2">Middle</td>
            <td class="p-2 font-mono">115-615</td>
            <td class="p-2 text-right font-mono">0.254</td>
            <td class="p-2 text-right font-mono">9.6%</td>
            <td class="p-2 text-right font-mono">50.2</td>
            <td class="p-2 text-green-400">{t('ministrc.disorder_validation.t7')}</td>
          </tr>
          <tr class="border-b border-white/5 bg-red-500/[0.03]">
            <td class="p-2 text-red-400 font-medium">{t('ministrc.disorder_validation.t8')}</td>
            <td class="p-2 font-mono text-red-400">616-699</td>
            <td class="p-2 text-right font-mono text-red-400">0.282</td>
            <td class="p-2 text-right font-mono text-red-400 font-bold">25.0%</td>
            <td class="p-2 text-right font-mono text-red-400">60.2</td>
            <td class="p-2 text-green-400">{t('ministrc.disorder_validation.t9')}</td>
          </tr>
          <tr class="border-b border-white/5 bg-sky-500/[0.03]">
            <td class="p-2 text-sky-400 font-medium">Mini-STRC</td>
            <td class="p-2 font-mono text-sky-400">700-1775</td>
            <td class="p-2 text-right font-mono text-sky-400">0.187</td>
            <td class="p-2 text-right font-mono text-sky-400 font-bold">2.5%</td>
            <td class="p-2 text-right font-mono text-sky-400">71.2</td>
            <td class="p-2 text-green-400">{t('ministrc.disorder_validation.t10')}</td>
          </tr>
          <tr class="bg-sky-500/[0.03]">
            <td class="p-2 text-sky-400">C-terminal core</td>
            <td class="p-2 font-mono text-sky-400">1075-1775</td>
            <td class="p-2 text-right font-mono text-sky-400">0.184</td>
            <td class="p-2 text-right font-mono text-sky-400">3.9%</td>
            <td class="p-2 text-right font-mono text-sky-400">73.0</td>
            <td class="p-2 text-green-400">{t('ministrc.disorder_validation.t11')}</td>
          </tr>
        </tbody>
      </table>
    </div>
    
    <!-- Cross-validation at cut point -->
    <div class="bg-sky-500/10 border border-sky-500/20 rounded-lg p-4 mb-5">
      <h4 class="text-xs font-semibold text-sky-400 mb-2">{t('ministrc.disorder_validation.t12')}</h4>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">{t('ministrc.disorder_validation.t13')}</p>
          <div class="space-y-1 text-xs">
            <p class="text-neutral-300"><Fragment set:html={t('ministrc.disorder_validation.t14')} /></p>
            <p class="text-neutral-300"><Fragment set:html={t('ministrc.disorder_validation.t15')} /></p>
            <p class="text-neutral-300"><Fragment set:html={t('ministrc.disorder_validation.t16')} /></p>
          </div>
        </div>
        <div>
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">{t('ministrc.disorder_validation.t17')}</p>
          <div class="space-y-1 text-xs">
            <p class="text-neutral-300"><Fragment set:html={t('ministrc.disorder_validation.t18')} /></p>
            <p class="text-neutral-300"><Fragment set:html={t('ministrc.disorder_validation.t19')} /></p>
            <p class="text-neutral-300"><Fragment set:html={t('ministrc.disorder_validation.t20')} /></p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Disordered stretches -->
    <div class="mb-5">
      <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-2">{t('ministrc.disorder_validation.t21')}</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">73-86 (14 aa)</span>
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">151-166 (16 aa)</span>
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">200-208 (9 aa)</span>
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">270-282 (13 aa)</span>
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/10 border border-red-500/20 text-red-400">332-339 (8 aa)</span>
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-red-500/15 border border-red-500/30 text-red-300 font-bold">{t('ministrc.disorder_validation.t22')}</span>
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-sky-500/10 border border-sky-500/20 text-sky-400">1246-1248 (3 aa)</span>
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-sky-500/10 border border-sky-500/20 text-sky-400">1459-1463 (5 aa)</span>
        <span class="px-2 py-1 text-[10px] font-mono rounded bg-sky-500/10 border border-sky-500/20 text-sky-400">1734-1752 (19 aa)</span>
      </div>
      <p class="text-[10px] text-neutral-500 mt-2">
        <span class="text-red-400">Red:</span> in truncated region (removed). <span class="text-sky-400">Blue:</span> in mini-STRC (retained, minor). The 676-696 stretch (21 residues) is the longest disordered region and sits exactly at our cut zone, confirming the truncation boundary is optimal.
      </p>
    </div>
    
    <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-4">
      <p class="text-xs text-neutral-300 leading-relaxed">
        <strong class="text-green-400">Conclusion:</strong> Two algorithmically independent methods (AlphaFold 3 deep learning + IUPred3 energy-based potentials) produce convergent disorder profiles. Both identify residue 691 as the disorder peak and residue 700 as the order boundary. The mini-STRC region (700-1775) is only 2.5% disordered by IUPred3 versus 25.0% in the transition zone. This cross-validation rules out the possibility that the disorder finding is an artifact of any single algorithm.
      </p>
    </div>
    
    <p class="text-[10px] text-neutral-500 mt-4">
      {t('ministrc.disorder_validation.t23')}
    </p>
  </div>
  
  <!-- PSIPRED / DISOPRED3 subsection -->
  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
    <h4 class="text-xs font-semibold text-neutral-300 mb-3">
      {t('ministrc.disorder_validation.t24')}
      <span class="ml-2 px-1.5 py-0.5 text-[10px] rounded bg-violet-500/20 text-violet-400 font-semibold normal-case">PSIPRED 4.0</span>
      <span class="ml-1 px-1.5 py-0.5 text-[10px] rounded bg-violet-500/20 text-violet-400 font-semibold normal-case">DISOPRED3</span>
    </h4>
    <p class="text-xs text-neutral-400 leading-relaxed mb-4">
      {t('ministrc.disorder_validation.t25')}
      {t('ministrc.disorder_validation.t26')}
    </p>

    <div class="overflow-x-auto mb-4">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b border-white/10 text-neutral-300">
            <th class="text-left p-2 font-medium">Region</th>
            <th class="text-right p-2 font-medium">Helix</th>
            <th class="text-right p-2 font-medium">Strand</th>
            <th class="text-right p-2 font-medium">Coil</th>
            <th class="text-right p-2 font-medium">{t('ministrc.disorder_validation.t27')}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <tr class="text-neutral-400 bg-red-500/[0.03]">
            <td class="p-2 text-red-400">N-terminal (1-699)</td>
            <td class="p-2 text-right font-mono">44.8%</td>
            <td class="p-2 text-right font-mono">1.6%</td>
            <td class="p-2 text-right font-mono">53.6%</td>
            <td class="p-2 text-right font-mono text-red-400 font-bold">32.8%</td>
          </tr>
          <tr class="text-neutral-400 bg-sky-500/[0.03]">
            <td class="p-2 text-sky-400">C-terminal (700-1775)</td>
            <td class="p-2 text-right font-mono">62.7%</td>
            <td class="p-2 text-right font-mono">0.0%</td>
            <td class="p-2 text-right font-mono">37.3%</td>
            <td class="p-2 text-right font-mono text-sky-400 font-bold">9.8%</td>
          </tr>
          <tr class="text-neutral-400 bg-red-500/[0.05]">
            <td class="p-2 text-red-300 font-medium">{t('ministrc.disorder_validation.t28')}</td>
            <td class="p-2 text-right font-mono">0.0%</td>
            <td class="p-2 text-right font-mono">0.0%</td>
            <td class="p-2 text-right font-mono text-red-400 font-bold">100%</td>
            <td class="p-2 text-right font-mono text-red-400">disordered</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p class="text-xs text-neutral-400 leading-relaxed mb-3">
      {t('ministrc.disorder_validation.t29')}
      <Fragment set:html={t('ministrc.disorder_validation.t30')} />
      {t('ministrc.disorder_validation.t31')}
      <Fragment set:html={t('ministrc.disorder_validation.t32')} />
    </p>
    
    <div class="bg-violet-500/10 border border-violet-500/20 rounded-lg p-4">
      <p class="text-xs text-neutral-300 leading-relaxed">
        <strong class="text-violet-400">Five independent methods now agree at residue 691:</strong>
      </p>
      <div class="grid sm:grid-cols-5 gap-2 mt-2 text-center">
        <div class="p-2 bg-white/5 rounded">
          <div class="text-[10px] text-neutral-500">AF3 pLDDT</div>
          <div class="text-xs font-mono text-red-400 font-bold">31.2</div>
        </div>
        <div class="p-2 bg-white/5 rounded">
          <div class="text-[10px] text-neutral-500">IUPred3</div>
          <div class="text-xs font-mono text-red-400 font-bold">0.819</div>
        </div>
        <div class="p-2 bg-white/5 rounded">
          <div class="text-[10px] text-neutral-500">ESMFold</div>
          <div class="text-xs font-mono text-red-400 font-bold">0.39</div>
        </div>
        <div class="p-2 bg-white/5 rounded">
          <div class="text-[10px] text-neutral-500">DISOPRED3</div>
          <div class="text-xs font-mono text-red-400 font-bold">disordered</div>
        </div>
        <div class="p-2 bg-white/5 rounded">
          <div class="text-[10px] text-neutral-500">PSIPRED</div>
          <div class="text-xs font-mono text-red-400 font-bold">100% coil</div>
        </div>
      </div>
    </div>
    
    <p class="text-[10px] text-neutral-500 mt-3">
      {t('ministrc.disorder_validation.t33')}
    </p>
  </div>
</div>
