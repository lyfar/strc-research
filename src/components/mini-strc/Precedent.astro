---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/Precedent.en.json';
import zh from './i18n/Precedent.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-400 mb-4">{t('t10')}</h3>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t1')} /></p>
        
        <div class="grid sm:grid-cols-2 gap-4 text-xs">
          <div>
            <div class="text-neutral-500 text-[10px] uppercase tracking-wider mb-2">{t('t11')}</div>
            <ul class="text-neutral-400 space-y-1">
              <li><Fragment set:html={t('t2')} /></li>
              <li><Fragment set:html={t('t3')} /></li>
              <li><Fragment set:html={t('t4')} /></li>
              <li><Fragment set:html={t('t5')} /></li>
            </ul>
          </div>
          <div>
            <div class="text-neutral-500 text-[10px] uppercase tracking-wider mb-2">{t('t12')}</div>
            <ul class="text-neutral-400 space-y-1">
              <li><Fragment set:html={t('t6')} /></li>
              <li><Fragment set:html={t('t7')} /></li>
              <li><Fragment set:html={t('t8')} /></li>
              <li><Fragment set:html={t('t9')} /></li>
            </ul>
          </div>
        </div>
      </div>
    </div>