---
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
// No props needed

---
<!-- ═══════════════════════════════════════════ -->
<!-- SECTION 3: PRECEDENT                        -->
<!-- ═══════════════════════════════════════════ -->
<div class="mb-12">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-400 mb-4">{t('ministrc.precedent.t1')}</h3>
  
  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
    <p class="text-xs text-neutral-400 leading-relaxed mb-4">
      {t('ministrc.precedent.t2')}
      {t('ministrc.precedent.t3')}
      <strong class="text-white">FDA-approved in 2023</strong>. Our proposal applies the same logic to stereocilin.
    </p>
    
    <div class="grid sm:grid-cols-2 gap-4 text-xs">
      <div class="p-3 bg-green-500/5 border border-green-500/10 rounded-lg">
        <div class="text-green-400 text-[10px] uppercase tracking-wider mb-2 font-semibold">{t('ministrc.precedent.t4')}</div>
        <ul class="text-neutral-400 space-y-1">
          <li><Fragment set:html={t('ministrc.precedent.t5')} /></li>
          <li>{t('ministrc.precedent.t6')}</li>
          <li>{t('ministrc.precedent.t7')}</li>
          <li>{t('ministrc.precedent.t8')}</li>
        </ul>
      </div>
      <div class="p-3 bg-purple-500/5 border border-purple-500/10 rounded-lg">
        <div class="text-purple-400 text-[10px] uppercase tracking-wider mb-2 font-semibold">{t('ministrc.precedent.t9')}</div>
        <ul class="text-neutral-400 space-y-1">
          <li><Fragment set:html={t('ministrc.precedent.t10')} /></li>
          <li>{t('ministrc.precedent.t11')}</li>
          <li>{t('ministrc.precedent.t12')}</li>
          <li><Fragment set:html={t('ministrc.precedent.t13')} /></li>
        </ul>
      </div>
    </div>
    <p class="text-[10px] text-neutral-500 mt-3">
      <Fragment set:html={t('ministrc.precedent.t14')} />
      {t('ministrc.precedent.t15')}
    </p>
  </div>
</div>
