---
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
// No props needed

---
<!-- ═══════════════════════════════════════════ -->
<!-- SECTION 10b: CROSS-SPECIES CONSERVATION     -->
<!-- ═══════════════════════════════════════════ -->
<div class="mb-12">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-400 mb-4">
    {t('ministrc.conservation.t1')}
    <span class="ml-2 px-1.5 py-0.5 text-[10px] rounded bg-blue-500/20 text-blue-400 font-semibold normal-case">9 mammals</span>
  </h3>
  
  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
    <p class="text-xs text-neutral-400 leading-relaxed mb-4">
      {t('ministrc.conservation.t2')}
      {t('ministrc.conservation.t3')}
    </p>

    <div class="overflow-x-auto mb-4">
      <table class="w-full text-xs">
        <thead>
          <tr class="text-neutral-500 border-b border-white/5">
            <th class="text-left p-2 font-medium">Species</th>
            <th class="text-right p-2 font-medium">N-term (1-699)</th>
            <th class="text-right p-2 font-medium">C-term (700-1775)</th>
            <th class="text-right p-2 font-medium">Δ</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <tr class="text-neutral-400"><td class="p-2">Rhesus macaque</td><td class="p-2 text-right font-mono">95.6%</td><td class="p-2 text-right font-mono">96.7%</td><td class="p-2 text-right font-mono text-green-400">+1.1</td></tr>
          <tr class="text-neutral-400"><td class="p-2">Green monkey</td><td class="p-2 text-right font-mono">95.0%</td><td class="p-2 text-right font-mono">95.6%</td><td class="p-2 text-right font-mono text-green-400">+0.6</td></tr>
          <tr class="text-neutral-400"><td class="p-2">Dog</td><td class="p-2 text-right font-mono">90.7%</td><td class="p-2 text-right font-mono">92.2%</td><td class="p-2 text-right font-mono text-green-400">+1.5</td></tr>
          <tr class="text-neutral-400"><td class="p-2">Horse</td><td class="p-2 text-right font-mono">91.1%</td><td class="p-2 text-right font-mono">91.5%</td><td class="p-2 text-right font-mono text-green-400">+0.4</td></tr>
          <tr class="text-neutral-400"><td class="p-2">Pig</td><td class="p-2 text-right font-mono">90.2%</td><td class="p-2 text-right font-mono">91.1%</td><td class="p-2 text-right font-mono text-green-400">+0.9</td></tr>
          <tr class="text-neutral-400"><td class="p-2">Cow</td><td class="p-2 text-right font-mono">89.3%</td><td class="p-2 text-right font-mono">90.3%</td><td class="p-2 text-right font-mono text-green-400">+1.0</td></tr>
          <tr class="text-neutral-400"><td class="p-2">Bat</td><td class="p-2 text-right font-mono">88.3%</td><td class="p-2 text-right font-mono">90.1%</td><td class="p-2 text-right font-mono text-green-400">+1.8</td></tr>
          <tr class="text-neutral-400"><td class="p-2">Mouse</td><td class="p-2 text-right font-mono">90.7%</td><td class="p-2 text-right font-mono">88.4%</td><td class="p-2 text-right font-mono text-red-400">-2.3</td></tr>
          <tr class="text-neutral-400"><td class="p-2">Rat</td><td class="p-2 text-right font-mono">91.4%</td><td class="p-2 text-right font-mono">87.0%</td><td class="p-2 text-right font-mono text-red-400">-4.4</td></tr>
          <tr class="border-t border-white/10 text-white font-medium"><td class="p-2">Average</td><td class="p-2 text-right font-mono">91.5%</td><td class="p-2 text-right font-mono">91.4%</td><td class="p-2 text-right font-mono text-neutral-400">+0.1</td></tr>
        </tbody>
      </table>
    </div>

    <div class="bg-amber-500/5 border border-amber-500/15 rounded-lg p-4">
      <p class="text-xs text-neutral-300 leading-relaxed">
        <strong class="text-amber-400">Interpretation:</strong> Both halves are <strong class="text-white">equally conserved (~91-92%)</strong> 
        {t('ministrc.conservation.t4')}
        <Fragment set:html={t('ministrc.conservation.t5')} />
        {t('ministrc.conservation.t6')}
        {t('ministrc.conservation.t7')}
        {t('ministrc.conservation.t8')}
      </p>
    </div>
  </div>
</div>
