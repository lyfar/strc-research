---
// Construct Optimization Map — which positions in mini-STRC can/cannot be modified
const { lang = 'en' } = Astro.props;

const criticalZones = [
  { pos: 885, wt: 'L', avg: -14.7, why: 'Hydrophobic core anchor' },
  { pos: 1652, wt: 'W', avg: -14.3, why: 'Adjacent to E1659 binding region' },
  { pos: 1724, wt: 'L', avg: -13.9, why: 'GPI anchor structural support' },
  { pos: 862, wt: 'W', avg: -13.9, why: 'Aromatic packing in LRR' },
  { pos: 1376, wt: 'G', avg: -13.7, why: 'Backbone flexibility in ARM repeat' },
  { pos: 1594, wt: 'L', avg: -13.7, why: 'ARM C-terminal packing' },
];

const safeZones = [
  { pos: 1309, wt: 'N', avg: 1.3, why: 'Surface-exposed, no structural role' },
  { pos: 765, wt: 'K', avg: 1.1, why: 'Flexible loop near cut point' },
  { pos: 1110, wt: 'M', avg: 0.9, why: 'ARM domain surface' },
  { pos: 1463, wt: 'N', avg: 0.1, why: 'Solvent-exposed asparagine' },
  { pos: 769, wt: 'K', avg: 0.1, why: 'Flexible loop, low conservation' },
];

const regions = [
  { name: 'E1659 region', range: '1600-1700', avg: -9.46, pct: 100 },
  { name: 'LRR domain', range: '754-1074', avg: -7.83, pct: 83 },
  { name: 'ARM C-term', range: '1400-1600', avg: -7.80, pct: 82 },
  { name: 'ARM mid', range: '1200-1400', avg: -6.56, pct: 69 },
  { name: 'GPI region', range: '1700-1775', avg: -6.44, pct: 68 },
  { name: 'ARM core', range: '1075-1200', avg: -5.71, pct: 60 },
];
---

<div class="mt-16 pt-10 border-t border-white/5">
  <h3 class="text-sm font-semibold text-white mb-1">Construct Optimization Map</h3>
  <p class="text-xs text-neutral-500 mb-6">
    Every position in mini-STRC scored for mutational tolerance. Tells the construct engineer which residues are untouchable and which are safe to modify during codon optimization or linker design.
  </p>

  <!-- What this means -->
  <div class="grid sm:grid-cols-2 gap-4 mb-8">
    <div class="bg-red-500/10 border border-red-500/20 rounded-lg p-4">
      <div class="text-sm font-bold text-red-400 mb-1">77% of positions: do not touch</div>
      <p class="text-xs text-neutral-400">784 of 1,022 positions are strongly constrained. Any amino acid change at these positions is predicted to damage protein function.</p>
    </div>
    <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-4">
      <div class="text-sm font-bold text-green-400 mb-1">5 positions: safe to modify</div>
      <p class="text-xs text-neutral-400">These surface-exposed residues tolerate substitution. Useful targets for synonymous codon changes or engineering modifications.</p>
    </div>
  </div>

  <!-- Regional constraint -->
  <h4 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-3">Constraint by region</h4>
  <div class="space-y-2 mb-3">
    {regions.map((r) => (
      <div class="flex items-center gap-3">
        <span class="w-28 text-xs text-neutral-400 text-right shrink-0">{r.name}</span>
        <div class="flex-1 h-5 bg-white/[0.02] rounded overflow-hidden">
          <div
            class={`h-full rounded ${r.pct === 100 ? 'bg-red-500/70' : 'bg-red-500/40'}`}
            style={`width: ${r.pct}%`}
          ></div>
        </div>
        <span class="w-12 text-xs font-mono text-neutral-500 shrink-0">{r.avg.toFixed(1)}</span>
      </div>
    ))}
  </div>
  <p class="text-xs text-neutral-600 mb-8">More negative = more constrained. E1659 region is the most critical part of the construct.</p>

  <!-- Critical positions -->
  <div class="grid sm:grid-cols-2 gap-6 mb-6">
    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider text-red-400/70 mb-3">Critical (do not modify)</h4>
      <div class="space-y-1">
        {criticalZones.map((p) => (
          <div class="flex items-center gap-2 text-xs">
            <span class="font-mono text-red-400 font-bold w-14">{p.wt}{p.pos}</span>
            <span class="font-mono text-neutral-500 w-10">{p.avg.toFixed(1)}</span>
            <span class="text-neutral-600">{p.why}</span>
          </div>
        ))}
      </div>
    </div>
    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider text-green-400/70 mb-3">Safe to modify</h4>
      <div class="space-y-1">
        {safeZones.map((p) => (
          <div class="flex items-center gap-2 text-xs">
            <span class="font-mono text-green-400 font-bold w-14">{p.wt}{p.pos}</span>
            <span class="font-mono text-neutral-500 w-10">+{p.avg.toFixed(1)}</span>
            <span class="text-neutral-600">{p.why}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <p class="text-xs text-neutral-600">
    19,418 single amino acid substitutions scored with <a href="/tools/tool/esm1v" class="text-blue-400 no-underline">ESM-2</a> protein language model. Variant library generated with <a href="https://doi.org/10.64898/2026.04.06.716802" class="text-blue-400 no-underline" target="_blank">PoolParty</a>. Full variant matrix available on request.
  </p>
</div>
