                <tr class="border-b border-white/5 bg-amber-500/[0.03]">
                  <td class="p-2 font-mono text-amber-400">N1179</td>
                  <td class="p-2 font-mono text-amber-400">NLTL</td>
                  <td class="p-2 text-right font-mono text-amber-400">0.678</td>
                  <td class="p-2 text-center text-amber-400">8/9</td>
                  <td class="p-2"><span class="text-green-400">+</span></td>
                  <td class="p-2"><Fragment set:html={t('t16')} /></td>
                </tr>
                <tr class="bg-amber-500/[0.03]">
                  <td class="p-2 font-mono text-amber-400">N1274</td>
                  <td class="p-2 font-mono text-amber-400">NESI</td>
                  <td class="p-2 text-right font-mono text-amber-400">0.517</td>
                  <td class="p-2 text-center text-amber-400">6/9</td>
                  <td class="p-2"><span class="text-green-400">+</span></td>
                  <td class="p-2"><Fragment set:html={t('t17')} /></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- Mini-STRC construct confirmation -->
        <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4 mb-5">
          <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('t3')} /></p>
        </div>
        
        <!-- Summary boxes -->
        <div class="grid sm:grid-cols-3 gap-3">
          <div class="bg-red-500/10 border border-red-500/20 rounded-lg p-3 text-center">
            <p class="text-2xl font-bold text-red-400">9 / 11</p>
            <p class="text-[10px] text-neutral-400 mt-1"><Fragment set:html={t('t4')} /></p>
            <p class="text-[10px] text-neutral-500"><Fragment set:html={t('t5')} /></p>
          </div>
          <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-3 text-center">
            <p class="text-2xl font-bold text-green-400">5 / 2</p>
            <p class="text-[10px] text-neutral-400 mt-1"><Fragment set:html={t('t6')} /></p>
            <p class="text-[10px] text-neutral-500"><Fragment set:html={t('t7')} /></p>
          </div>
          <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-3 text-center">
            <p class="text-2xl font-bold text-amber-400">0.60</p>
            <p class="text-[10px] text-neutral-400 mt-1"><Fragment set:html={t('t8')} /></p>
            <p class="text-[10px] text-neutral-500"><Fragment set:html={t('t9')} /></p>
          </div>
        </div>
        
        <p class="text-[10px] text-neutral-500 mt-4"><Fragment set:html={t('t10')} /></p>
      </div>
    </div>