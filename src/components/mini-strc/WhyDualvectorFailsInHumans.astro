---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/WhyDualvectorFailsInHumans.en.json';
import zh from './i18n/WhyDualvectorFailsInHumans.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-amber-400 mb-4">{t('t3')}</h3>
      
      <div class="bg-white/[0.02] border border-cyan-500/20 rounded-lg p-5">
        <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t1')} /></p>
        
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div class="bg-green-500/5 border border-green-500/10 rounded-lg p-4 text-center">
            <div class="text-[10px] text-green-400 font-semibold uppercase tracking-wider mb-2">{t('t4')}</div>
            <div class="text-2xl font-bold text-green-400 mb-1">~60%</div>
            <div class="text-[10px] text-neutral-500">OHC co-transduction (Iranfar 2026)</div>
          </div>
          <div class="bg-amber-500/5 border border-amber-500/10 rounded-lg p-4 text-center">
            <div class="text-[10px] text-amber-400 font-semibold uppercase tracking-wider mb-2">{t('t5')}</div>
            <div class="text-2xl font-bold text-amber-400 mb-1">~6%</div>
            <div class="text-[10px] text-neutral-500">{t('t6')}</div>
          </div>
        </div>
        
        <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('t2')} /></p>
      </div>
    </div>