---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/Conclusions.en.json';
import zh from './i18n/Conclusions.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-green-400 mb-4">{t('t35')}</h3>
      
      <div class="bg-green-500/5 border border-green-500/20 rounded-lg p-5 mb-4">
        <div class="text-xs text-neutral-300 leading-relaxed space-y-3">
          <p><Fragment set:html={t('t1')} /></p>
          <p><Fragment set:html={t('t2')} /></p>
          <p><Fragment set:html={t('t3')} /></p>
          <ul class="space-y-1 ml-4">
            <li><Fragment set:html={t('t5')} /></li>
            <li><Fragment set:html={t('t6')} /></li>
            <li><Fragment set:html={t('t7')} /></li>
            <li><Fragment set:html={t('t8')} /></li>
            <li><Fragment set:html={t('t9')} /></li>
            <li><Fragment set:html={t('t10')} /></li>
            <li><Fragment set:html={t('t11')} /></li>
            <li><Fragment set:html={t('t12')} /></li>
            <li><Fragment set:html={t('t13')} /></li>
            <li><Fragment set:html={t('t14')} /></li>
            <li><Fragment set:html={t('t15')} /></li>
            <li><Fragment set:html={t('t16')} /></li>
            <li><Fragment set:html={t('t17')} /></li>
          </ul>
        </div>
      </div>
      
      <!-- What's been resolved computationally -->
      <div class="bg-green-500/10 border border-green-500/20 rounded-lg p-4 mb-4">
        <h4 class="text-xs font-semibold text-green-400 mb-2">{t('t36')}</h4>
        <ul class="text-xs text-neutral-300 space-y-1">
          <li><Fragment set:html={t('t18')} /></li>
          <li><Fragment set:html={t('t19')} /></li>
          <li><Fragment set:html={t('t20')} /></li>
          <li><Fragment set:html={t('t21')} /></li>
          <li><Fragment set:html={t('t22')} /></li>
          <li><Fragment set:html={t('t23')} /></li>
          <li><Fragment set:html={t('t24')} /></li>
          <li><Fragment set:html={t('t25')} /></li>
          <li><Fragment set:html={t('t26')} /></li>
          <li><Fragment set:html={t('t48')} /></li>
          <li><Fragment set:html={t('t49')} /></li>
          <li><Fragment set:html={t('t50')} /></li>
          <li><Fragment set:html={t('t51')} /></li>
          <li><Fragment set:html={t('t52')} /></li>
        </ul>
      </div>
      
      <!-- Remaining questions -->
      <div class="bg-yellow-500/10 border border-yellow-500/20 rounded-lg p-4 mb-4">
        <h4 class="text-xs font-semibold text-yellow-400 mb-2">{t('t37')}</h4>
        <ul class="text-xs text-neutral-300 space-y-1">
          <li><Fragment set:html={t('t27')} /></li>
          <li><Fragment set:html={t('t28')} /></li>
          <li><Fragment set:html={t('t29')} /></li>
          <li><Fragment set:html={t('t30')} /></li>
