---
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
// No props needed

---
<!-- ═══════════════════════════════════════════ -->
<!-- SECTION 4: AF3 VALIDATION                   -->
<!-- ═══════════════════════════════════════════ -->
<div class="mb-12">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-green-400 mb-4">{t('ministrc.a_f3_validation.t1')}</h3>
  
  <div class="grid sm:grid-cols-3 gap-3 mb-4">
    <!-- Full STRC -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg overflow-hidden">
      <div id="v-job4" style="width:100%;height:140px;position:relative;overflow:hidden;background:#080808;"></div>
      <div class="p-3">
        <div class="text-[10px] text-neutral-500 mb-1">{t('ministrc.a_f3_validation.t2')}</div>
        <div class="text-lg font-bold font-mono text-neutral-300">0.63</div>
        <div class="text-[10px] text-neutral-500">{t('ministrc.a_f3_validation.t3')}</div>
      </div>
    </div>
    
    <!-- N-terminal solo -->
    <div class="bg-white/[0.02] border border-red-500/20 rounded-lg overflow-hidden">
      <div id="v-job6" style="width:100%;height:140px;position:relative;overflow:hidden;background:#080808;"></div>
      <div class="p-3">
        <div class="text-[10px] text-red-400 mb-1">{t('ministrc.a_f3_validation.t4')}</div>
        <div class="text-lg font-bold font-mono text-red-400">0.27</div>
        <div class="text-[10px] text-neutral-500">{t('ministrc.a_f3_validation.t5')}</div>
      </div>
    </div>
    
    <!-- Mini-STRC -->
    <div class="bg-white/[0.02] border border-green-500/20 rounded-lg overflow-hidden">
      <div id="v-job5" style="width:100%;height:140px;position:relative;overflow:hidden;background:#080808;"></div>
      <div class="p-3">
        <div class="text-[10px] text-green-400 mb-1">{t('ministrc.a_f3_validation.t6')}</div>
        <div class="text-lg font-bold font-mono text-green-400">0.81</div>
        <div class="text-[10px] text-neutral-500">{t('ministrc.a_f3_validation.t7')}</div>
      </div>
    </div>
  </div>
  
  <p class="text-xs text-neutral-400 leading-relaxed">
    <Fragment set:html={t('ministrc.a_f3_validation.t8')} />
    {t('ministrc.a_f3_validation.t9')}
    {t('ministrc.a_f3_validation.t10')}
  </p>
</div>
