---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/SignalPeptide.en.json';
import zh from './i18n/SignalPeptide.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-cyan-400 mb-4"><Fragment set:html={t('t21')} /></h3>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
        <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t1')} /></p>
        <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t2')} /></p>
        <p class="text-xs text-neutral-400 leading-relaxed mb-5"><Fragment set:html={t('t3')} /></p>
        
        <!-- Results table -->
        <div class="overflow-x-auto mb-5">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/10 text-neutral-300">
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t16')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t17')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t18')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t19')} /></th>
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t20')} /></th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t9')} /></td>
                <td class="p-3 text-right font-mono">93.4%</td>
                <td class="p-3 text-right font-mono"><Fragment set:html={t('t10')} /></td>
                <td class="p-3 text-right font-mono">0.689</td>
                <td class="p-3"><Fragment set:html={t('t11')} /></td>
              </tr>
              <tr class="border-b border-white/5 bg-cyan-500/[0.03]">
                <td class="p-3 text-cyan-400 font-medium"><Fragment set:html={t('t12')} /></td>
                <td class="p-3 text-right font-mono text-cyan-400 font-bold">99.97%</td>
                <td class="p-3 text-right font-mono text-cyan-400"><Fragment set:html={t('t13')} /></td>
                <td class="p-3 text-right font-mono text-cyan-400">0.978</td>
                <td class="p-3"><Fragment set:html={t('t14')} /></td>
              </tr>
              <tr class="text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t15')} /></td>
                <td class="p-3 text-right font-mono text-red-400">0.00%</td>
                <td class="p-3 text-right font-mono text-neutral-500">—</td>
                <td class="p-3 text-right font-mono text-neutral-500">—</td>
                <td class="p-3"><span class="text-red-400">✗ No SP</span></td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div class="bg-cyan-500/10 border border-cyan-500/20 rounded-lg p-4 mb-5">
          <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('t4')} /></p>
        </div>
        
        <!-- SignalP plots -->
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-2 text-center"><Fragment set:html={t('t5')} /></p>
            <div class="bg-white rounded-lg overflow-hidden">
              <img src="/images/signalp-igk-mini-strc.png" alt="SignalP 6.0 prediction for IgK-SP + shorter mini-STRC showing 99.97% SP probability and clean cleavage at position 20-21" class="w-full" loading="lazy" />
            </div>
          </div>
          <div>
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-2 text-center"><Fragment set:html={t('t6')} /></p>
            <div class="bg-white rounded-lg overflow-hidden">
              <img src="/images/signalp-full-strc.png" alt="SignalP 6.0 prediction for full STRC showing 93.4% SP probability and cleavage at position 24-25" class="w-full" loading="lazy" />
            </div>
          </div>
        </div>
        <p class="text-[10px] text-neutral-500 mt-3 text-center"><Fragment set:html={t('t7')} /></p>
      </div>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4">
        <h4 class="text-xs font-semibold text-neutral-300 mb-2">{t('t22')}</h4>
        <p class="text-xs text-neutral-400 leading-relaxed"><Fragment set:html={t('t8')} /></p>
      </div>
    </div>