---
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
// No props needed

---
<!-- ═══════════════════════════════════════════ -->
<!-- SECTION 10: TRUNCATION BOUNDARY SWEEP       -->
<!-- ═══════════════════════════════════════════ -->
<div class="mb-12">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-violet-400 mb-4">
    {t('ministrc.truncation_boundary.t1')}
    <span class="ml-2 px-1.5 py-0.5 text-[10px] rounded bg-violet-500/20 text-violet-400 font-semibold normal-case">4 AF3 jobs</span>
  </h3>
  
  <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
    <p class="text-xs text-neutral-400 leading-relaxed mb-4">
      {t('ministrc.truncation_boundary.t2')}
    </p>
    
    <div class="overflow-x-auto mb-5">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b border-white/10 text-neutral-300">
            <th class="text-left p-3 font-medium">{t('ministrc.truncation_boundary.t3')}</th>
            <th class="text-right p-3 font-medium">Residues</th>
            <th class="text-right p-3 font-medium">CDS (bp)</th>
            <th class="text-right p-3 font-medium">pTM</th>
            <th class="text-right p-3 font-medium">Ranking</th>
            <th class="text-right p-3 font-medium">Disorder</th>
            <th class="text-right p-3 font-medium">{t('ministrc.truncation_boundary.t4')}</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-white/5 text-neutral-400">
            <td class="p-3 font-mono">650</td>
            <td class="p-3 text-right font-mono">650-1775</td>
            <td class="p-3 text-right font-mono">3,378</td>
            <td class="p-3 text-right font-mono">0.84</td>
            <td class="p-3 text-right font-mono">0.88</td>
            <td class="p-3 text-right font-mono">7%</td>
            <td class="p-3 text-right font-mono">1,322 bp</td>
          </tr>
          <tr class="border-b border-white/5 text-neutral-400">
            <td class="p-3 font-mono">680</td>
            <td class="p-3 text-right font-mono">680-1775</td>
            <td class="p-3 text-right font-mono">3,288</td>
            <td class="p-3 text-right font-mono">0.84</td>
            <td class="p-3 text-right font-mono">0.87</td>
            <td class="p-3 text-right font-mono">6%</td>
            <td class="p-3 text-right font-mono">1,412 bp</td>
          </tr>
          <tr class="border-b border-white/5 bg-violet-500/[0.03]">
            <td class="p-3 font-mono text-violet-400 font-bold">700 ★</td>
            <td class="p-3 text-right font-mono text-violet-400">700-1775</td>
            <td class="p-3 text-right font-mono text-violet-400">3,228</td>
            <td class="p-3 text-right font-mono text-violet-400 font-bold">0.86</td>
            <td class="p-3 text-right font-mono text-violet-400">0.88</td>
            <td class="p-3 text-right font-mono text-violet-400">4%</td>
            <td class="p-3 text-right font-mono text-violet-400">1,472 bp</td>
          </tr>
          <tr class="border-b border-white/5 bg-violet-500/[0.03]">
            <td class="p-3 font-mono text-violet-400 font-bold">720</td>
            <td class="p-3 text-right font-mono text-violet-400">720-1775</td>
            <td class="p-3 text-right font-mono text-violet-400">3,168</td>
            <td class="p-3 text-right font-mono text-violet-400 font-bold">0.86</td>
            <td class="p-3 text-right font-mono text-violet-400">0.89</td>
            <td class="p-3 text-right font-mono text-violet-400">4-5%</td>
            <td class="p-3 text-right font-mono text-violet-400">1,532 bp</td>
          </tr>
        </tbody>
      </table>
    </div>
    
    <div class="bg-violet-500/10 border border-violet-500/20 rounded-lg p-4 mb-4">
      <p class="text-xs text-neutral-300 leading-relaxed">
        <strong class="text-violet-400">Result:</strong> Residues 700 and 720 are both optimal (pTM 0.86), while cutting at 650 or 680 includes the disorder dip (residues 685-694, pLDDT 31-39) and gives worse results. This confirms the pLDDT-based domain boundary. The cut at 700 sits at the exact recovery point where structural confidence returns.
      </p>
    </div>
    
    <!-- IgK-SP fold test -->
    <h4 class="text-xs font-semibold text-neutral-300 mb-3">{t('ministrc.truncation_boundary.t5')}</h4>
    <div class="overflow-x-auto mb-4">
      <table class="w-full text-xs">
        <thead>
          <tr class="border-b border-white/10 text-neutral-300">
            <th class="text-left p-3 font-medium">Construct</th>
            <th class="text-right p-3 font-medium">pTM</th>
            <th class="text-right p-3 font-medium">Ranking</th>
            <th class="text-right p-3 font-medium">Disorder</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-white/5 text-neutral-400">
            <td class="p-3">{t('ministrc.truncation_boundary.t6')}</td>
            <td class="p-3 text-right font-mono">0.86</td>
            <td class="p-3 text-right font-mono">0.88</td>
            <td class="p-3 text-right font-mono">4%</td>
          </tr>
          <tr class="text-neutral-400">
            <td class="p-3">{t('ministrc.truncation_boundary.t7')}</td>
            <td class="p-3 text-right font-mono">0.85</td>
            <td class="p-3 text-right font-mono">0.88</td>
            <td class="p-3 text-right font-mono">5%</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-neutral-400 leading-relaxed">
      {t('ministrc.truncation_boundary.t8')}
    </p>
  </div>
</div>
