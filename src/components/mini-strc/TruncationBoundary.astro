---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/TruncationBoundary.en.json';
import zh from './i18n/TruncationBoundary.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-violet-400 mb-4"><Fragment set:html={t('t15')} /></h3>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
        <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t1')} /></p>
        
        <div class="overflow-x-auto mb-5">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/10 text-neutral-300">
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t6')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t7')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t8')} /></th>
                <th class="text-right p-3 font-medium">pTM</th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t9')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t10')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t11')} /></th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3 font-mono">650</td>
                <td class="p-3 text-right font-mono">650-1775</td>
                <td class="p-3 text-right font-mono">3,378</td>
                <td class="p-3 text-right font-mono">0.84</td>
                <td class="p-3 text-right font-mono">0.88</td>
                <td class="p-3 text-right font-mono">7%</td>
                <td class="p-3 text-right font-mono">1,322 bp</td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3 font-mono">680</td>
                <td class="p-3 text-right font-mono">680-1775</td>
                <td class="p-3 text-right font-mono">3,288</td>
                <td class="p-3 text-right font-mono">0.84</td>
                <td class="p-3 text-right font-mono">0.87</td>
                <td class="p-3 text-right font-mono">6%</td>
                <td class="p-3 text-right font-mono">1,412 bp</td>
              </tr>
              <tr class="border-b border-white/5 bg-violet-500/[0.03]">
                <td class="p-3 font-mono text-violet-400 font-bold">700 ★</td>
                <td class="p-3 text-right font-mono text-violet-400">700-1775</td>
                <td class="p-3 text-right font-mono text-violet-400">3,228</td>
                <td class="p-3 text-right font-mono text-violet-400 font-bold">0.86</td>
                <td class="p-3 text-right font-mono text-violet-400">0.88</td>
                <td class="p-3 text-right font-mono text-violet-400">4%</td>
                <td class="p-3 text-right font-mono text-violet-400">1,472 bp</td>
              </tr>
              <tr class="border-b border-white/5 bg-violet-500/[0.03]">
                <td class="p-3 font-mono text-violet-400 font-bold">720</td>
                <td class="p-3 text-right font-mono text-violet-400">720-1775</td>
                <td class="p-3 text-right font-mono text-violet-400">3,168</td>
                <td class="p-3 text-right font-mono text-violet-400 font-bold">0.86</td>
                <td class="p-3 text-right font-mono text-violet-400">0.89</td>
                <td class="p-3 text-right font-mono text-violet-400">4-5%</td>
                <td class="p-3 text-right font-mono text-violet-400">1,532 bp</td>
              </tr>
              <tr class="border-b border-white/5 bg-emerald-500/[0.06]">
                <td class="p-3 font-mono text-emerald-400 font-bold">1075 ★★</td>
                <td class="p-3 text-right font-mono text-emerald-400">1075-1775</td>
                <td class="p-3 text-right font-mono text-emerald-400">2,103</td>
                <td class="p-3 text-right font-mono text-emerald-400 font-bold">0.87</td>
                <td class="p-3 text-right font-mono text-emerald-400 font-bold">0.90</td>
                <td class="p-3 text-right font-mono text-emerald-400">6%</td>
                <td class="p-3 text-right font-mono text-emerald-400 font-bold">2,597 bp</td>
              </tr>
            </tbody>
          </table>
          <p class="text-[10px] text-neutral-500 mt-2">★ first-pass optimum · ★★ step-2 clinical (Ultra-Mini) — <span class="text-emerald-400">better pTM, better ranking, 1,125 bp more headroom</span>; 2 pp more IUPred3 disorder is a narrow-window artefact of the ARM repeats (AF3 pTM is the load-bearing fold score).</p>
        </div>
        
        <div class="bg-violet-500/10 border border-violet-500/20 rounded-lg p-4 mb-4">
          <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('t2')} /></p>
        </div>
        
        <!-- IgK-SP fold test -->
        <h4 class="text-xs font-semibold text-neutral-300 mb-3">{t('t16')}</h4>
        <div class="overflow-x-auto mb-4">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/10 text-neutral-300">
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t12')} /></th>
                <th class="text-right p-3 font-medium">pTM</th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t13')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t14')} /></th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t4')} /></td>
                <td class="p-3 text-right font-mono">0.86</td>
                <td class="p-3 text-right font-mono">0.88</td>
                <td class="p-3 text-right font-mono">4%</td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t5')} /></td>
                <td class="p-3 text-right font-mono">0.85</td>
                <td class="p-3 text-right font-mono">0.88</td>
                <td class="p-3 text-right font-mono">5%</td>
              </tr>
              <tr class="bg-emerald-500/[0.05] text-neutral-300">
                <td class="p-3 text-white font-semibold">Ultra-Mini 1075-1775 (no SP, solo fold)</td>
                <td class="p-3 text-right font-mono text-emerald-400 font-bold">0.87</td>
                <td class="p-3 text-right font-mono text-emerald-400">0.90</td>
                <td class="p-3 text-right font-mono text-emerald-400">6%</td>
              </tr>
            </tbody>
          </table>
          <p class="text-[10px] text-neutral-500 mt-2">IgK-SP behaviour is identical on Ultra-Mini by construction (SP is cleaved before the mature protein sees the C-terminal fold). A dedicated IgK-SP + Ultra-Mini AF3 job was not run — the 21 aa SP has no more impact on the 701 aa Ultra-Mini than it did on the 1,076 aa Mini-STRC.</p>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed"><Fragment set:html={t('t3')} /></p>
      </div>
    </div>