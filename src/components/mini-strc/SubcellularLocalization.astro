---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/SubcellularLocalization.en.json';
import zh from './i18n/SubcellularLocalization.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-teal-400 mb-4"><Fragment set:html={t('t23')} /></h3>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-4">
        <p class="text-xs text-neutral-400 leading-relaxed mb-4"><Fragment set:html={t('t1')} /></p>
        
        <div class="overflow-x-auto mb-5">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/10 text-neutral-300">
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t17')} /></th>
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t18')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t19')} /></th>
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t20')} /></th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t21')} /></th>
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t22')} /></th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t6')} /></td>
                <td class="p-3"><Fragment set:html={t('t7')} /></td>
                <td class="p-3 text-right font-mono">74.1%</td>
                <td class="p-3"><Fragment set:html={t('t8')} /></td>
                <td class="p-3 text-right font-mono">28.4%</td>
                <td class="p-3"><Fragment set:html={t('t9')} /></td>
              </tr>
              <tr class="border-b border-white/5 bg-teal-500/[0.03]">
                <td class="p-3 text-teal-400 font-medium">IgK-SP + Mini-STRC 700-1775 (first pass)</td>
                <td class="p-3"><Fragment set:html={t('t11')} /></td>
                <td class="p-3 text-right font-mono text-teal-400">57.4%</td>
                <td class="p-3 text-teal-400"><Fragment set:html={t('t12')} /></td>
                <td class="p-3 text-right font-mono text-teal-400 font-bold">72.1%</td>
                <td class="p-3"><Fragment set:html={t('t13')} /></td>
              </tr>
              <tr class="border-b border-white/5 bg-emerald-500/[0.05]">
                <td class="p-3 text-white font-semibold">IgK-SP + Ultra-Mini 1075-1775 (clinical · by construction)</td>
                <td class="p-3"><span class="text-emerald-400 font-semibold">Extracellular</span></td>
                <td class="p-3 text-right font-mono text-emerald-400">57.4%</td>
                <td class="p-3 text-emerald-400">Lipid anchor</td>
                <td class="p-3 text-right font-mono text-emerald-400 font-bold">72.1%</td>
                <td class="p-3"><span class="text-emerald-400">✓ Yes</span></td>
              </tr>
              <tr class="text-neutral-400">
                <td class="p-3">No SP (control)</td>
                <td class="p-3"><Fragment set:html={t('t14')} /></td>
                <td class="p-3 text-right font-mono">42.9%</td>
                <td class="p-3"><Fragment set:html={t('t15')} /></td>
                <td class="p-3 text-right font-mono">71.4%</td>
                <td class="p-3"><Fragment set:html={t('t16')} /></td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div class="bg-teal-500/10 border border-teal-500/20 rounded-lg p-4 mb-5">
          <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('t2')} /></p>
        </div>
        
        <!-- DeepLoc attention plots -->
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-2 text-center"><Fragment set:html={t('t3')} /></p>
            <div class="bg-white rounded-lg overflow-hidden">
              <img src="/images/deeploc-igk-mini-strc.png" alt="DeepLoc 2.1 sorting signal attention map for IgK-SP + mini-STRC showing N-terminal SP attention and C-terminal GPI signal" class="w-full" loading="lazy" />
            </div>
          </div>
          <div>
            <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-2 text-center"><Fragment set:html={t('t4')} /></p>
            <div class="bg-white rounded-lg overflow-hidden">
              <img src="/images/deeploc-full-strc.png" alt="DeepLoc 2.1 sorting signal attention map for full STRC showing native SP attention pattern" class="w-full" loading="lazy" />
            </div>
          </div>
        </div>
        <p class="text-[10px] text-neutral-500 mt-3 text-center"><Fragment set:html={t('t5')} /></p>
      </div>
    </div>