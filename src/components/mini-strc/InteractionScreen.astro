---
import { useComponentTranslations } from '../../lib/component-i18n';
import en from './i18n/InteractionScreen.en.json';
import zh from './i18n/InteractionScreen.zh.json';
const { lang = 'en' } = Astro.props;
const t = useComponentTranslations(lang, { en, zh });
---
<div class="mb-12">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-400 mb-4">{t('t24')}</h3>
      <p class="text-xs text-neutral-400 mb-4"><Fragment set:html={t('t1')} /></p>
      
      <div class="bg-white/[0.02] border border-white/5 rounded-lg overflow-hidden mb-4">
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-white/5 text-neutral-500">
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t21')} /></th>
                <th class="text-right p-3 font-medium">ipTM</th>
                <th class="text-right p-3 font-medium"><Fragment set:html={t('t22')} /></th>
                <th class="text-left p-3 font-medium"><Fragment set:html={t('t23')} /></th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t3')} /></td>
                <td class="p-3 text-right font-mono">0.47</td>
                <td class="p-3 text-right font-mono">8.6 A</td>
                <td class="p-3"><Fragment set:html={t('t4')} /></td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t5')} /></td>
                <td class="p-3 text-right font-mono">0.43</td>
                <td class="p-3 text-right font-mono">—</td>
                <td class="p-3"><Fragment set:html={t('t6')} /></td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t7')} /></td>
                <td class="p-3 text-right font-mono text-neutral-500">0.30</td>
                <td class="p-3 text-right font-mono text-neutral-500">14-17 A</td>
                <td class="p-3"><Fragment set:html={t('t8')} /></td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t9')} /></td>
                <td class="p-3 text-right font-mono text-neutral-500">0.29</td>
                <td class="p-3 text-right font-mono text-neutral-500">17-21 A</td>
                <td class="p-3"><Fragment set:html={t('t10')} /></td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t11')} /></td>
                <td class="p-3 text-right font-mono text-neutral-500">0.24</td>
                <td class="p-3 text-right font-mono text-neutral-500">16-17 A</td>
                <td class="p-3"><Fragment set:html={t('t12')} /></td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t13')} /></td>
                <td class="p-3 text-right font-mono text-neutral-500">0.20</td>
                <td class="p-3 text-right font-mono text-neutral-500">19-21 A</td>
                <td class="p-3"><Fragment set:html={t('t14')} /></td>
              </tr>
              <tr class="border-b border-white/5 text-neutral-400">
                <td class="p-3"><Fragment set:html={t('t15')} /></td>
                <td class="p-3 text-right font-mono text-neutral-500">0.20</td>
                <td class="p-3 text-right font-mono text-neutral-500">20-30 A</td>
                <td class="p-3"><Fragment set:html={t('t16')} /></td>
              </tr>
              <tr class="border-b border-white/5 bg-amber-500/[0.03]">
                <td class="p-3 text-amber-400 font-medium"><Fragment set:html={t('t17')} /></td>
                <td class="p-3 text-right font-mono text-amber-400">0.24</td>
                <td class="p-3 text-right font-mono text-amber-400">26-29 A</td>
                <td class="p-3"><Fragment set:html={t('t18')} /></td>
              </tr>
              <tr class="bg-cyan-500/[0.03]">
                <td class="p-3 text-cyan-400 font-medium"><Fragment set:html={t('t19')} /></td>
                <td class="p-3 text-right font-mono text-cyan-400 font-bold">0.73</td>
                <td class="p-3 text-right font-mono text-cyan-400">0.9-2.1 A</td>
                <td class="p-3"><Fragment set:html={t('t20')} /></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      
      <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4">
        <p class="text-xs text-neutral-300 leading-relaxed"><Fragment set:html={t('t2')} /></p>
      </div>
    </div>