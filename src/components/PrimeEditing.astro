---
// Prime Editing Feasibility section
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('primeediting.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-purple-500/20 text-purple-400 font-semibold">{t('primeediting.badge')}</span>
    </div>
    <p class="text-neutral-400 text-sm mb-6">
      {t('primeediting.desc')}
    </p>

    <!-- Visual explanation of the three editors -->
    <div class="space-y-3 mb-6">
      <!-- What we need -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4">
        <div class="text-xs font-semibold text-neutral-300 mb-2">{t('primeediting.mutation.title')}</div>
        <div class="flex items-center gap-2 text-xs font-mono">
          <span class="text-neutral-500">{t('primeediting.mutation.healthy_label')}</span>
          <span class="text-neutral-400" set:html={t('primeediting.mutation.healthy_seq')} />
        </div>
        <div class="flex items-center gap-2 text-xs font-mono">
          <span class="text-neutral-500">{t('primeediting.mutation.michael_label')}</span>
          <span class="text-neutral-400" set:html={t('primeediting.mutation.michael_seq')} />
        </div>
        <div class="text-[10px] text-neutral-500 mt-2">{t('primeediting.mutation.note')}</div>
      </div>

      <!-- Three tools comparison -->
      <div class="grid md:grid-cols-3 gap-3">
        <div class="bg-white/[0.02] border border-red-500/10 rounded-lg p-4">
          <div class="text-xs font-semibold text-red-400 mb-1">{t('primeediting.cbe.title')}</div>
          <div class="text-[10px] text-neutral-500 mb-2">{t('primeediting.cbe.what')}</div>
          <div class="flex items-center gap-2 font-mono text-xs mb-2">
            <span class="text-neutral-400">C</span>
            <span class="text-neutral-500">→</span>
            <span class="text-neutral-300">T</span>
            <span class="text-[10px] text-neutral-500 ml-1">{t('primeediting.cbe.arrow')}</span>
          </div>
          <div class="text-[10px] text-neutral-400 mb-2">{t('primeediting.cbe.note')}</div>
          <div class="text-xs text-red-400 font-semibold">{t('primeediting.cbe.verdict')}</div>
        </div>

        <div class="bg-white/[0.02] border border-red-500/10 rounded-lg p-4">
          <div class="text-xs font-semibold text-red-400 mb-1">{t('primeediting.abe.title')}</div>
          <div class="text-[10px] text-neutral-500 mb-2">{t('primeediting.abe.what')}</div>
          <div class="flex items-center gap-2 font-mono text-xs mb-2">
            <span class="text-neutral-400">A</span>
            <span class="text-neutral-500">→</span>
            <span class="text-neutral-300">G</span>
            <span class="text-[10px] text-neutral-500 ml-1">{t('primeediting.abe.arrow')}</span>
          </div>
          <div class="text-[10px] text-neutral-400 mb-2">{t('primeediting.abe.note')}</div>
          <div class="text-xs text-red-400 font-semibold">{t('primeediting.abe.verdict')}</div>
        </div>

        <div class="bg-white/[0.02] border border-green-500/10 rounded-lg p-4">
          <div class="text-xs font-semibold text-green-400 mb-1">{t('primeediting.pe.title')}</div>
          <div class="text-[10px] text-neutral-500 mb-2">{t('primeediting.pe.what')}</div>
          <div class="flex items-center gap-2 font-mono text-xs mb-2">
            <span class="text-neutral-400">any</span>
            <span class="text-neutral-500">→</span>
            <span class="text-neutral-300">any</span>
            <span class="text-[10px] text-neutral-500 ml-1">{t('primeediting.pe.arrow')}</span>
          </div>
          <div class="text-[10px] text-neutral-400 mb-2">{t('primeediting.pe.note')}</div>
          <div class="text-xs text-green-400 font-semibold">{t('primeediting.pe.verdict')}</div>
        </div>
      </div>
    </div>

    <!-- PAM site analysis -->
    <div class="bg-white/[0.02] border border-green-500/10 rounded-lg p-4 mb-4">
      <div class="text-xs font-semibold text-green-400 mb-2">{t('primeediting.pam.title')}</div>
      <p class="text-xs text-neutral-400 mb-3" set:html={t('primeediting.pam.desc')} />
      <div class="bg-black/40 rounded p-3 overflow-x-auto">
        <div class="text-[11px] font-mono text-neutral-500 leading-relaxed whitespace-nowrap">
          <span class="text-neutral-600">chr15:43600521-43600581 (GRCh38)</span><br/>
          CCCAGCTCCCCACCTGCTATGGTGCC<span class="text-yellow-400 font-bold underline">CC</span>AATTT<span class="text-red-400 font-bold">[C]</span>AGTGAAGATCTCAGG<br/>
          <span class="text-neutral-700">..........................PAM↑....↑variant</span><br/>
          <span class="text-neutral-700">..........................4bp apart</span>
        </div>
      </div>
      <div class="text-[10px] text-neutral-500 mt-2" set:html={t('primeediting.pam.howfound')} />
    </div>

    <!-- Base editing precedent in cochlea -->
    <div class="bg-white/[0.02] border border-green-500/10 rounded-lg p-5 mb-6">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-green-400/60 mb-2">{t('primeediting.precedent.title')}</h3>
      <p class="text-xs text-neutral-400 leading-relaxed mb-3">{t('primeediting.precedent.desc')}</p>
      <div class="space-y-2 text-xs text-neutral-400">
        <p set:html={t('primeediting.precedent.otof')} />
        <p set:html={t('primeediting.precedent.mpzl2')} />
      </div>
      <div class="mt-3 bg-green-500/5 border border-green-500/10 rounded-lg p-3">
        <p class="text-[10px] text-neutral-400" set:html={t('primeediting.precedent.note')} />
      </div>
    </div>

    <div class="bg-yellow-500/10 border border-yellow-500/20 rounded-lg p-4">
      <p class="text-xs text-neutral-300" set:html={t('primeediting.caveat')} />
    </div>
  </div>
</section>
