---
// Day 3: Delivery Hypothesis - Sonoporation + LNP
import { useTranslations } from '../lib/i18n';
import Problem from './delivery/Problem.astro';
import SonoporationSteps from './delivery/SonoporationSteps.astro';
import ModelResults from './delivery/ModelResults.astro';
import SensitivityAnalysis from './delivery/SensitivityAnalysis.astro';
import NonviralDelivery from './delivery/NonviralDelivery.astro';
import References from './delivery/References.astro';

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="delivery" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('dlv.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">DAY 3</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-amber-500/20 text-amber-400 font-semibold">{t('dlv.badge')}</span>
    </div>

    <Problem lang={lang} />
    <SonoporationSteps lang={lang} />
    <ModelResults lang={lang} />
    <SensitivityAnalysis lang={lang} />
    <NonviralDelivery lang={lang} />
    <References lang={lang} />
  </div>
</section>
