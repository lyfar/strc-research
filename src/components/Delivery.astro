---
// Day 3: Delivery Hypothesis - Sonoporation + LNP
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="delivery" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('dlv.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">DAY 3</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-amber-500/20 text-amber-400 font-semibold">{t('dlv.badge')}</span>
    </div>

    <!-- Story -->
    <div class="space-y-4 text-sm text-neutral-300 leading-relaxed mb-10">
      <p set:html={t('dlv.story.p1')} />
      <p set:html={t('dlv.story.p2')} />
      <p set:html={t('dlv.story.p3')} />
    </div>

    <!-- The Problem -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-4">{t('dlv.problem.title')}</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Current: Surgery -->
        <div class="border border-red-500/20 bg-red-950/10 rounded-lg p-4">
          <div class="text-[10px] text-red-400 font-semibold uppercase tracking-wider mb-2">{t('dlv.problem.current')}</div>
          <div class="space-y-1.5 text-xs text-neutral-400">
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span set:html={t('dlv.problem.c1')} /></div>
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span set:html={t('dlv.problem.c2')} /></div>
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span set:html={t('dlv.problem.c3')} /></div>
            <div class="flex items-start gap-2"><span class="text-red-500/60 shrink-0">✗</span><span set:html={t('dlv.problem.c4')} /></div>
          </div>
        </div>
        <!-- Proposed: Non-invasive -->
        <div class="border border-green-500/20 bg-green-950/10 rounded-lg p-4">
          <div class="text-[10px] text-green-400 font-semibold uppercase tracking-wider mb-2">{t('dlv.problem.proposed')}</div>
          <div class="space-y-1.5 text-xs text-neutral-400">
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span set:html={t('dlv.problem.p1')} /></div>
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span set:html={t('dlv.problem.p2')} /></div>
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span set:html={t('dlv.problem.p3')} /></div>
            <div class="flex items-start gap-2"><span class="text-green-500/60 shrink-0">✓</span><span set:html={t('dlv.problem.p4')} /></div>
          </div>
        </div>
      </div>
    </div>

    <!-- How Sonoporation Works -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-5">{t('dlv.how.title')}</h3>
      
      <div class="sono-steps">
        <div class="sono-step">
          <div class="sono-step-num bg-cyan-500/20 text-cyan-400">1</div>
          <div class="sono-step-content">
            <div class="text-xs font-semibold text-cyan-400 mb-1">{t('dlv.how.s1.title')}</div>
            <div class="text-xs text-neutral-400" set:html={t('dlv.how.s1.desc')} />
          </div>
        </div>
        <div class="sono-step-arrow">↓</div>
        <div class="sono-step">
          <div class="sono-step-num bg-purple-500/20 text-purple-400">2</div>
          <div class="sono-step-content">
            <div class="text-xs font-semibold text-purple-400 mb-1">{t('dlv.how.s2.title')}</div>
            <div class="text-xs text-neutral-400" set:html={t('dlv.how.s2.desc')} />
          </div>
        </div>
        <div class="sono-step-arrow">↓</div>
        <div class="sono-step">
          <div class="sono-step-num bg-green-500/20 text-green-400">3</div>
          <div class="sono-step-content">
            <div class="text-xs font-semibold text-green-400 mb-1">{t('dlv.how.s3.title')}</div>
            <div class="text-xs text-neutral-400" set:html={t('dlv.how.s3.desc')} />
          </div>
        </div>
        <div class="sono-step-arrow">↓</div>
        <div class="sono-step">
          <div class="sono-step-num bg-amber-500/20 text-amber-400">4</div>
          <div class="sono-step-content">
            <div class="text-xs font-semibold text-amber-400 mb-1">{t('dlv.how.s4.title')}</div>
            <div class="text-xs text-neutral-400" set:html={t('dlv.how.s4.desc')} />
          </div>
        </div>
      </div>
    </div>

    <!-- ODE MODEL RESULTS: The Honest Part -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-4">{t('dlv.model.title')}</h3>
      <p class="text-xs text-neutral-400 mb-5" set:html={t('dlv.model.desc')} />

      <!-- Scenario 1: Baseline (FAILED) -->
      <div class="border border-red-500/20 bg-red-950/10 rounded-lg p-4 mb-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[10px] font-semibold text-red-400 uppercase tracking-wider">{t('dlv.model.baseline.label')}</span>
          <span class="px-1.5 py-0.5 text-[9px] rounded bg-red-500/20 text-red-400 font-semibold">{t('dlv.model.baseline.badge')}</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-3">
          <div>
            <div class="text-[9px] text-neutral-600 uppercase">{t('dlv.model.col.conc')}</div>
            <div class="text-xs text-neutral-300 font-mono">10¹²/mL</div>
          </div>
          <div>
            <div class="text-[9px] text-neutral-600 uppercase">{t('dlv.model.col.escape')}</div>
            <div class="text-xs text-neutral-300 font-mono">2%</div>
          </div>
          <div>
            <div class="text-[9px] text-neutral-600 uppercase">{t('dlv.model.col.exposure')}</div>
            <div class="text-xs text-neutral-300 font-mono">10 min</div>
          </div>
          <div>
            <div class="text-[9px] text-neutral-600 uppercase">{t('dlv.model.col.result')}</div>
            <div class="text-xs text-red-400 font-mono font-bold">0.39%</div>
          </div>
        </div>
        <p class="text-[11px] text-neutral-500" set:html={t('dlv.model.baseline.note')} />
      </div>

      <!-- Scenario 2: Optimized (VIABLE) -->
      <div class="border border-green-500/20 bg-green-950/10 rounded-lg p-4 mb-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[10px] font-semibold text-green-400 uppercase tracking-wider">{t('dlv.model.optimized.label')}</span>
          <span class="px-1.5 py-0.5 text-[9px] rounded bg-green-500/20 text-green-400 font-semibold">{t('dlv.model.optimized.badge')}</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-3">
          <div>
            <div class="text-[9px] text-neutral-600 uppercase">{t('dlv.model.col.conc')}</div>
            <div class="text-xs text-green-300 font-mono">10¹³/mL</div>
          </div>
          <div>
            <div class="text-[9px] text-neutral-600 uppercase">{t('dlv.model.col.escape')}</div>
            <div class="text-xs text-green-300 font-mono">15%</div>
          </div>
          <div>
            <div class="text-[9px] text-neutral-600 uppercase">{t('dlv.model.col.exposure')}</div>
            <div class="text-xs text-green-300 font-mono">20 min</div>
          </div>
          <div>
            <div class="text-[9px] text-neutral-600 uppercase">{t('dlv.model.col.result')}</div>
            <div class="text-xs text-green-400 font-mono font-bold">78%</div>
          </div>
        </div>
        <p class="text-[11px] text-neutral-500" set:html={t('dlv.model.optimized.note')} />
      </div>

      <!-- Scenario 3: Hybrid (REALISTIC) -->
      <div class="border border-cyan-500/20 bg-cyan-950/10 rounded-lg p-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[10px] font-semibold text-cyan-400 uppercase tracking-wider">{t('dlv.model.hybrid.label')}</span>
          <span class="px-1.5 py-0.5 text-[9px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">{t('dlv.model.hybrid.badge')}</span>
        </div>
        <div class="space-y-2 text-xs text-neutral-400">
          <div class="flex items-start gap-2">
            <span class="text-cyan-500 font-mono text-[10px] shrink-0">Y0</span>
            <span set:html={t('dlv.model.hybrid.y0')} />
          </div>
          <div class="flex items-start gap-2">
            <span class="text-cyan-500 font-mono text-[10px] shrink-0">Y3+</span>
            <span set:html={t('dlv.model.hybrid.y3')} />
          </div>
          <div class="flex items-start gap-2">
            <span class="text-cyan-500 font-mono text-[10px] shrink-0">Y5+</span>
            <span set:html={t('dlv.model.hybrid.y5')} />
          </div>
        </div>
        <p class="text-[11px] text-neutral-500 mt-3" set:html={t('dlv.model.hybrid.note')} />
      </div>
    </div>

    <!-- Sensitivity Analysis -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-4">{t('dlv.sensitivity.title')}</h3>
      <p class="text-xs text-neutral-400 mb-4" set:html={t('dlv.sensitivity.desc')} />
      
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="text-left text-neutral-500 text-[10px] uppercase tracking-wider">
              <th class="pb-2 pr-3">{t('dlv.sensitivity.col.param')}</th>
              <th class="pb-2 pr-3">{t('dlv.sensitivity.col.range')}</th>
              <th class="pb-2 pr-3">{t('dlv.sensitivity.col.effect')}</th>
              <th class="pb-2">{t('dlv.sensitivity.col.verdict')}</th>
            </tr>
          </thead>
          <tbody class="text-neutral-400">
            <tr class="border-t border-white/5">
              <td class="py-2 pr-3 text-amber-400 font-mono">{t('dlv.sensitivity.r1.param')}</td>
              <td class="py-2 pr-3 font-mono">1% → 20%</td>
              <td class="py-2 pr-3 font-mono">0.19% → 3.89%</td>
              <td class="py-2"><span class="text-red-400 font-semibold">{t('dlv.sensitivity.r1.verdict')}</span></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="py-2 pr-3 text-amber-400 font-mono">{t('dlv.sensitivity.r2.param')}</td>
              <td class="py-2 pr-3 font-mono">10¹¹ → 10¹³</td>
              <td class="py-2 pr-3 font-mono">0.04% → 3.89%</td>
              <td class="py-2"><span class="text-amber-400 font-semibold">{t('dlv.sensitivity.r2.verdict')}</span></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="py-2 pr-3 text-neutral-400 font-mono">{t('dlv.sensitivity.r3.param')}</td>
              <td class="py-2 pr-3 font-mono">5 → 30 min</td>
              <td class="py-2 pr-3 font-mono">0.26% → 1.06%</td>
              <td class="py-2"><span class="text-neutral-500">{t('dlv.sensitivity.r3.verdict')}</span></td>
            </tr>
            <tr class="border-t border-white/5">
              <td class="py-2 pr-3 text-neutral-400 font-mono">{t('dlv.sensitivity.r4.param')}</td>
              <td class="py-2 pr-3 font-mono">70 → 200 nm</td>
              <td class="py-2 pr-3 font-mono">~0.39%</td>
              <td class="py-2"><span class="text-neutral-500">{t('dlv.sensitivity.r4.verdict')}</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-[11px] text-neutral-500 mt-3 italic" set:html={t('dlv.sensitivity.note')} />
    </div>

    <!-- Literature -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-3">{t('dlv.lit.title')}</h3>
      <div class="space-y-2 text-xs text-neutral-400">
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[1]</span>
          <span set:html={t('dlv.lit.ref1')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[2]</span>
          <span set:html={t('dlv.lit.ref2')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[3]</span>
          <span set:html={t('dlv.lit.ref3')} />
        </div>
        <div class="flex items-start gap-2">
          <span class="text-neutral-600 shrink-0">[4]</span>
          <span set:html={t('dlv.lit.ref4')} />
        </div>
      </div>
    </div>

    <!-- Code link -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4 mb-6">
      <div class="flex items-center gap-3">
        <span class="text-lg">🧮</span>
        <div>
          <div class="text-xs font-semibold text-neutral-300">{t('dlv.code.title')}</div>
          <a href="https://github.com/lyfar/strc-research/blob/master/sonoporation_model.py" 
             target="_blank" rel="noopener" 
             class="text-xs text-blue-400 hover:underline">{t('dlv.code.link')}</a>
        </div>
      </div>
    </div>

    <!-- Caveat -->
    <p class="text-xs text-neutral-500 italic" set:html={t('dlv.caveat')} />
  </div>
</section>

<style>
  .sono-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sono-step {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .sono-step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .sono-step-content {
    flex: 1;
    min-width: 0;
  }
  .sono-step-arrow {
    color: #444;
    font-size: 14px;
    padding-left: 9px;
    line-height: 1;
    padding-top: 2px;
    padding-bottom: 2px;
  }
</style>
