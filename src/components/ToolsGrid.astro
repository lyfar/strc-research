---
// Tools grid + closing text
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="px-6 pb-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="mt-8 bg-white/[0.02] border border-white/5 rounded-lg p-5">
      <h3 class="text-sm font-semibold mb-2">{t('toolsgrid.title')}</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-xs">
        <a href="https://openclaw.ai" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.openclaw.name')}</div>
          <div>{t('toolsgrid.openclaw.desc')}</div>
        </a>
        <a href="https://www.anthropic.com" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.claude.name')}</div>
          <div>{t('toolsgrid.claude.desc')}</div>
        </a>
        <a href="https://alphafold.ebi.ac.uk" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.alphafold.name')}</div>
          <div>{t('toolsgrid.alphafold.desc')}</div>
        </a>
        <a href="https://deepmind.google/technologies/alphamissense/" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.alphamissense.name')}</div>
          <div>{t('toolsgrid.alphamissense.desc')}</div>
        </a>
        <a href="https://alphafoldserver.com" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.af3.name')}</div>
          <div>{t('toolsgrid.af3.desc')}</div>
        </a>
        <a href="https://www.uniprot.org" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.uniprot.name')}</div>
          <div>{t('toolsgrid.uniprot.desc')}</div>
        </a>
        <a href="https://rest.ensembl.org" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.ensembl.name')}</div>
          <div>{t('toolsgrid.ensembl.desc')}</div>
        </a>
        <a href="https://gnomad.broadinstitute.org" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.gnomad.name')}</div>
          <div>{t('toolsgrid.gnomad.desc')}</div>
        </a>
        <a href="https://clinicaltrials.gov" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.clinicaltrials.name')}</div>
          <div>{t('toolsgrid.clinicaltrials.desc')}</div>
        </a>
        <a href="https://pubmed.ncbi.nlm.nih.gov" target="_blank" rel="noopener" class="no-underline text-neutral-400 hover:text-white transition-colors">
          <div class="font-medium text-neutral-300">{t('toolsgrid.pubmed.name')}</div>
          <div>{t('toolsgrid.pubmed.desc')}</div>
        </a>
      </div>
      <p class="text-xs text-neutral-500 mt-4">{t('toolsgrid.footnote')}</p>
    </div>
  </div>
</section>
