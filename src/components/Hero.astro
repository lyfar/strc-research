---
// Hero: intro + photo + metrics + timeline + powered by
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="px-6 py-16 md:py-20 max-w-6xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <span class="px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded bg-green-500/20 text-green-400">{t('hero.badge1')}</span>
    <span class="px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded bg-blue-500/20 text-blue-400">{t('hero.badge2')}</span>
  </div>

  <div class="grid md:grid-cols-[1fr_320px] gap-10 items-start">
    <div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight leading-tight">
        STRC c.4976 <span class="text-green-400 line-through opacity-60">A</span><span class="text-red-400">C</span>
      </h1>
      <p class="text-sm text-neutral-400 mt-2">I asked AI what that means. Came up with a variant pathogenicity analysis and a new hypothesis.</p>
      <div class="mt-6 space-y-3 text-sm text-neutral-300 leading-relaxed">
        <p set:html={t('hero.p1')} />
        <p set:html={t('hero.p2')} />
        <p set:html={t('hero.p3')} />
        <p set:html={t('hero.p4')} />
      </div>

      <!-- Listen / Watch -->
      <div class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-3">
        <!-- Audio -->
        <div id="audio-card" class="flex items-center gap-3 bg-white/[0.03] border border-white/5 rounded-lg px-4 py-3 cursor-pointer hover:border-white/10 transition-colors">
          <div id="audio-icon" class="w-8 h-8 flex items-center justify-center bg-white/10 rounded-full shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-xs text-neutral-300">Listen to podcast</div>
            <div class="text-[10px] text-neutral-600">AI-generated · NotebookLM</div>
            <div class="h-1 bg-white/5 rounded-full mt-1.5" id="audio-bar">
              <div id="audio-progress" class="h-full bg-white/30 rounded-full" style="width:0%"></div>
            </div>
          </div>
          <span id="audio-time" class="text-[10px] text-neutral-600 font-mono shrink-0"></span>
        </div>
        <audio id="podcast-audio" preload="metadata" src="/media/podcast.mp3"></audio>

        <!-- Video -->
        <div class="flex items-center gap-3 bg-white/[0.03] border border-white/5 rounded-lg px-4 py-3 cursor-pointer hover:border-white/10 transition-colors" onclick="document.getElementById('video-lightbox').classList.remove('hidden');document.getElementById('lightbox-video').play()">
          <div class="w-8 h-8 flex items-center justify-center bg-white/10 rounded-full shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/></svg>
          </div>
          <div>
            <div class="text-xs text-neutral-300">Watch video overview</div>
            <div class="text-[10px] text-neutral-600">AI-generated · NotebookLM</div>
          </div>
        </div>
      </div>

      <!-- Audio script -->
      <script is:inline>
      document.addEventListener('DOMContentLoaded', function(){
        var card=document.getElementById('audio-card');
        var icon=document.getElementById('audio-icon');
        var a=document.getElementById('podcast-audio');
        var prog=document.getElementById('audio-progress');
        var time=document.getElementById('audio-time');
        var bar=document.getElementById('audio-bar');
        if(!card||!a) return;
        var playSvg='<svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>';
        var pauseSvg='<svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M5.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75A.75.75 0 007.25 3h-1.5zM12.75 3a.75.75 0 00-.75.75v12.5c0 .414.336.75.75.75h1.5a.75.75 0 00.75-.75V3.75a.75.75 0 00-.75-.75h-1.5z"/></svg>';
        card.addEventListener('click',function(){
          if(a.paused){a.play();icon.innerHTML=pauseSvg}
          else{a.pause();icon.innerHTML=playSvg}
        });
        bar.addEventListener('click',function(e){e.stopPropagation();if(a.duration){a.currentTime=(e.offsetX/bar.offsetWidth)*a.duration}});
        a.addEventListener('timeupdate',function(){if(a.duration){prog.style.width=(a.currentTime/a.duration*100)+'%';var m=Math.floor(a.currentTime/60),s=Math.floor(a.currentTime%60);var tm=Math.floor(a.duration/60),ts=Math.floor(a.duration%60);time.textContent=m+':'+(s<10?'0':'')+s+'/'+tm+':'+(ts<10?'0':'')+ts}});
        a.addEventListener('loadedmetadata',function(){var tm=Math.floor(a.duration/60),ts=Math.floor(a.duration%60);time.textContent='0:00/'+tm+':'+(ts<10?'0':'')+ts});
        a.addEventListener('ended',function(){icon.innerHTML=playSvg;prog.style.width='0%'});
      });
      </script>

      <!-- Video lightbox (full viewport) -->
      <div id="video-lightbox" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-sm" onclick="this.classList.add('hidden');document.getElementById('lightbox-video').pause()">
        <div class="relative w-full max-w-2xl max-h-[90vh] mx-4" onclick="event.stopPropagation()">
          <button onclick="document.getElementById('video-lightbox').classList.add('hidden');document.getElementById('lightbox-video').pause()" class="absolute -top-10 right-0 text-white/60 hover:text-white text-sm z-10">✕ Close</button>
          <video id="lightbox-video" controls preload="none" class="w-full max-h-[85vh] rounded-lg shadow-2xl object-contain" playsinline>
            <source src="/media/video.mp4" type="video/mp4" />
          </video>
        </div>
      </div>



      <!-- Powered by + cost (single line) -->
      <div class="mt-6 text-[11px] text-neutral-500 leading-relaxed">
        <span class="text-neutral-600">Built with</span>
        <a href="https://openclaw.ai" target="_blank" rel="noopener" class="text-neutral-400 hover:text-white no-underline">OpenClaw</a> (free, open source) +
        <a href="https://www.anthropic.com" target="_blank" rel="noopener" class="text-neutral-400 hover:text-white no-underline">Claude Opus 4.6</a> (API, ~$50-100) +
        <a href="https://alphafold.ebi.ac.uk" target="_blank" rel="noopener" class="text-neutral-400 hover:text-white no-underline">AlphaFold</a> +
        <a href="https://alphafoldserver.com" target="_blank" rel="noopener" class="text-neutral-400 hover:text-white no-underline">AlphaFold 3</a> +
        <a href="https://deepmind.google/technologies/alphamissense/" target="_blank" rel="noopener" class="text-neutral-400 hover:text-white no-underline">AlphaMissense</a> +
        <a href="https://www.uniprot.org" target="_blank" rel="noopener" class="text-neutral-400 hover:text-white no-underline">UniProt</a> +
        <a href="https://rest.ensembl.org" target="_blank" rel="noopener" class="text-neutral-400 hover:text-white no-underline">Ensembl</a>
        <span class="text-neutral-600">(all free)</span>
      </div>
    </div>
    <div class="order-first md:order-last">
      <img src="/images/egor-misha.jpg" alt={t('hero.photo.alt')} class="rounded-xl w-full md:sticky md:top-24 shadow-2xl shadow-black/50" loading="eager" />
      <p class="text-[10px] text-neutral-600 mt-2 text-center">{t('hero.photo.caption')}</p>
    </div>
  </div>

  <!-- Key metrics -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-10">
    <div class="bg-white/[0.03] border border-white/5 rounded-lg p-4">
      <div class="text-[10px] text-neutral-500 uppercase tracking-wider">{t('hero.metric1.label')}</div>
      <div class="text-2xl font-bold text-red-400 mt-1">{t('hero.metric1.value')}</div>
      <div class="text-xs text-neutral-500 mt-1">{t('hero.metric1.desc')}</div>
    </div>
    <div class="bg-white/[0.03] border border-white/5 rounded-lg p-4">
      <div class="text-[10px] text-neutral-500 uppercase tracking-wider">{t('hero.metric2.label')}</div>
      <div class="text-2xl font-bold text-green-400 mt-1">{t('hero.metric2.value')}</div>
      <div class="text-xs text-neutral-500 mt-1">{t('hero.metric2.desc')}</div>
    </div>
    <div class="bg-white/[0.03] border border-white/5 rounded-lg p-4">
      <div class="text-[10px] text-neutral-500 uppercase tracking-wider">{t('hero.metric3.label')}</div>
      <div class="text-2xl font-bold text-orange-400 mt-1">{t('hero.metric3.value')}</div>
      <div class="text-xs text-neutral-500 mt-1">{t('hero.metric3.desc')}</div>
    </div>
    <div class="bg-white/[0.03] border border-white/5 rounded-lg p-4">
      <div class="text-[10px] text-neutral-500 uppercase tracking-wider">{t('hero.metric4.label')}</div>
      <div class="text-2xl font-bold text-green-400 mt-1">{t('hero.metric4.value')}</div>
      <div class="text-xs text-neutral-500 mt-1">{t('hero.metric4.desc')}</div>
    </div>
  </div>


</section>
