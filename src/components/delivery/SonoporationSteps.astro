---
// Delivery: How Sonoporation Works - 4 steps
import { useTranslations } from '../../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-8">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-neutral-500 mb-5">{t('dlv.how.title')}</h3>

  <div class="sono-steps">
    <div class="sono-step">
      <div class="sono-step-num bg-cyan-500/20 text-cyan-400">1</div>
      <div class="sono-step-content">
        <div class="text-xs font-semibold text-cyan-400 mb-1">{t('dlv.how.s1.title')}</div>
        <div class="text-xs text-neutral-400" set:html={t('dlv.how.s1.desc')} />
      </div>
    </div>
    <div class="sono-step-arrow">&darr;</div>
    <div class="sono-step">
      <div class="sono-step-num bg-purple-500/20 text-purple-400">2</div>
      <div class="sono-step-content">
        <div class="text-xs font-semibold text-purple-400 mb-1">{t('dlv.how.s2.title')}</div>
        <div class="text-xs text-neutral-400" set:html={t('dlv.how.s2.desc')} />
      </div>
    </div>
    <div class="sono-step-arrow">&darr;</div>
    <div class="sono-step">
      <div class="sono-step-num bg-green-500/20 text-green-400">3</div>
      <div class="sono-step-content">
        <div class="text-xs font-semibold text-green-400 mb-1">{t('dlv.how.s3.title')}</div>
        <div class="text-xs text-neutral-400" set:html={t('dlv.how.s3.desc')} />
      </div>
    </div>
    <div class="sono-step-arrow">&darr;</div>
    <div class="sono-step">
      <div class="sono-step-num bg-amber-500/20 text-amber-400">4</div>
      <div class="sono-step-content">
        <div class="text-xs font-semibold text-amber-400 mb-1">{t('dlv.how.s4.title')}</div>
        <div class="text-xs text-neutral-400" set:html={t('dlv.how.s4.desc')} />
      </div>
    </div>
  </div>
</div>

<style>
  .sono-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sono-step {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .sono-step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .sono-step-content {
    flex: 1;
    min-width: 0;
  }
  .sono-step-arrow {
    color: #444;
    font-size: 14px;
    padding-left: 9px;
    line-height: 1;
    padding-top: 2px;
    padding-bottom: 2px;
  }
</style>
