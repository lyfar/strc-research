---
import { render } from 'astro:content';

interface Props {
  paper: any;
}

const { paper } = Astro.props;
const { Content } = await render(paper);
const { title, authors, journal, date, pubmed_id, biorxiv_id, doi, relevance_type, relevance_score, tags, date_added } = paper.data;

const score = parseInt(relevance_score);
const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);
const isNew = date_added ? date_added >= sevenDaysAgo : false;
const aheadOfPrint = date.getTime() > Date.now();
const scoreColor = score >= 8 ? 'text-green-400 bg-green-500/10 border-green-500/20'
  : score >= 6 ? 'text-amber-400 bg-amber-500/10 border-amber-500/20'
  : 'text-neutral-400 bg-white/5 border-white/10';

const typeLabel: Record<string, string> = {
  fda_path: 'FDA Path',
  applicable: 'Applicable',
  background: 'Background',
  direct: 'Direct',
  lateral: 'Lateral',
};

const dateStr = date.toISOString().split('T')[0];
const firstAuthor = authors[0]?.split(',')[0] ?? '';
---

<article class="border border-white/5 rounded-lg overflow-hidden bg-white/[0.015] hover:border-white/10 transition-colors">
  <div class="px-5 pt-5 pb-4">
    <!-- Meta row -->
    <div class="flex items-start justify-between gap-3 mb-3">
      <div class="flex items-center gap-2 flex-wrap">
        <span class={`text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded border ${scoreColor}`}>
          {relevance_score}
        </span>
        <span class="text-[10px] px-1.5 py-0.5 rounded bg-blue-500/10 text-blue-400 border border-blue-500/20">
          {typeLabel[relevance_type] ?? relevance_type}
        </span>
        {isNew && (
          <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">New</span>
        )}
        {aheadOfPrint && (
          <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-400 border border-amber-500/20" title="Publication date is in the future — this is an online-first / ahead-of-print paper">Ahead of print</span>
        )}
      </div>
      <time class="text-[11px] text-neutral-500 font-mono shrink-0">{dateStr}</time>
    </div>

    <!-- Title -->
    <h2 class="text-sm font-semibold text-white leading-snug mb-1">{title}</h2>
    <p class="text-xs text-neutral-500 mb-3">{firstAuthor} et al. · <em>{journal}</em></p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1 mb-4">
      {tags.map(tag => (
        <span class="text-[10px] px-1.5 py-0.5 rounded bg-white/5 text-neutral-500">{tag}</span>
      ))}
    </div>

    <!-- Content -->
    <div class="paper-body text-xs text-neutral-400 leading-relaxed">
      <Content />
    </div>

    <!-- Links -->
    <div class="mt-4 pt-4 border-t border-white/5 flex gap-4">
      {pubmed_id && (
        <a href={`https://pubmed.ncbi.nlm.nih.gov/${pubmed_id}/`} target="_blank" rel="noopener"
          class="text-[11px] text-neutral-500 hover:text-white transition-colors no-underline font-mono">
          PubMed ↗
        </a>
      )}
      {biorxiv_id && (
        <a href={`https://biorxiv.org/content/${biorxiv_id}`} target="_blank" rel="noopener"
          class="text-[11px] text-neutral-500 hover:text-white transition-colors no-underline font-mono">
          bioRxiv ↗
        </a>
      )}
      <a href={`https://doi.org/${doi}`} target="_blank" rel="noopener"
        class="text-[11px] text-neutral-500 hover:text-white transition-colors no-underline font-mono">
        DOI ↗
      </a>
    </div>
  </div>
</article>

<style is:global>
  .paper-body h2 {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #737373;
    margin-top: 1rem;
    margin-bottom: 0.4rem;
  }
  .paper-body h2:first-child { margin-top: 0; }
  .paper-body p { margin-bottom: 0.5rem; }
  .paper-body ul { list-style: none; padding: 0; margin-bottom: 0.5rem; }
  .paper-body li { padding-left: 0.75rem; position: relative; margin-bottom: 0.2rem; }
  .paper-body li::before { content: '—'; position: absolute; left: 0; color: #525252; }
  .paper-body a { display: none; } /* Links section hidden — shown via buttons below */
</style>
