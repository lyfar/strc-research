---
// Beyond reclassification: Research methodology steps
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="px-6 pb-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="mt-12 mb-6">
      <span class="text-[10px] uppercase tracking-widest text-neutral-500 font-semibold">{t('methodresearch.beyond_label')}</span>
      <h3 class="text-base font-bold mt-1">{t('methodresearch.beyond_title')}</h3>
      <p class="text-xs text-neutral-400 mt-2 max-w-2xl leading-relaxed">{t('methodresearch.beyond_desc')}</p>
    </div>

    <div class="space-y-6 mb-8">
      <!-- Step 8 (10 in sequence) -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-purple-500/20 flex items-center justify-center text-xs font-bold text-purple-400 shrink-0">10</span>
          <h3 class="text-sm font-semibold">{t('methodresearch.step8.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('methodresearch.step8.body1')} />
        <p class="text-xs text-neutral-300 leading-relaxed" set:html={t('methodresearch.step8.body2')} />
      </div>

      <!-- Step 9 (11 in sequence) -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-purple-500/20 flex items-center justify-center text-xs font-bold text-purple-400 shrink-0">11</span>
          <h3 class="text-sm font-semibold">{t('methodresearch.step9.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3">{t('methodresearch.step9.body1')}</p>
        <p class="text-xs text-neutral-300 leading-relaxed" set:html={t('methodresearch.step9.body2')} />
      </div>

      <!-- Step 10 (12 in sequence) -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-purple-500/20 flex items-center justify-center text-xs font-bold text-purple-400 shrink-0">12</span>
          <h3 class="text-sm font-semibold">{t('methodresearch.step10.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('methodresearch.step10.body1')} />
        <p class="text-xs text-neutral-300 leading-relaxed mb-3" set:html={t('methodresearch.step10.body2')} />
        <p class="text-xs text-neutral-400 leading-relaxed mb-3">{t('methodresearch.step10.body3')}</p>
        <div class="overflow-x-auto">
          <table class="text-[11px] w-full min-w-[500px]">
            <tr class="border-b border-white/10">
              <th class="text-left py-1.5 pr-2 text-neutral-500">{t('methodresearch.step10.col_num')}</th>
              <th class="text-left py-1.5 pr-2 text-neutral-500">{t('methodresearch.step10.col_exp')}</th>
              <th class="text-left py-1.5 pr-2 text-neutral-500">{t('methodresearch.step10.col_status')}</th>
              <th class="text-left py-1.5 text-neutral-500">{t('methodresearch.step10.col_tests')}</th>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-1.5 pr-2 text-neutral-500">1</td>
              <td class="py-1.5 pr-2">{t('methodresearch.step10.job1_name')}</td>
              <td class="py-1.5 pr-2 text-green-400">{t('methodresearch.step10.job1_status')}</td>
              <td class="py-1.5 text-neutral-400">{t('methodresearch.step10.job1_tests')}</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-1.5 pr-2 text-neutral-500">2</td>
              <td class="py-1.5 pr-2">{t('methodresearch.step10.job2_name')}</td>
              <td class="py-1.5 pr-2 text-green-400">{t('methodresearch.step10.job2_status')}</td>
              <td class="py-1.5 text-neutral-400">{t('methodresearch.step10.job2_tests')}</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-1.5 pr-2 text-neutral-500">3</td>
              <td class="py-1.5 pr-2">{t('methodresearch.step10.job3_name')}</td>
              <td class="py-1.5 pr-2 text-green-400">{t('methodresearch.step10.job3_status')}</td>
              <td class="py-1.5 text-neutral-400">{t('methodresearch.step10.job3_tests')}</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-1.5 pr-2 text-neutral-500">4</td>
              <td class="py-1.5 pr-2">{t('methodresearch.step10.job4_name')}</td>
              <td class="py-1.5 pr-2 text-green-400">{t('methodresearch.step10.job4_status')}</td>
              <td class="py-1.5 text-neutral-400">{t('methodresearch.step10.job4_tests')}</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-1.5 pr-2 text-neutral-500">5</td>
              <td class="py-1.5 pr-2">{t('methodresearch.step10.job5_name')}</td>
              <td class="py-1.5 pr-2 text-green-400">{t('methodresearch.step10.job5_status')}</td>
              <td class="py-1.5 text-neutral-400">{t('methodresearch.step10.job5_tests')}</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-1.5 pr-2 text-neutral-500">6</td>
              <td class="py-1.5 pr-2">{t('methodresearch.step10.job6_name')}</td>
              <td class="py-1.5 pr-2 text-green-400">{t('methodresearch.step10.job6_status')}</td>
              <td class="py-1.5 text-neutral-400">{t('methodresearch.step10.job6_tests')}</td>
            </tr>
            <tr class="border-b border-cyan-500/10 bg-cyan-500/[0.02]">
              <td class="py-1.5 pr-2 text-cyan-500">7</td>
              <td class="py-1.5 pr-2 text-cyan-300">{t('methodresearch.step10.job7_name')}</td>
              <td class="py-1.5 pr-2 text-yellow-400">{t('methodresearch.step10.job7_status')}</td>
              <td class="py-1.5 text-neutral-400">{t('methodresearch.step10.job7_tests')}</td>
            </tr>
            <tr class="bg-cyan-500/[0.02]">
              <td class="py-1.5 pr-2 text-cyan-500">8</td>
              <td class="py-1.5 pr-2 text-cyan-300">{t('methodresearch.step10.job8_name')}</td>
              <td class="py-1.5 pr-2 text-yellow-400">{t('methodresearch.step10.job8_status')}</td>
              <td class="py-1.5 text-neutral-400">{t('methodresearch.step10.job8_tests')}</td>
            </tr>
          </table>
        </div>
        <div class="mt-3 text-xs text-neutral-500 bg-black/30 p-3 rounded">
          <a href="https://alphafoldserver.com/fold/739cbeb76239c7c8" target="_blank" rel="noopener" class="text-blue-400">Job 1</a> · 
          <a href="https://alphafoldserver.com/fold/1bdcb17b9bcb4a6c" target="_blank" rel="noopener" class="text-blue-400">Job 3</a> · 
          <a href="https://alphafoldserver.com/fold/1f78a8dd5afe06b2" target="_blank" rel="noopener" class="text-blue-400">Job 2</a> · 
          <a href="https://alphafoldserver.com/fold/1578cf5e5548ebb7" target="_blank" rel="noopener" class="text-blue-400">Job 4</a> · 
          <a href="https://alphafoldserver.com/fold/2c71cca0a405ee3c" target="_blank" rel="noopener" class="text-blue-400">Job 5</a> · 
          <a href="https://alphafoldserver.com/fold/162f48c90aeb8a24" target="_blank" rel="noopener" class="text-blue-400">Job 6</a>
        </div>
      </div>

      <!-- Step 11 (13 in sequence) -->
      <div class="bg-white/[0.02] border border-blue-500/10 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-blue-500/20 flex items-center justify-center text-xs font-bold text-blue-400 shrink-0">13</span>
          <h3 class="text-sm font-semibold">{t('methodresearch.step11.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-2">{t('methodresearch.step11.body1')}</p>
        <p class="text-xs text-neutral-300 leading-relaxed">{t('methodresearch.step11.body2')}</p>
      </div>
    </div>

    <!-- DAY 3 -->
    <div class="mt-12 mb-6">
      <span class="text-[10px] uppercase tracking-widest text-cyan-500 font-semibold">{t('methodresearch.day3_label')}</span>
      <h3 class="text-base font-bold mt-1">{t('methodresearch.day3_title')}</h3>
      <p class="text-xs text-neutral-400 mt-2 max-w-2xl leading-relaxed">{t('methodresearch.day3_desc')}</p>
    </div>

    <div class="space-y-6 mb-8">
      <!-- Step 12 (14 in sequence): Sonogenetic hypothesis -->
      <div class="bg-white/[0.02] border border-cyan-500/10 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-cyan-500/20 flex items-center justify-center text-xs font-bold text-cyan-400 shrink-0">14</span>
          <h3 class="text-sm font-semibold">{t('methodresearch.step12.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('methodresearch.step12.body1')} />
        <p class="text-xs text-neutral-300 leading-relaxed" set:html={t('methodresearch.step12.body2')} />
      </div>

      <!-- Step 13 (15 in sequence): ODE model -->
      <div class="bg-white/[0.02] border border-cyan-500/10 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-cyan-500/20 flex items-center justify-center text-xs font-bold text-cyan-400 shrink-0">15</span>
          <h3 class="text-sm font-semibold">{t('methodresearch.step13.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('methodresearch.step13.body1')} />
        <p class="text-xs text-neutral-300 leading-relaxed" set:html={t('methodresearch.step13.body2')} />
      </div>

      <!-- Step 14 (16 in sequence): New AF3 jobs -->
      <div class="bg-white/[0.02] border border-cyan-500/10 rounded-lg p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-7 h-7 rounded-full bg-cyan-500/20 flex items-center justify-center text-xs font-bold text-cyan-400 shrink-0">16</span>
          <h3 class="text-sm font-semibold">{t('methodresearch.step14.title')}</h3>
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed mb-3" set:html={t('methodresearch.step14.body1')} />
        <p class="text-xs text-neutral-300 leading-relaxed" set:html={t('methodresearch.step14.body2')} />
      </div>
    </div>
  </div>
</section>
