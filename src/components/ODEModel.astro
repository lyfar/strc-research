---
// ODE Model Results — Computational proof of concept for mechanosensitive STRC expression
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="ode-model" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('ode.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">DAY 3</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-green-500/20 text-green-400 font-semibold">{t('ode.badge')}</span>
    </div>
    <p class="text-neutral-400 text-sm mb-8 max-w-3xl">{t('ode.desc')}</p>

    <!-- Results grid: 4 scenarios -->
    <div class="grid md:grid-cols-2 gap-4 mb-6">
      <!-- Hearing Aid Cycle -->
      <div class="bg-white/[0.02] border border-green-500/20 rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-green-400">{t('ode.scenario2.title')}</span>
          <span class="px-1.5 py-0.5 text-[10px] rounded bg-green-500/20 text-green-400 font-semibold">{t('ode.scenario2.badge')}</span>
        </div>
        <div class="space-y-2">
          <div>
            <div class="flex justify-between text-[11px] mb-1">
              <span class="text-neutral-400">{t('ode.label.protein')}</span>
              <span class="text-green-400 font-mono font-bold">29,571</span>
            </div>
            <div class="h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-green-500/60 rounded-full" style="width:100%"></div>
            </div>
          </div>
          <div class="flex justify-between text-[10px] text-neutral-500">
            <span>{t('ode.label.target')}: 15,000</span>
            <span class="text-green-400">197%</span>
          </div>
          <div class="text-[10px] text-neutral-500 space-y-0.5">
            <div>Peak Ca²⁺: <span class="text-white font-mono">689 nM</span></div>
            <div>Peak NFAT(nuclear): <span class="text-white font-mono">37.3%</span></div>
            <div>{t('ode.label.t10')}: <span class="text-white font-mono">7.5h</span></div>
            <div>{t('ode.label.t50')}: <span class="text-white font-mono">13.0h</span></div>
          </div>
        </div>
      </div>

      <!-- Therapy Sessions -->
      <div class="bg-white/[0.02] border border-cyan-500/20 rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-cyan-400">{t('ode.scenario3.title')}</span>
          <span class="px-1.5 py-0.5 text-[10px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">85 dB</span>
        </div>
        <div class="space-y-2">
          <div>
            <div class="flex justify-between text-[11px] mb-1">
              <span class="text-neutral-400">{t('ode.label.protein')}</span>
              <span class="text-cyan-400 font-mono font-bold">29,571</span>
            </div>
            <div class="h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-cyan-500/60 rounded-full" style="width:100%"></div>
            </div>
          </div>
          <div class="flex justify-between text-[10px] text-neutral-500">
            <span>{t('ode.label.target')}: 15,000</span>
            <span class="text-cyan-400">197%</span>
          </div>
          <div class="text-[10px] text-neutral-500 space-y-0.5">
            <div>Peak Ca²⁺: <span class="text-white font-mono">886 nM</span></div>
            <div>Peak NFAT(nuclear): <span class="text-white font-mono">40.0%</span></div>
          </div>
        </div>
      </div>

      <!-- Constant 70 dB -->
      <div class="bg-white/[0.02] border border-white/5 rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-neutral-300">{t('ode.scenario1.title')}</span>
          <span class="px-1.5 py-0.5 text-[10px] rounded bg-white/10 text-neutral-400 font-semibold">70 dB</span>
        </div>
        <div class="space-y-2">
          <div>
            <div class="flex justify-between text-[11px] mb-1">
              <span class="text-neutral-400">{t('ode.label.protein')}</span>
              <span class="text-white font-mono font-bold">29,733</span>
            </div>
            <div class="h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-white/30 rounded-full" style="width:100%"></div>
            </div>
          </div>
          <div class="flex justify-between text-[10px] text-neutral-500">
            <span>{t('ode.label.target')}: 15,000</span>
            <span class="text-white">198%</span>
          </div>
        </div>
      </div>

      <!-- Silence (control) -->
      <div class="bg-white/[0.02] border border-red-500/10 rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold text-red-400">{t('ode.scenario4.title')}</span>
          <span class="px-1.5 py-0.5 text-[10px] rounded bg-red-500/20 text-red-400 font-semibold">{t('ode.scenario4.badge')}</span>
        </div>
        <div class="space-y-2">
          <div>
            <div class="flex justify-between text-[11px] mb-1">
              <span class="text-neutral-400">{t('ode.label.protein')}</span>
              <span class="text-red-400 font-mono font-bold">1,023</span>
            </div>
            <div class="h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-red-500/40 rounded-full" style="width:6.8%"></div>
            </div>
          </div>
          <div class="flex justify-between text-[10px] text-neutral-500">
            <span>{t('ode.label.target')}: 15,000</span>
            <span class="text-red-400">6.8%</span>
          </div>
          <div class="text-[10px] text-neutral-500">
            <div>Peak Ca²⁺: <span class="text-white font-mono">171 nM</span></div>
            <div>Peak NFAT(nuclear): <span class="text-white font-mono">1.3%</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Key Finding callout -->
    <div class="bg-green-500/5 border border-green-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold text-green-400 mb-2">{t('ode.finding.title')}</h3>
      <p class="text-xs text-neutral-300 leading-relaxed" set:html={t('ode.finding.desc')} />
    </div>

    <!-- Parameters table -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('ode.params.title')}</h3>
      <div class="overflow-x-auto">
        <table class="text-[11px] w-full min-w-[500px]">
          <tr class="border-b border-white/10">
            <th class="text-left py-1.5 pr-3 text-neutral-500">{t('ode.params.col_param')}</th>
            <th class="text-left py-1.5 pr-3 text-neutral-500">{t('ode.params.col_value')}</th>
            <th class="text-left py-1.5 text-neutral-500">{t('ode.params.col_source')}</th>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 pr-3 text-neutral-300">MET channel conductance</td>
            <td class="py-1.5 pr-3 font-mono text-white">150 pS</td>
            <td class="py-1.5 text-neutral-500">Beurg et al. 2006</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 pr-3 text-neutral-300">Channels per bundle</td>
            <td class="py-1.5 pr-3 font-mono text-white">134</td>
            <td class="py-1.5 text-neutral-500">Fettiplace 2017</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 pr-3 text-neutral-300">Endolymphatic potential</td>
            <td class="py-1.5 pr-3 font-mono text-white">+80 mV</td>
            <td class="py-1.5 text-neutral-500">Standard</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 pr-3 text-neutral-300">Calcineurin Kd (Ca²⁺)</td>
            <td class="py-1.5 pr-3 font-mono text-white">500 nM</td>
            <td class="py-1.5 text-neutral-500">Stemmer & Klee 1994</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 pr-3 text-neutral-300">NFAT nuclear import t½</td>
            <td class="py-1.5 pr-3 font-mono text-white">~2 min</td>
            <td class="py-1.5 text-neutral-500">Tomida et al. 2003</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 pr-3 text-neutral-300">Promoter fold induction</td>
            <td class="py-1.5 pr-3 font-mono text-white">up to 62x</td>
            <td class="py-1.5 text-neutral-500">Wu et al. 2023</td>
          </tr>
          <tr class="border-b border-white/5">
            <td class="py-1.5 pr-3 text-neutral-300">Promoter leakage</td>
            <td class="py-1.5 pr-3 font-mono text-green-400">Zero (3 weeks)</td>
            <td class="py-1.5 text-neutral-500">Wu et al. 2023</td>
          </tr>
          <tr>
            <td class="py-1.5 pr-3 text-neutral-300">Apical compartment volume</td>
            <td class="py-1.5 pr-3 font-mono text-white">0.05 pL</td>
            <td class="py-1.5 text-neutral-500">Lumpkin & Bhatt 2001</td>
          </tr>
        </table>
      </div>
    </div>

    <!-- Sensitivity analysis -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('ode.sensitivity.title')}</h3>
      <p class="text-xs text-neutral-400 mb-3">{t('ode.sensitivity.desc')}</p>
      <div class="space-y-2">
        <div>
          <div class="flex justify-between text-[11px] mb-1">
            <span class="text-neutral-400">k_transcription_max</span>
            <span class="text-white font-mono">1.50</span>
          </div>
          <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-orange-500/60 rounded-full" style="width:100%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-[11px] mb-1">
            <span class="text-neutral-400">k_translation</span>
            <span class="text-white font-mono">1.50</span>
          </div>
          <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-orange-500/60 rounded-full" style="width:100%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-[11px] mb-1">
            <span class="text-neutral-400">n_channels</span>
            <span class="text-white font-mono">0.46</span>
          </div>
          <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-yellow-500/40 rounded-full" style="width:31%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-[11px] mb-1">
            <span class="text-neutral-400">Kd_CaN</span>
            <span class="text-white font-mono">-0.47</span>
          </div>
          <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-blue-500/40 rounded-full" style="width:31%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-[11px] mb-1">
            <span class="text-neutral-400">buffer_ratio</span>
            <span class="text-white font-mono">-0.46</span>
          </div>
          <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-blue-500/40 rounded-full" style="width:31%"></div>
          </div>
        </div>
      </div>
      <p class="text-[10px] text-neutral-500 mt-3">{t('ode.sensitivity.note')}</p>
    </div>

    <!-- AF3 structural validation — 3D viewer -->
    <div class="bg-cyan-500/5 border border-cyan-500/20 rounded-lg overflow-hidden mb-6">
      <div id="v-ode-job8" style="width:100%;height:280px;position:relative;overflow:hidden;background:#080808;cursor:grab;">
        <div style="color:#555;display:flex;align-items:center;justify-content:center;height:100%;font-size:11px;">Loading 3D model...</div>
      </div>
      <div class="p-5">
        <h3 class="text-sm font-semibold text-cyan-400 mb-2">{t('ode.af3val.title')}</h3>
        <p class="text-xs text-neutral-300 leading-relaxed mb-3" set:html={t('ode.af3val.desc')} />
        <div class="grid grid-cols-3 gap-3 mb-3">
          <div class="bg-black/30 rounded p-2 text-center">
            <div class="text-[10px] text-cyan-400 mb-0.5">NFAT</div>
            <div class="w-3 h-3 rounded-full bg-[#22d3ee] mx-auto mb-1"></div>
            <div class="text-[10px] text-neutral-500">chain A</div>
          </div>
          <div class="bg-black/30 rounded p-2 text-center">
            <div class="text-[10px] text-blue-400 mb-0.5">Calcineurin A</div>
            <div class="w-3 h-3 rounded-full bg-[#4a9eff] mx-auto mb-1"></div>
            <div class="text-[10px] text-neutral-500">chain B</div>
          </div>
          <div class="bg-black/30 rounded p-2 text-center">
            <div class="text-[10px] text-purple-400 mb-0.5">Calcineurin B</div>
            <div class="w-3 h-3 rounded-full bg-[#a78bfa] mx-auto mb-1"></div>
            <div class="text-[10px] text-neutral-500">chain C</div>
          </div>
        </div>
        <ul class="space-y-1.5 text-xs text-neutral-400 mb-3">
          <li class="flex items-start gap-2">
            <span class="text-green-400 mt-0.5">●</span>
            <span set:html={t('ode.af3val.pair1')} />
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-400 mt-0.5">●</span>
            <span set:html={t('ode.af3val.pair2')} />
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-400 mt-0.5">●</span>
            <span set:html={t('ode.af3val.pair3')} />
          </li>
        </ul>
        <p class="text-[11px] text-neutral-500 leading-relaxed">{t('ode.af3val.note')}</p>
      </div>
    </div>

    <!-- Source code -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5">
      <h3 class="text-sm font-semibold mb-2">{t('ode.code.title')}</h3>
      <p class="text-xs text-neutral-400 mb-3">{t('ode.code.desc')}</p>
      <a href="https://github.com/lyfar/strc-research/blob/main/ode_model.py" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-3 py-2 bg-white/5 hover:bg-white/10 rounded text-xs text-white no-underline transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        {t('ode.code.link')}
      </a>
    </div>
  </div>
</section>

<!-- 3Dmol.js viewer for ODE section Job 8 -->
<script is:inline>
(function() {
  function initODEViewer() {
    if (typeof $3Dmol === 'undefined') { setTimeout(initODEViewer, 300); return; }
    var el = document.getElementById('v-ode-job8');
    if (!el) return;
    fetch('/models/job8-nfatc1-calcineurin.cif').then(function(r) { return r.text(); }).then(function(data) {
      el.innerHTML = '';
      var v = $3Dmol.createViewer(el, {backgroundColor: '#080808'});
      v.addModel(data, 'cif');
      v.setStyle({chain: 'A'}, {cartoon: {color: '#22d3ee'}});
      v.setStyle({chain: 'B'}, {cartoon: {color: '#4a9eff'}});
      v.setStyle({chain: 'C'}, {cartoon: {color: '#a78bfa'}});
      v.zoomTo();
      v.render();
      v.spin('y', 0.3);
    }).catch(function() {
      el.innerHTML = '<div style="color:#555;text-align:center;padding:20px;font-size:10px;">Model loading failed</div>';
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initODEViewer);
  } else {
    initODEViewer();
  }
})();
</script>
