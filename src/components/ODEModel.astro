---
// ODE Model Results — Computational proof of concept for mechanosensitive STRC expression
import { useTranslations } from '../lib/i18n';
import ScenariosGrid from './ode-model/ScenariosGrid.astro';
import KeyFinding from './ode-model/KeyFinding.astro';
import ParametersTable from './ode-model/ParametersTable.astro';
import SensitivityAnalysis from './ode-model/SensitivityAnalysis.astro';
import SourceCode from './ode-model/SourceCode.astro';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="ode-model" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('ode.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-cyan-500/20 text-cyan-400 font-semibold">DAY 3</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-green-500/20 text-green-400 font-semibold">{t('ode.badge')}</span>
    </div>
    <p class="text-neutral-400 text-sm mb-8 max-w-3xl">{t('ode.desc')}</p>

    <ScenariosGrid lang={lang} />
    <KeyFinding lang={lang} />
    <ParametersTable lang={lang} />
    <SensitivityAnalysis lang={lang} />
    <SourceCode lang={lang} />
  </div>
</section>
