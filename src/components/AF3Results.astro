---
// AlphaFold 3 Experiment Results — 6 jobs with 3D viewers
import SectionHeader from './af3-results/SectionHeader.astro';
import OriginalJobs from './af3-results/OriginalJobs.astro';
import ValidationJobs from './af3-results/ValidationJobs.astro';
import FinalJobs from './af3-results/FinalJobs.astro';
import Summary from './af3-results/Summary.astro';
import ViewerScript from './af3-results/ViewerScript.astro';

const { lang = 'en' } = Astro.props;
---
<section class="px-6 py-16 border-t border-white/5">
  <div class="max-w-5xl mx-auto">
    <SectionHeader lang={lang} />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      <OriginalJobs lang={lang} />
      <ValidationJobs lang={lang} />
      <FinalJobs lang={lang} />
    </div>

    <!-- Summary -->
    <Summary lang={lang} />
  </div>
</section>

<ViewerScript />
