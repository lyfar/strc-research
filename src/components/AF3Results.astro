---
// AlphaFold 3 Experiment Results — 6 jobs with 3D viewers
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="px-6 py-16 border-t border-white/5">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('af3results.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-purple-500/20 text-purple-400 font-semibold">{t('af3results.badge')}</span>
    </div>
    <p class="text-neutral-400 text-sm mb-8 max-w-3xl">
      {t('af3results.desc')}
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">

      <!-- Job 1 -->
      <a href="https://alphafoldserver.com/fold/739cbeb76239c7c8" target="_blank" rel="noopener" class="bg-white/[0.02] border border-white/5 rounded-lg overflow-hidden no-underline group hover:border-white/10 transition-colors">
        <div id="v-job1" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
        <div class="p-3">
          <div class="text-[10px] text-neutral-500 mb-1">Question 1</div>
          <div class="text-xs font-semibold text-white mb-1">{t('af3results.job1.title')}</div>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono text-yellow-400">{t('af3results.job1.score')}</span>
            <span class="text-[10px] text-neutral-500">Low confidence</span>
          </div>
          <p class="text-[10px] text-neutral-500 leading-relaxed">{t('af3results.job1.desc')}</p>
        </div>
      </a>

      <!-- Job 2 -->
      <a href="https://alphafoldserver.com/fold/1f78a8dd5afe06b2" target="_blank" rel="noopener" class="bg-white/[0.02] border border-green-500/20 rounded-lg overflow-hidden no-underline group hover:border-green-500/30 transition-colors">
        <div id="v-job2" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
        <div class="p-3">
          <div class="text-[10px] text-neutral-500 mb-1">Question 2</div>
          <div class="text-xs font-semibold text-green-400 mb-1">{t('af3results.job2.title')}</div>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono text-green-400">{t('af3results.job2.score')}</span>
            <span class="text-[10px] text-neutral-500">vs 0.47 baseline</span>
          </div>
          <p class="text-[10px] text-neutral-400 leading-relaxed">{t('af3results.job2.desc')}</p>
        </div>
      </a>

      <!-- Job 3: E1659A mutant -->
      <a href="https://alphafoldserver.com/fold/1bdcb17b9bcb4a6c" target="_blank" rel="noopener" class="bg-white/[0.02] border border-yellow-500/20 rounded-lg overflow-hidden no-underline group hover:border-yellow-500/30 transition-colors">
        <div id="v-job3" style="width:100%;height:180px;position:relative;overflow:hidden;background:#080808;"></div>
        <div class="p-3">
          <div class="text-[10px] text-neutral-500 mb-1">Question 3</div>
          <div class="text-xs font-semibold text-yellow-400 mb-1">{t('af3results.job3.title')}</div>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono text-yellow-400">{t('af3results.job3.score')}</span>
            <span class="text-[10px] text-neutral-500">= wildtype 0.63</span>
          </div>
          <p class="text-[10px] text-neutral-400 leading-relaxed">{t('af3results.job3.desc')}</p>
        </div>
      </a>

      <!-- Job 4 -->
