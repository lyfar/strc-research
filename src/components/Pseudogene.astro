---
// Why AlphaMissense Matters for STRC (Pseudogene Problem)
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400 mb-6">{t('pseudogene.title')}</h2>
    <div class="bg-orange-500/10 border border-orange-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold text-orange-400 mb-2">{t('pseudogene.box.title')}</h3>
      <p class="text-sm text-neutral-300 leading-relaxed">
        {t('pseudogene.box.desc')}
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-3">
      <div class="bg-white/[0.02] border border-red-500/10 rounded-lg p-4">
        <div class="text-xs text-red-400 font-semibold mb-1">SIFT</div>
        <div class="text-xs text-neutral-400">{t('pseudogene.sift.desc')}</div>
      </div>
      <div class="bg-white/[0.02] border border-red-500/10 rounded-lg p-4">
        <div class="text-xs text-red-400 font-semibold mb-1">PolyPhen-2</div>
        <div class="text-xs text-neutral-400">{t('pseudogene.polyphen.desc')}</div>
      </div>
      <div class="bg-white/[0.02] border border-green-500/10 rounded-lg p-4">
        <div class="text-xs text-green-400 font-semibold mb-1">CADD</div>
        <div class="text-xs text-neutral-400">{t('pseudogene.cadd.desc')}</div>
      </div>
      <div class="bg-white/[0.02] border border-green-500/10 rounded-lg p-4">
        <div class="text-xs text-green-400 font-semibold mb-1">AlphaMissense</div>
        <div class="text-xs text-neutral-400">{t('pseudogene.alphamissense.desc')}</div>
      </div>
    </div>
    <p class="text-xs text-neutral-500 mt-4">
      {t('pseudogene.footnote')}
    </p>
  </div>
</section>
