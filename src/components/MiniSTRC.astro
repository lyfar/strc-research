---
// Mini-STRC Hypothesis section
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="mini-strc" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('ministrc.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-purple-500/20 text-purple-400 font-semibold">{t('ministrc.badge_new')}</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-yellow-500/20 text-yellow-400 font-semibold">{t('ministrc.badge_comp')}</span>
    </div>
    <p class="text-neutral-400 text-sm mb-8 max-w-2xl">
      {t('ministrc.desc')}
    </p>

    <!-- The problem -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('ministrc.packaging.title')}</h3>
      <div class="flex items-center gap-3 text-xs mb-4">
        <div class="flex-1">
          <div class="flex items-center justify-between mb-1">
            <span class="text-neutral-400">{t('ministrc.packaging.full_cdna')}</span>
            <span class="text-red-400 font-mono">5325 bp</span>
          </div>
          <div class="h-3 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-red-500/60 rounded-full" style="width:100%"></div>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-3 text-xs mb-4">
        <div class="flex-1">
          <div class="flex items-center justify-between mb-1">
            <span class="text-neutral-400">{t('ministrc.packaging.aav_limit')}</span>
            <span class="text-yellow-400 font-mono">~4400 bp</span>
          </div>
          <div class="h-3 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-yellow-500/60 rounded-full" style="width:82.6%"></div>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-3 text-xs">
        <div class="flex-1">
          <div class="flex items-center justify-between mb-1">
            <span class="text-neutral-400">{t('ministrc.packaging.mini')}</span>
            <span class="text-green-400 font-mono font-bold">3984 bp</span>
          </div>
          <div class="h-3 bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-green-500/60 rounded-full" style="width:74.8%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- AlphaFold insight -->
    <div class="bg-white/[0.02] border border-purple-500/20 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-3">{t('ministrc.alphafold.title')}</h3>
      <p class="text-xs text-neutral-400 leading-relaxed mb-4" set:html={t('ministrc.alphafold.desc')} />
      
      <!-- pLDDT profile visualization -->
      <div class="relative h-20 bg-black/30 rounded overflow-hidden mb-3">
        <div class="absolute inset-0 flex items-end">
          <!-- Simplified pLDDT bars -->
          <div style="width:6.3%;height:17%" class="bg-red-500/60" title="1-114: avg pLDDT 30.6"></div>
          <div style="width:1%;height:55%" class="bg-yellow-500/40" title="115-131"></div>
          <div style="width:6.8%;height:21%" class="bg-red-500/60" title="132-251: avg pLDDT 37.0"></div>
          <div style="width:3.3%;height:60%" class="bg-yellow-500/40" title="252-308"></div>
          <div style="width:4.5%;height:25%" class="bg-red-500/50" title="309-387: disordered"></div>
          <div style="width:3.5%;height:55%" class="bg-yellow-500/40" title="388-448"></div>
          <div style="width:2.1%;height:27%" class="bg-red-500/50" title="449-485: disordered"></div>
          <div style="width:0.6%;height:55%" class="bg-yellow-500/40" title="486-495"></div>
          <div style="width:6.8%;height:18%" class="bg-red-500/60" title="496-615: avg pLDDT 31.1"></div>
          <div style="width:3.8%;height:60%" class="bg-yellow-500/50" title="616-682"></div>
          <div style="width:22.1%;height:78%" class="bg-blue-500/60" title="663-1074: LRR domain"></div>
          <div style="width:39.2%;height:85%" class="bg-blue-500/70" title="1075-1775: C-terminal"></div>
        </div>
        <!-- Position 1659 marker -->
        <div class="absolute bottom-0 bg-red-500" style="left:93.5%;width:2px;height:100%;"></div>
        <div class="absolute top-0 text-[9px] text-red-400 font-mono" style="left:90%;">E1659</div>
        <!-- Cutoff line -->
        <div class="absolute bottom-0 border-l-2 border-dashed border-green-500/50" style="left:34.7%;height:100%;"></div>
        <div class="absolute bottom-1 text-[9px] text-green-400 font-mono" style="left:28%;">{t('ministrc.chart.cuthere')}</div>
      </div>
      
      <div class="flex justify-between text-[10px] text-neutral-500 mb-4">
        <span>1</span>
        <span>{t('ministrc.chart.nterm')}</span>
        <span>{t('ministrc.chart.lrr')}</span>
        <span>{t('ministrc.chart.cterm')}</span>
        <span>1775</span>
      </div>
    </div>

    <!-- What to remove / what to keep -->
    <div class="grid md:grid-cols-2 gap-4 mb-6">
      <div class="bg-white/[0.02] border border-red-500/10 rounded-lg p-4">
        <h3 class="text-xs font-semibold text-red-400 mb-2">{t('ministrc.remove.title')}</h3>
        <ul class="text-xs text-neutral-400 space-y-1.5">
          <li set:html={t('ministrc.remove.r1')} />
          <li set:html={t('ministrc.remove.r2')} />
          <li set:html={t('ministrc.remove.r3')} />
          <li set:html={t('ministrc.remove.r4')} />
          <li set:html={t('ministrc.remove.r5')} />
        </ul>
        <p class="text-[10px] text-neutral-500 mt-2" set:html={t('ministrc.remove.footnote')} />
      </div>
      <div class="bg-white/[0.02] border border-green-500/10 rounded-lg p-4">
        <h3 class="text-xs font-semibold text-green-400 mb-2">{t('ministrc.keep.title')}</h3>
        <ul class="text-xs text-neutral-400 space-y-1.5">
          <li set:html={t('ministrc.keep.r1')} />
          <li set:html={t('ministrc.keep.r2')} />
          <li set:html={t('ministrc.keep.r3')} />
          <li set:html={t('ministrc.keep.r4')} />
          <li>{t('ministrc.keep.r5')}</li>
        </ul>
        <p class="text-[10px] text-green-400 mt-2 font-semibold" set:html={t('ministrc.keep.footnote')} />
      </div>
    </div>

    <!-- Precedent -->
    <div class="bg-white/[0.02] border border-white/5 rounded-lg p-5 mb-6">
      <h3 class="text-sm font-semibold mb-2">{t('ministrc.precedent.title')}</h3>
      <p class="text-xs text-neutral-400 leading-relaxed">
        {t('ministrc.precedent.desc')}
      </p>
    </div>

    <!-- Caveat -->
    <div class="bg-yellow-500/10 border border-yellow-500/20 rounded-lg p-4">
      <p class="text-xs text-neutral-300" set:html={t('ministrc.caveat')} />
    </div>
  </div>
</section>
