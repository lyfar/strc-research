---
import { useTranslations } from '../lib/i18n';

// Abstract / verdict
import UltraMiniStatus from './mini-strc/UltraMiniStatus.astro';

// Intro + hypothesis
import Intro from './mini-strc/Intro.astro';
import HypothesisUltraMini from './mini-strc/HypothesisUltraMini.astro';

// Master tables
import AllExperiments from './mini-strc/AllExperiments.astro';
import OtherComputations from './mini-strc/OtherComputations.astro';

// Truncation design path (Full → Mini → Ultra)
import TruncationPath from './mini-strc/TruncationPath.astro';

// Target biology
import TargetBiology from './mini-strc/TargetBiology.astro';

// Interface gates (three Ultra-Mini AF3 gates)
import UltraMiniGOLDInterface from './mini-strc/UltraMiniGOLDInterface.astro';
import UltraMiniFullTMEM145 from './mini-strc/UltraMiniFullTMEM145.astro';
import UltraMiniHomodimer from './mini-strc/UltraMiniHomodimer.astro';

// Orthogonal + context + engineering + precedent + next
import OrthogonalChecks from './mini-strc/OrthogonalChecks.astro';
import EvolutionContext from './mini-strc/EvolutionContext.astro';
import UltraMiniCassette from './mini-strc/UltraMiniCassette.astro';
import PrecedentCard from './mini-strc/PrecedentCard.astro';
import UltraMiniWetlab from './mini-strc/UltraMiniWetlab.astro';

// Appendix — raw 3D viewers + 3Dmol init script
import AF3Expandable from './mini-strc/AF3Expandable.astro';

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section id="mini-strc" class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2 flex-wrap">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('ministrc.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-purple-500/20 text-purple-400 font-semibold">{t('ministrc.badge_comp')}</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-emerald-500/20 text-emerald-400 font-semibold">23 AF3 JOBS</span>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-emerald-500/15 text-emerald-400 font-semibold border border-emerald-500/30">CLINICAL CANDIDATE · ULTRA-MINI</span>
    </div>
    <p class="text-neutral-400 text-sm mb-8 max-w-2xl">
      {t('ministrc.desc')}
    </p>

    <UltraMiniStatus lang={lang} />

    <Intro lang={lang} />
    <HypothesisUltraMini lang={lang} />

    <AllExperiments lang={lang} />
    <OtherComputations lang={lang} />

    <TruncationPath lang={lang} />
    <TargetBiology lang={lang} />

    <UltraMiniGOLDInterface lang={lang} />
    <UltraMiniFullTMEM145 lang={lang} />
    <UltraMiniHomodimer lang={lang} />

    <OrthogonalChecks lang={lang} />
    <EvolutionContext lang={lang} />

    <UltraMiniCassette lang={lang} />
    <PrecedentCard lang={lang} />
    <UltraMiniWetlab lang={lang} />

    <AF3Expandable lang={lang} />
  </div>
</section>
