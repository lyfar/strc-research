---
// Evolutionary Conservation section
import { useTranslations } from '../lib/i18n';
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="px-6 py-16 border-t border-white/5">
  <div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{t('conservation.title')}</h2>
      <span class="px-1.5 py-0.5 text-[10px] rounded bg-green-500/20 text-green-400 font-semibold">{t('conservation.badge_new')}</span>
    </div>
    <p class="text-neutral-400 text-sm mb-6">
      {t('conservation.desc')}
    </p>
    <div class="bg-white/[0.02] border border-white/5 rounded-lg overflow-x-auto">
      <table class="w-full min-w-[500px] text-xs">
        <thead>
          <tr class="border-b border-white/5">
            <th class="text-left px-4 py-2 text-neutral-400">{t('conservation.col_species')}</th>
            <th class="text-left px-4 py-2 text-neutral-400">{t('conservation.col_position')}</th>
            <th class="text-left px-4 py-2 text-neutral-400">{t('conservation.col_residue')}</th>
            <th class="text-left px-4 py-2 text-neutral-400">{t('conservation.col_context')}</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-white/5 bg-red-500/5"><td class="px-4 py-2 font-medium">{t('conservation.species_human')}</td><td class="px-4 py-2 font-mono text-neutral-400">1659</td><td class="px-4 py-2 font-mono text-red-400 font-bold">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-red-400 font-bold">E</span>IGTIAAG</td></tr>
          <tr class="border-b border-white/5"><td class="px-4 py-2">{t('conservation.species_mouse')}</td><td class="px-4 py-2 font-mono text-neutral-400">1693</td><td class="px-4 py-2 font-mono text-green-400">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-green-400">E</span>IGTIAAG</td></tr>
          <tr class="border-b border-white/5"><td class="px-4 py-2">{t('conservation.species_rat')}</td><td class="px-4 py-2 font-mono text-neutral-400">1693</td><td class="px-4 py-2 font-mono text-green-400">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-green-400">E</span>IGTIAAG</td></tr>
          <tr class="border-b border-white/5"><td class="px-4 py-2">{t('conservation.species_cow')}</td><td class="px-4 py-2 font-mono text-neutral-400">1647</td><td class="px-4 py-2 font-mono text-green-400">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-green-400">E</span>IGTIAAG</td></tr>
          <tr class="border-b border-white/5"><td class="px-4 py-2">{t('conservation.species_monkey')}</td><td class="px-4 py-2 font-mono text-neutral-400">1659</td><td class="px-4 py-2 font-mono text-green-400">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-green-400">E</span>IGTIAAG</td></tr>
          <tr class="border-b border-white/5"><td class="px-4 py-2">{t('conservation.species_pig')}</td><td class="px-4 py-2 font-mono text-neutral-400">1650</td><td class="px-4 py-2 font-mono text-green-400">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-green-400">E</span>IGTIAAG</td></tr>
          <tr class="border-b border-white/5"><td class="px-4 py-2">{t('conservation.species_dog')}</td><td class="px-4 py-2 font-mono text-neutral-400">1649</td><td class="px-4 py-2 font-mono text-green-400">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-green-400">E</span>IGTIAAG</td></tr>
          <tr class="border-b border-white/5"><td class="px-4 py-2">{t('conservation.species_bat')}</td><td class="px-4 py-2 font-mono text-neutral-400">1646</td><td class="px-4 py-2 font-mono text-green-400">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-green-400">E</span>IGTIAAG</td></tr>
          <tr><td class="px-4 py-2">{t('conservation.species_bear')}</td><td class="px-4 py-2 font-mono text-neutral-400">1643</td><td class="px-4 py-2 font-mono text-green-400">E</td><td class="px-4 py-2 font-mono text-neutral-500">PEIFT<span class="text-green-400">E</span>IGTIAAG</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-neutral-500 mt-3">
      {t('conservation.footnote')}
    </p>
  </div>
</section>
